---
import { createSupabaseServerClient } from '@/lib/supabase';
import '@/styles/globals.css';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

// Encerra a sessão — este é o ponto correto para limpar cookies (página real, não redirect)
await supabase.auth.signOut();
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>Acesso desativado — UNAFIT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-zinc-950 text-white flex items-center justify-center p-4">

  <div class="w-full max-w-md text-center space-y-6">

    <!-- Ícone -->
    <div class="flex justify-center">
      <div class="flex h-20 w-20 items-center justify-center rounded-full bg-red-900/30 border border-red-800/50">
        <svg class="h-10 w-10 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
        </svg>
      </div>
    </div>

    <!-- Logo -->
    <img src="/logo-unafit.png" alt="UNAFIT" class="h-8 w-auto mx-auto opacity-60" />

    <!-- Mensagem -->
    <div class="space-y-2">
      <h1 class="text-2xl font-bold text-white">Acesso desativado</h1>
      <p class="text-zinc-400 leading-relaxed">
        Sua conta foi desativada e não tem mais autorização para acessar o sistema.
      </p>
      <p class="text-zinc-500 text-sm">
        Entre em contato com o responsável pela academia para mais informações.
      </p>
    </div>

    <!-- Botão voltar -->
    <a href="/login"
      class="inline-flex items-center justify-center gap-2 w-full py-3 px-6 rounded-xl bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 hover:text-white font-medium transition-colors">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      Voltar ao início
    </a>

  </div>

</body>
</html>
