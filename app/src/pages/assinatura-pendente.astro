---
import '@/styles/globals.css';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const admin = createSupabaseAdminClient();

const { data: profile } = await admin
  .from('profiles')
  .select('nome_completo, academia_id, role')
  .eq('id', user.id)
  .single();

if (!profile || profile.role === 'saas_admin') return Astro.redirect('/dashboard');

const { data: academia } = profile?.academia_id
  ? await admin.from('academias').select('nome, logo_url').eq('id', profile.academia_id).single()
  : { data: null };

// Busca faturas em atraso (pendente ou vencida)
const { data: faturas } = profile?.academia_id
  ? await admin
      .from('saas_faturas')
      .select('id, descricao, valor, data_vencimento, status, invoice_url, boleto_url, boleto_linha, pix_qr_code_base64, pix_copia_cola, asaas_payment_id')
      .eq('academia_id', profile.academia_id)
      .in('status', ['pendente', 'vencido'])
      .order('data_vencimento', { ascending: false })
  : { data: [] };

const hoje = new Date();
const carenciaData = new Date();
carenciaData.setDate(carenciaData.getDate() - 10);

function diasAtraso(dataVenc: string): number {
  const venc = new Date(dataVenc + 'T12:00:00');
  const diff = hoje.getTime() - venc.getTime();
  return Math.max(0, Math.floor(diff / (1000 * 60 * 60 * 24)));
}
---

<!DOCTYPE html>
<html lang="pt-BR" class="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <title>Pagamento Pendente — UNAFIT</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body class="min-h-screen bg-zinc-950 text-white font-[Inter,sans-serif]">

  <!-- Header mínimo -->
  <header class="border-b border-zinc-800 px-6 py-4 flex items-center justify-between">
    <img src="/logo-unafit.png" alt="UNAFIT" class="h-8 w-auto" />
    <a href="/logout" class="text-xs text-zinc-500 hover:text-zinc-300 transition-colors">Sair</a>
  </header>

  <main class="max-w-2xl mx-auto px-4 py-10 space-y-8">

    <!-- Alerta de bloqueio -->
    <div class="rounded-2xl border border-red-600/40 bg-red-900/10 p-6 flex gap-4">
      <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-full bg-red-900/30 border border-red-600/40">
        <svg class="h-6 w-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
        </svg>
      </div>
      <div>
        <h1 class="text-lg font-bold text-red-400">Acesso bloqueado — pagamento em atraso</h1>
        <p class="text-sm text-zinc-400 mt-1">
          {academia?.nome ?? 'Sua academia'} possui {faturas?.length ?? 0} fatura{(faturas?.length ?? 0) !== 1 ? 's' : ''} em aberto.
          Realize o pagamento para reativar o acesso imediatamente.
        </p>
      </div>
    </div>

    <!-- Faturas em atraso -->
    {faturas && faturas.length > 0 ? (
      <div class="space-y-5">
        {faturas.map((f: any) => {
          const atraso = diasAtraso(f.data_vencimento);
          return (
            <div class="rounded-2xl border border-red-700/30 bg-zinc-900 overflow-hidden">
              <!-- Cabeçalho da fatura -->
              <div class="px-5 py-4 flex items-center justify-between gap-3 border-b border-zinc-800">
                <div>
                  <p class="font-semibold text-white">{f.descricao}</p>
                  <p class="text-xs text-red-400 mt-0.5">
                    Venceu em {new Date(f.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}
                    {atraso > 0 && ` · ${atraso} dia${atraso !== 1 ? 's' : ''} em atraso`}
                  </p>
                </div>
                <span class="text-xl font-bold text-white shrink-0">
                  {Number(f.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                </span>
              </div>

              <!-- Métodos de pagamento -->
              <div class="p-5 space-y-4">

                {f.invoice_url && (
                  <a href={f.invoice_url} target="_blank"
                    class="flex items-center justify-center gap-2 w-full rounded-xl bg-primary py-3 text-sm font-bold text-white hover:bg-primary/90 transition-colors">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    Pagar agora (PIX · Boleto · Cartão)
                  </a>
                )}

                <div class="grid sm:grid-cols-2 gap-4">
                  {f.pix_qr_code_base64 && (
                    <div class="rounded-xl border border-zinc-800 p-4 text-center space-y-3">
                      <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">PIX — pagamento instantâneo</p>
                      <img src={`data:image/png;base64,${f.pix_qr_code_base64}`}
                        alt="QR Code PIX" class="h-36 w-36 mx-auto rounded-lg" />
                      {f.pix_copia_cola && (
                        <button id={`pix-${f.id}`}
                          onclick={`navigator.clipboard.writeText('${f.pix_copia_cola}').then(()=>{document.getElementById('pix-${f.id}').textContent='Copiado!';setTimeout(()=>document.getElementById('pix-${f.id}').textContent='Copiar código PIX',2000)})`}
                          class="w-full py-2 rounded-lg border border-zinc-700 text-xs text-zinc-400 hover:text-primary hover:border-primary/40 transition-colors">
                          Copiar código PIX
                        </button>
                      )}
                    </div>
                  )}

                  {f.boleto_linha && (
                    <div class="rounded-xl border border-zinc-800 p-4 space-y-3">
                      <p class="text-xs font-bold text-zinc-400 uppercase tracking-wider">Boleto bancário</p>
                      <p class="text-[11px] font-mono text-zinc-500 break-all leading-relaxed bg-zinc-950 rounded-lg p-2">
                        {f.boleto_linha}
                      </p>
                      <button id={`bol-${f.id}`}
                        onclick={`navigator.clipboard.writeText('${f.boleto_linha}').then(()=>{document.getElementById('bol-${f.id}').textContent='Copiado!';setTimeout(()=>document.getElementById('bol-${f.id}').textContent='Copiar código de barras',2000)})`}
                        class="w-full py-2 rounded-lg border border-zinc-700 text-xs text-zinc-400 hover:text-primary hover:border-primary/40 transition-colors">
                        Copiar código de barras
                      </button>
                      {f.boleto_url && (
                        <a href={f.boleto_url} target="_blank"
                          class="block text-center text-xs text-primary hover:underline">
                          Ver boleto (PDF)
                        </a>
                      )}
                    </div>
                  )}
                </div>

                {!f.invoice_url && !f.pix_qr_code_base64 && !f.boleto_linha && (
                  <p class="text-sm text-zinc-500 text-center py-2">
                    Cobrança sendo processada. Entre em contato com o suporte.
                  </p>
                )}
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-10 text-zinc-500">
        <p>Nenhuma fatura pendente encontrada.</p>
        <a href="/dashboard" class="mt-4 inline-block text-sm text-primary hover:underline">
          Voltar ao painel
        </a>
      </div>
    )}

    <!-- Rodapé de suporte -->
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 text-sm text-zinc-400 text-center space-y-1">
      <p>Após o pagamento, o acesso é reativado automaticamente em até <strong class="text-white">5 minutos</strong>.</p>
      <p>Dúvidas? <a href="mailto:suporte@unafit.com.br" class="text-primary hover:underline">suporte@unafit.com.br</a></p>
    </div>

  </main>

</body>
</html>
