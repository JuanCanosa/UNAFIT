---
const SUPABASE_URL      = import.meta.env.SUPABASE_URL      ?? import.meta.env.PUBLIC_SUPABASE_URL;
const SUPABASE_ANON_KEY = import.meta.env.SUPABASE_ANON_KEY ?? import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
---

<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Criar senha — UNAFIT</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: #0a0a0a;
      font-family: 'Inter', -apple-system, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background-image: radial-gradient(ellipse at 50% 0%, rgba(220,38,38,0.12) 0%, transparent 60%);
    }

    .card {
      width: 100%;
      max-width: 420px;
      background: #111111;
      border: 1px solid #1f1f1f;
      border-radius: 16px;
      padding: 40px 36px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.5);
    }

    .logo-area {
      text-align: center;
      margin-bottom: 32px;
    }

    .logo-area img {
      max-height: 52px;
      max-width: 160px;
      object-fit: contain;
    }

    .logo-area .academy-name {
      font-size: 20px;
      font-weight: 700;
      color: #ffffff;
    }

    .logo-area .subtitle {
      margin-top: 8px;
      font-size: 13px;
      color: #52525b;
    }

    h1 {
      font-size: 18px;
      font-weight: 700;
      color: #ffffff;
      margin-bottom: 6px;
    }

    .desc {
      font-size: 14px;
      color: #71717a;
      margin-bottom: 28px;
      line-height: 1.5;
    }

    label {
      display: block;
      font-size: 12px;
      font-weight: 500;
      color: #a1a1aa;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    input[type="password"] {
      width: 100%;
      padding: 11px 14px;
      background: #0f0f0f;
      border: 1px solid #27272a;
      border-radius: 8px;
      color: #ffffff;
      font-size: 15px;
      outline: none;
      transition: border-color 0.15s;
      margin-bottom: 16px;
    }

    input[type="password"]:focus {
      border-color: #dc2626;
    }

    .strength-bar {
      height: 3px;
      background: #1f1f1f;
      border-radius: 2px;
      margin-top: -12px;
      margin-bottom: 16px;
      overflow: hidden;
    }

    .strength-bar-fill {
      height: 100%;
      border-radius: 2px;
      transition: width 0.2s, background 0.2s;
      width: 0%;
      background: #dc2626;
    }

    .btn {
      width: 100%;
      padding: 13px;
      background: #dc2626;
      color: #ffffff;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s, opacity 0.15s;
      margin-top: 4px;
    }

    .btn:hover { background: #b91c1c; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .alert {
      padding: 12px 14px;
      border-radius: 8px;
      font-size: 13px;
      margin-bottom: 20px;
      display: none;
    }

    .alert.error {
      background: rgba(220,38,38,0.1);
      border: 1px solid rgba(220,38,38,0.3);
      color: #fca5a5;
    }

    .alert.success {
      background: rgba(34,197,94,0.1);
      border: 1px solid rgba(34,197,94,0.3);
      color: #86efac;
    }

    .loading-state {
      text-align: center;
      padding: 20px 0;
    }

    .spinner {
      width: 32px;
      height: 32px;
      border: 2px solid #27272a;
      border-top-color: #dc2626;
      border-radius: 50%;
      animation: spin 0.7s linear infinite;
      margin: 0 auto 16px;
    }

    @keyframes spin { to { transform: rotate(360deg); } }

    .loading-state p { color: #52525b; font-size: 14px; }

    #form-area { display: none; }
    #success-area { display: none; text-align: center; padding: 10px 0; }
    #error-area { display: none; text-align: center; padding: 10px 0; }

    .check-icon {
      width: 48px;
      height: 48px;
      background: rgba(34,197,94,0.1);
      border: 1px solid rgba(34,197,94,0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 22px;
    }

    .error-icon {
      width: 48px;
      height: 48px;
      background: rgba(220,38,38,0.1);
      border: 1px solid rgba(220,38,38,0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 16px;
      font-size: 22px;
    }

    #success-area h2, #error-area h2 { font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 8px; }
    #success-area p, #error-area p { font-size: 14px; color: #71717a; margin-bottom: 24px; line-height: 1.5; }

    .btn-secondary {
      display: inline-block;
      padding: 11px 24px;
      background: transparent;
      border: 1px solid #27272a;
      color: #a1a1aa;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      transition: border-color 0.15s, color 0.15s;
    }

    .btn-secondary:hover { border-color: #52525b; color: #fff; }
  </style>
</head>
<body>
  <div class="card">
    <!-- Logo da academia (preenchido via JS) -->
    <div class="logo-area" id="logo-area" style="display:none">
      <img id="academy-logo" src="" alt="" style="display:none" />
      <div id="academy-name" class="academy-name"></div>
      <div class="subtitle">Sistema de Gestão</div>
    </div>

    <!-- Carregando sessão -->
    <div id="loading-area" class="loading-state">
      <div class="spinner"></div>
      <p>Verificando link de redefinição…</p>
    </div>

    <!-- Erro: link expirado/inválido -->
    <div id="error-area">
      <div class="error-icon">✕</div>
      <h2>Link expirado ou inválido</h2>
      <p id="error-detail">Peça ao responsável pela academia que envie um novo link de redefinição.</p>
      <a href="/login" class="btn-secondary">Ir para o login →</a>
    </div>

    <!-- Formulário -->
    <div id="form-area">
      <h1>Crie sua senha</h1>
      <p class="desc">Escolha uma senha segura para acessar o sistema.</p>

      <div id="alert-msg" class="alert"></div>

      <form id="reset-form">
        <label for="password">Nova senha</label>
        <input type="password" id="password" name="password" placeholder="Mínimo 8 caracteres" minlength="8" required autocomplete="new-password" />
        <div class="strength-bar"><div class="strength-bar-fill" id="strength-fill"></div></div>

        <label for="confirm">Confirmar senha</label>
        <input type="password" id="confirm" name="confirm" placeholder="Repita a senha" minlength="8" required autocomplete="new-password" />

        <button type="submit" class="btn" id="submit-btn">Salvar senha</button>
      </form>
    </div>

    <!-- Sucesso -->
    <div id="success-area">
      <div class="check-icon">✓</div>
      <h2>Senha criada com sucesso!</h2>
      <p>Redirecionando para o sistema da sua academia em instantes…</p>
      <a href="/login" class="btn-secondary">Entrar agora →</a>
    </div>
  </div>

  <!-- Config injetada pelo servidor via data attributes -->
  <div id="app-config"
    data-url={SUPABASE_URL}
    data-key={SUPABASE_ANON_KEY}
    style="display:none"
    aria-hidden="true">
  </div>

  <script type="module">
    import { createClient } from 'https://esm.sh/@supabase/supabase-js@2';

    const cfg = document.getElementById('app-config').dataset;
    const supabase = createClient(cfg.url, cfg.key, {
      auth: { detectSessionInUrl: true, persistSession: true }
    });

    const loadingArea = document.getElementById('loading-area');
    const formArea    = document.getElementById('form-area');
    const successArea = document.getElementById('success-area');
    const errorArea   = document.getElementById('error-area');
    const alertMsg    = document.getElementById('alert-msg');
    const submitBtn   = document.getElementById('submit-btn');
    const logoArea    = document.getElementById('logo-area');
    const passwordInput = document.getElementById('password');
    const strengthFill  = document.getElementById('strength-fill');

    function showAlert(msg, type = 'error') {
      alertMsg.textContent = msg;
      alertMsg.className = `alert ${type}`;
      alertMsg.style.display = 'block';
    }

    function hideAlert() {
      alertMsg.style.display = 'none';
    }

    // Força da senha
    passwordInput.addEventListener('input', () => {
      const val = passwordInput.value;
      let score = 0;
      if (val.length >= 8) score++;
      if (val.length >= 12) score++;
      if (/[A-Z]/.test(val)) score++;
      if (/[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;
      const pct = [0, 20, 40, 65, 85, 100][score];
      const colors = ['#dc2626','#dc2626','#f97316','#eab308','#22c55e','#22c55e'];
      strengthFill.style.width = pct + '%';
      strengthFill.style.background = colors[score];
    });

    let academyLoginUrl = '/login'; // fallback

    // Carrega logo/nome da academia do usuário e define URL de redirecionamento
    async function loadAcademyBranding(userId) {
      try {
        const { data: profile } = await supabase
          .from('profiles')
          .select('academia_id')
          .eq('id', userId)
          .single();
        if (!profile?.academia_id) return;

        const { data: acad } = await supabase
          .from('academias')
          .select('nome, slug, logo_url')
          .eq('id', profile.academia_id)
          .single();
        if (!acad) return;

        // Define URL de login da academia
        if (acad.slug) {
          academyLoginUrl = '/' + acad.slug;
          document.querySelector('#success-area a').href = academyLoginUrl;
        }

        document.getElementById('academy-name').textContent = acad.nome;
        const logoImg = document.getElementById('academy-logo');
        if (acad.logo_url) {
          logoImg.src = acad.logo_url;
          logoImg.alt = acad.nome;
          logoImg.style.display = 'block';
          document.getElementById('academy-name').style.display = 'none';
        }
        logoArea.style.display = 'block';
      } catch {}
    }

    /**
     * Verifica se o hash da URL contém erros do Supabase Auth.
     * Retorna true se encontrou um erro (e já mostra a tela de erro).
     */
    function checkHashForErrors() {
      const hash = window.location.hash.substring(1); // remove #
      if (!hash) return false;

      const params = new URLSearchParams(hash);
      const error = params.get('error');
      const errorCode = params.get('error_code');
      const errorDesc = params.get('error_description');

      if (error || errorCode) {
        loadingArea.style.display = 'none';

        // Mensagem amigável baseada no código de erro
        let mensagem = 'Peça ao responsável pela academia que envie um novo link de redefinição.';
        if (errorCode === 'otp_expired') {
          mensagem = 'Este link expirou ou já foi utilizado. Peça ao responsável pela academia que envie um novo link.';
        } else if (errorDesc) {
          mensagem = errorDesc.replace(/\+/g, ' ');
        }

        document.getElementById('error-detail').textContent = mensagem;
        errorArea.style.display = 'block';

        // Limpa o hash da URL para ficar mais limpo
        history.replaceState(null, '', window.location.pathname);
        return true;
      }

      return false;
    }

    // Detecta sessão de recovery
    async function init() {
      // 1. PRIMEIRO: verifica se há erros no hash (link expirado/inválido)
      if (checkHashForErrors()) return;

      // 2. Tenta sessão já existente (cookie)
      const { data: { session } } = await supabase.auth.getSession();
      if (session?.user) {
        showForm(session.user.id);
        return;
      }

      // 3. Aguarda evento via URL hash (fluxo implícito do generateLink)
      const { data: { subscription } } = supabase.auth.onAuthStateChange(async (event, sess) => {
        if (event === 'PASSWORD_RECOVERY' || event === 'SIGNED_IN') {
          subscription.unsubscribe();
          showForm(sess?.user?.id);
        }
      });

      // 4. Timeout: se nada acontecer em 8s, mostra erro
      setTimeout(() => {
        if (formArea.style.display === 'none' && errorArea.style.display === 'none') {
          loadingArea.style.display = 'none';
          document.getElementById('error-detail').textContent =
            'Não foi possível verificar o link. Peça ao responsável pela academia que envie um novo.';
          errorArea.style.display = 'block';
        }
      }, 8000);
    }

    async function showForm(userId) {
      loadingArea.style.display = 'none';
      formArea.style.display = 'block';
      if (userId) await loadAcademyBranding(userId);
    }

    // Submit
    document.getElementById('reset-form').addEventListener('submit', async (e) => {
      e.preventDefault();
      hideAlert();

      const password = document.getElementById('password').value;
      const confirm  = document.getElementById('confirm').value;

      if (password !== confirm) {
        showAlert('As senhas não coincidem.');
        return;
      }
      if (password.length < 8) {
        showAlert('A senha deve ter pelo menos 8 caracteres.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Salvando…';

      const { error } = await supabase.auth.updateUser({ password });

      if (error) {
        showAlert(error.message);
        submitBtn.disabled = false;
        submitBtn.textContent = 'Salvar senha';
        return;
      }

      formArea.style.display = 'none';
      successArea.style.display = 'block';

      // Redireciona para a área da academia após 3s
      setTimeout(() => { window.location.href = academyLoginUrl; }, 3000);
    });

    init();
  </script>
</body>
</html>
