---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id, nome_completo')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'aluno') return Astro.redirect('/dashboard');

const admin = createSupabaseAdminClient();

// ── Plano atual (aluno_academias → alunos → aluno_planos → planos) ─────────
const { data: vinculo } = await admin
  .from('aluno_academias')
  .select('aluno_id')
  .eq('profile_id', user.id)
  .eq('academia_id', profile.academia_id!)
  .eq('ativo', true)
  .maybeSingle();

let planoAtual: { nome: string; valor: number; vencimento_dia: number } | null = null;
if (vinculo?.aluno_id) {
  const { data: alunoPlano } = await admin
    .from('aluno_planos')
    .select('planos(nome, valor, vencimento_dia)')
    .eq('aluno_id', vinculo.aluno_id)
    .eq('status', 'ativo')
    .order('data_inicio', { ascending: false })
    .limit(1)
    .maybeSingle();
  planoAtual = (alunoPlano as any)?.planos ?? null;
}

// ── Checkins — coluna correta é feito_em (não created_at) ─────────────────
const { data: checkins } = await supabase
  .from('checkins')
  .select(`
    id, feito_em,
    aulas_agenda(id, data_aula, horario_inicio, modalidade,
      wods(id, nome)
    )
  `)
  .eq('aluno_id', user.id)
  .order('feito_em', { ascending: false })
  .limit(50);

// ── Scores de performance ─────────────────────────────────────────────────
const { data: resultados } = await supabase
  .from('resultados_performance')
  .select(`
    id, tempo, repeticoes, carga_kg, rounds, reps_extra, passou, rx_scaled, observacao, registrado_em,
    aulas_agenda(id, data_aula, modalidade,
      wods(id, nome, score_type)
    )
  `)
  .eq('aluno_id', user.id)
  .order('registrado_em', { ascending: false })
  .limit(50);

const totalCheckins   = checkins?.length ?? 0;
const totalResultados = resultados?.length ?? 0;

// Checkins nos últimos 30 dias em BRT
const trintaDias = new Date(Date.now() - 30 * 24 * 60 * 60 * 1000);
const checkinsRecentes = checkins?.filter(c => new Date((c as any).feito_em) >= trintaDias).length ?? 0;

function fmtData(iso: string) {
  return new Date(iso + 'T12:00:00Z').toLocaleDateString('pt-BR', {
    weekday: 'short', day: '2-digit', month: 'short',
  });
}
---

<DashboardLayout title="Meus Resultados">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Meus Resultados</h1>
    <p class="mt-1 text-sm text-muted-foreground">Histórico de treinos e performance</p>
  </div>

  <!-- Card do plano atual -->
  {planoAtual && (
    <div class="mb-6 rounded-xl border border-primary/20 bg-primary/5 px-4 py-3 flex items-center gap-4">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/15 border border-primary/30">
        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
        </svg>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Plano atual</p>
        <p class="font-bold text-foreground">{planoAtual.nome}</p>
      </div>
      <div class="text-right shrink-0">
        <p class="text-lg font-bold text-primary">
          {Number(planoAtual.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
          <span class="text-xs font-normal text-muted-foreground">/mês</span>
        </p>
        {planoAtual.vencimento_dia && (
          <p class="text-xs text-muted-foreground">Vence todo dia {planoAtual.vencimento_dia}</p>
        )}
      </div>
    </div>
  )}

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-3 mb-6">
    <Card>
      <p class="text-[10px] font-medium text-muted-foreground uppercase tracking-wider">Total treinos</p>
      <p class="mt-1 text-3xl font-bold text-primary">{totalCheckins}</p>
    </Card>
    <Card>
      <p class="text-[10px] font-medium text-muted-foreground uppercase tracking-wider">Últimos 30 dias</p>
      <p class="mt-1 text-3xl font-bold text-foreground">{checkinsRecentes}</p>
    </Card>
    <Card>
      <p class="text-[10px] font-medium text-muted-foreground uppercase tracking-wider">Scores</p>
      <p class="mt-1 text-3xl font-bold text-foreground">{totalResultados}</p>
    </Card>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">

    <!-- Histórico de Check-ins -->
    <Card>
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Histórico de Treinos</h2>
      {!checkins || checkins.length === 0 ? (
        <p class="py-6 text-center text-sm text-muted-foreground">Nenhum treino registrado ainda.</p>
      ) : (
        <div class="space-y-3">
          {checkins.slice(0, 20).map((c: any) => {
            const aula = c.aulas_agenda;
            const wod  = aula?.wods;
            // feito_em é UTC — converte para data da aula
            const dataDisplay = aula?.data_aula ? fmtData(aula.data_aula) : new Date(c.feito_em).toLocaleDateString('pt-BR');
            return (
              <div class="flex items-start gap-3 border-b border-border/50 pb-3 last:border-0 last:pb-0">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary text-xs font-bold">
                  {aula?.data_aula
                    ? new Date(aula.data_aula + 'T12:00:00Z').getUTCDate()
                    : '—'}
                </div>
                <div class="min-w-0 flex-1">
                  <p class="text-sm font-medium text-foreground truncate">
                    {wod?.nome ?? aula?.modalidade ?? 'Aula'}
                  </p>
                  <p class="text-xs text-muted-foreground">
                    {dataDisplay}
                    {aula?.horario_inicio ? ` · ${aula.horario_inicio.slice(0,5)}` : ''}
                  </p>
                </div>
                <span class="text-xs text-primary font-bold shrink-0">✓</span>
              </div>
            );
          })}
        </div>
      )}
    </Card>

    <!-- Scores / Performance -->
    <Card>
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Scores Registrados</h2>
      {!resultados || resultados.length === 0 ? (
        <p class="py-6 text-center text-sm text-muted-foreground">Nenhum score registrado ainda.</p>
      ) : (
        <div class="space-y-3">
          {resultados.slice(0, 20).map((r: any) => {
            const aula = r.aulas_agenda;
            const wod  = aula?.wods;
            // Formata o score conforme o tipo
            let scoreLabel = '';
            if (r.tempo)      scoreLabel = r.tempo;
            else if (r.rounds != null) scoreLabel = `${r.rounds}${r.reps_extra ? `+${r.reps_extra}` : ''} rounds`;
            else if (r.repeticoes != null) scoreLabel = `${r.repeticoes} reps`;
            else if (r.carga_kg != null)   scoreLabel = `${r.carga_kg} kg`;
            else if (r.passou != null)     scoreLabel = r.passou ? 'Pass ✓' : 'Fail ✗';
            const ehRx = r.rx_scaled === true || r.rx_scaled === 'rx';
            return (
              <div class="flex items-start gap-3 border-b border-border/50 pb-3 last:border-0 last:pb-0">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-muted text-muted-foreground text-xs font-bold">
                  {aula?.data_aula ? new Date(aula.data_aula + 'T12:00:00Z').getUTCDate() : '—'}
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2">
                    <p class="text-sm font-medium text-foreground truncate">
                      {wod?.nome ?? aula?.modalidade ?? 'WOD'}
                    </p>
                    {ehRx && <span class="text-[10px] font-bold text-primary bg-primary/10 px-1.5 py-0.5 rounded">RX</span>}
                  </div>
                  {scoreLabel && <p class="text-xs text-primary font-bold">{scoreLabel}</p>}
                  {r.observacao && <p class="text-xs text-muted-foreground truncate">{r.observacao}</p>}
                </div>
                <span class="text-xs text-muted-foreground shrink-0">
                  {aula?.data_aula ? fmtData(aula.data_aula) : '—'}
                </span>
              </div>
            );
          })}
        </div>
      )}
    </Card>

  </div>
</DashboardLayout>
