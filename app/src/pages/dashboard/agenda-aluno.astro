---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, nome_completo, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'aluno') return Astro.redirect('/dashboard');

// ── Parâmetro de dia ──────────────────────────────────────────────────────────
const url      = new URL(Astro.request.url);
const diaParam = url.searchParams.get('dia');
// Data de hoje no fuso de Brasília — servidor roda em UTC
const hojeISO  = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Sao_Paulo' }).format(new Date());
const diaISO   = diaParam && /^\d{4}-\d{2}-\d{2}$/.test(diaParam) ? diaParam : hojeISO;

// ── Semana (hoje + 6 dias) usando UTC ao meio-dia para evitar problemas de DST ─
function addDays(iso: string, days: number): string {
  const d = new Date(iso + 'T12:00:00Z');
  d.setUTCDate(d.getUTCDate() + days);
  return d.toISOString().split('T')[0];
}
const semana = Array.from({ length: 7 }, (_, i) => addDays(hojeISO, i));

// ── Aulas do dia selecionado ──────────────────────────────────────────────────
const admin = createSupabaseAdminClient();

// Busca vínculo e modalidades do aluno diretamente em aluno_modalidades
const { data: vinculoAluno } = await admin
  .from('aluno_academias')
  .select('aluno_id')
  .eq('profile_id', user.id)
  .eq('academia_id', profile.academia_id!)
  .eq('ativo', true)
  .maybeSingle();

let modalidadesAluno: string[] = [];
if (vinculoAluno?.aluno_id) {
  const { data: mods } = await admin
    .from('aluno_modalidades')
    .select('modalidade')
    .eq('aluno_id', vinculoAluno.aluno_id)
    .eq('academia_id', profile.academia_id!);
  modalidadesAluno = (mods ?? []).map((m: any) => m.modalidade);
}

let aulasQuery = supabase
  .from('aulas_agenda')
  .select('id, wod_id, data_aula, horario_inicio, horario_fim, capacidade_max, modalidade, wods(nome, score_type, treino)')
  .eq('academia_id', profile.academia_id!)
  .eq('data_aula', diaISO)
  .order('horario_inicio');

if (modalidadesAluno.length > 0) {
  aulasQuery = aulasQuery.in('modalidade', modalidadesAluno);
}
const { data: aulas } = await aulasQuery;

// Busca detalhes completos dos WODs das aulas do dia
const wodIds = [...new Set((aulas ?? []).map((a: any) => a.wod_id).filter(Boolean))];
const [{ data: wodGrupos }, { data: wodExs }] = await Promise.all([
  wodIds.length > 0
    ? admin.from('wod_grupos').select('id, wod_id, nome, rounds, tempo, ordem').in('wod_id', wodIds).order('ordem')
    : Promise.resolve({ data: [] as any[] }),
  wodIds.length > 0
    ? admin.from('wod_exercicios')
        .select('id, wod_id, grupo_id, ordem, repeticoes, carga, distancia, observacao, exercicios(nome)')
        .in('wod_id', wodIds).order('ordem')
    : Promise.resolve({ data: [] as any[] }),
]);

// Mapa wod_id → { grupos (com exercícios), exsSemGrupo }
const wodMap: Record<string, { grupos: any[]; exsSemGrupo: any[] }> = {};
for (const wid of wodIds) {
  const grupos = (wodGrupos ?? []).filter((g: any) => g.wod_id === wid)
    .map((g: any) => ({ ...g, exercicios: (wodExs ?? []).filter((e: any) => e.grupo_id === g.id) }));
  const exsSemGrupo = (wodExs ?? []).filter((e: any) => e.wod_id === wid && !e.grupo_id);
  wodMap[wid] = { grupos, exsSemGrupo };
}

const aulaIds = aulas?.map(a => a.id) ?? [];

const [checkinAlunoRes, totalCheckinsRes] = await Promise.all([
  aulaIds.length > 0
    ? supabase.from('checkins').select('aula_id').eq('aluno_id', user.id).in('aula_id', aulaIds)
    : Promise.resolve({ data: [] }),
  aulaIds.length > 0
    ? admin.from('checkins').select('aula_id').in('aula_id', aulaIds)
    : Promise.resolve({ data: [] }),
]);

const checkinsFeitosSet = new Set<string>((checkinAlunoRes.data ?? []).map((c: any) => c.aula_id));
const checkinCountMap = new Map<string, number>();
(totalCheckinsRes.data ?? []).forEach((c: any) => {
  checkinCountMap.set(c.aula_id, (checkinCountMap.get(c.aula_id) ?? 0) + 1);
});

// ── PRs do aluno e ranking da turma nas aulas confirmadas ────────────────────
const confirmedIds = aulaIds.filter(id => checkinsFeitosSet.has(id));
const [{ data: meusPRs }, { data: rankingTodos }] = await Promise.all([
  confirmedIds.length > 0
    ? admin.from('prs')
        .select('id, aula_id, tipo, valor_peso, valor_tempo_seg, valor_reps, valor_rounds, valor_reps_extra, rx, observacao')
        .eq('aluno_id', user.id)
        .in('aula_id', confirmedIds)
    : Promise.resolve({ data: [] as any[] }),
  confirmedIds.length > 0
    ? admin.from('prs')
        .select('aula_id, aluno_id, tipo, valor_peso, valor_tempo_seg, valor_reps, valor_rounds, valor_reps_extra, rx, profiles(nome_completo)')
        .eq('academia_id', profile.academia_id!)
        .in('aula_id', confirmedIds)
    : Promise.resolve({ data: [] as any[] }),
]);

const meuPRPorAula = new Map<string, any>(
  (meusPRs ?? []).map((p: any) => [p.aula_id, p])
);

// Agrupa e ordena ranking por aula
function scoreNum(pr: any): number {
  if (pr.tipo === 'peso')        return pr.valor_peso ?? 0;
  if (pr.tipo === 'tempo')       return -(pr.valor_tempo_seg ?? 999999);
  if (pr.tipo === 'reps')        return pr.valor_reps ?? 0;
  if (pr.tipo === 'rounds_reps') return (pr.valor_rounds ?? 0) * 10000 + (pr.valor_reps_extra ?? 0);
  return 0;
}
function fmtScore(pr: any): string {
  if (pr.tipo === 'peso') return `${pr.valor_peso} kg`;
  if (pr.tipo === 'reps') return `${pr.valor_reps} rep${pr.valor_reps !== 1 ? 's' : ''}`;
  if (pr.tipo === 'rounds_reps') {
    const r = pr.valor_rounds ?? 0;
    const x = pr.valor_reps_extra;
    return x ? `${r} rounds + ${x}` : `${r} rounds`;
  }
  if (pr.tipo === 'tempo' && pr.valor_tempo_seg != null) {
    const m = Math.floor(pr.valor_tempo_seg / 60);
    const s = pr.valor_tempo_seg % 60;
    return `${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
  }
  return '—';
}

const rankingPorAula = new Map<string, any[]>();
for (const pr of rankingTodos ?? []) {
  if (!rankingPorAula.has(pr.aula_id)) rankingPorAula.set(pr.aula_id, []);
  rankingPorAula.get(pr.aula_id)!.push(pr);
}
for (const [id, lista] of rankingPorAula) {
  rankingPorAula.set(id, lista.sort((a: any, b: any) => scoreNum(b) - scoreNum(a)));
}

// ── Helpers ───────────────────────────────────────────────────────────────────
const DIAS = ['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
const MESES = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];

function fmt(t: string) { return t.substring(0, 5); }

type Status = 'aguardando' | 'aberto' | 'encerrado';
function getStatus(dataAula: string, ini: string, fim: string): Status {
  const agora = new Date(); // UTC
  const hIni  = ini.length === 5 ? ini + ':00' : ini;
  const hFim  = fim.length === 5 ? fim + ':00' : fim;
  // Offset -03:00 de Brasília para comparação correta com UTC do servidor
  const start       = new Date(`${dataAula}T${hIni}-03:00`);
  const end         = new Date(`${dataAula}T${hFim}-03:00`);
  const abertura    = new Date(start.getTime() - 10 * 60_000);
  const fechamento  = new Date(end.getTime()   + 10 * 60_000);
  if (agora < abertura)    return 'aguardando';
  if (agora <= fechamento) return 'aberto';
  return 'encerrado';
}

const scoreLabel: Record<string, string> = {
  tempo: 'Para Tempo', reps: 'Max Reps', carga: 'Max Carga',
  rounds_reps: 'AMRAP', pass_fail: 'Pass/Fail',
};

const modalidadeBadge: Record<string, string> = {
  'CrossFit':     'border-[#00FF85]/30 text-[#00FF85] bg-[#00FF85]/10',
  'Treino Livre': 'border-blue-500/30 text-blue-400 bg-blue-500/10',
  'Funcional':    'border-orange-500/30 text-orange-400 bg-orange-500/10',
};

// Usa UTC noon para evitar ambiguidade de timezone no título
const diaSelecionadoDate  = new Date(diaISO + 'T12:00:00Z');
const diaSelecionadoLabel = `${DIAS[diaSelecionadoDate.getUTCDay()]}, ${diaSelecionadoDate.getUTCDate()} de ${MESES[diaSelecionadoDate.getUTCMonth()]}`;
---

<DashboardLayout title="Agenda">

  <!-- Cabeçalho -->
  <div class="mb-5">
    <p class="text-xs font-semibold uppercase tracking-widest text-[#00FF85] mb-0.5">Agenda de Aulas</p>
    <h1 class="text-2xl font-bold text-foreground">{diaSelecionadoLabel}</h1>
  </div>

  <!-- Seletor de dias (scroll horizontal no mobile) -->
  <div class="mb-6 -mx-4 px-4">
    <div class="flex gap-2 overflow-x-auto pb-1 scrollbar-hide">
      {semana.map(iso => {
        const ativo  = iso === diaISO;
        const ehHoje = iso === hojeISO;
        // Usa UTC noon para evitar problemas de offset ao ler getUTCDay/getUTCDate
        const d = new Date(iso + 'T12:00:00Z');
        return (
          <a
            href={`/dashboard/agenda-aluno?dia=${iso}`}
            class={`flex flex-col items-center shrink-0 rounded-xl px-3 py-2.5 border transition-all min-w-[56px] ${
              ativo
                ? 'bg-[#00FF85] border-[#00FF85] text-black font-bold shadow-[0_0_16px_rgba(0,255,133,0.4)]'
                : 'bg-card border-border text-muted-foreground hover:border-[#00FF85]/40 hover:text-foreground'
            }`}
          >
            <span class="text-[10px] font-semibold uppercase tracking-wider">{DIAS[d.getUTCDay()]}</span>
            <span class={`text-lg font-bold leading-none mt-0.5 ${ativo ? 'text-black' : ''}`}>{d.getUTCDate()}</span>
            {ehHoje && !ativo && (
              <span class="mt-1 h-1 w-1 rounded-full bg-[#00FF85]"></span>
            )}
          </a>
        );
      })}
    </div>
  </div>

  <!-- Lista de aulas -->
  {!aulas || aulas.length === 0 ? (

    <div class="flex flex-col items-center justify-center py-16 text-center">
      <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-zinc-900 border border-border">
        <svg class="h-8 w-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <p class="font-semibold text-foreground">Sem aulas neste dia</p>
      <p class="mt-1 text-sm text-muted-foreground">Selecione outro dia ou fale com seu professor.</p>
    </div>

  ) : (

    <div class="space-y-3">
      {aulas.map(aula => {
        const status      = getStatus(aula.data_aula, aula.horario_inicio, aula.horario_fim);
        const jaFez       = checkinsFeitosSet.has(aula.id);
        const totalCheckins = checkinCountMap.get(aula.id) ?? 0;
        const cap         = aula.capacidade_max as number | null;
        const semVagas    = !!cap && cap > 0 && totalCheckins >= cap;
        const vagasRestantes = cap && cap > 0 ? cap - totalCheckins : null;
        const wod         = (aula.wods as any);
        const podeCheckin = status === 'aberto' && !jaFez && !semVagas;
        const badgeMod    = modalidadeBadge[aula.modalidade] ?? 'border-border text-muted-foreground bg-zinc-900';

        return (
          <div class={`relative overflow-hidden rounded-2xl border bg-[#0a0a0a] transition-all ${
            podeCheckin
              ? 'border-[#00FF85]/50 shadow-[0_0_24px_rgba(0,255,133,0.15)] animate-pulse-border'
              : jaFez
              ? 'border-[#00FF85]/30'
              : 'border-zinc-800'
          }`}>

            <!-- Linha lateral de status -->
            <div class={`absolute left-0 top-0 h-full w-[3px] ${
              jaFez         ? 'bg-[#00FF85]' :
              podeCheckin   ? 'bg-[#00FF85]' :
              status === 'encerrado' ? 'bg-zinc-700' :
              'bg-zinc-600'
            }`}></div>

            <div class="pl-5 pr-4 pt-4 pb-4">

              <!-- Linha 1: horário + badge modalidade + status -->
              <div class="flex items-start justify-between gap-3 mb-3">
                <div class="flex items-center gap-3">
                  <!-- Horário -->
                  <div class="shrink-0">
                    <div class="text-xl font-black font-mono text-white leading-none">{fmt(aula.horario_inicio)}</div>
                    <div class="text-[10px] text-zinc-500 mt-0.5">até {fmt(aula.horario_fim)}</div>
                  </div>
                  <!-- Separador -->
                  <div class="h-8 w-px bg-zinc-800"></div>
                  <!-- Modalidade + WOD -->
                  <div>
                    <span class={`inline-flex items-center rounded-md border px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider ${badgeMod}`}>
                      {aula.modalidade}
                    </span>
                    {wod?.nome && (
                      <p class="mt-1 font-bold text-sm text-white leading-tight">{wod.nome}</p>
                    )}
                  </div>
                </div>

                <!-- Status badge direito -->
                {jaFez ? (
                  <span class="shrink-0 flex items-center gap-1 rounded-full bg-[#00FF85]/10 border border-[#00FF85]/30 px-2.5 py-1 text-[10px] font-bold text-[#00FF85]">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Confirmado
                  </span>
                ) : podeCheckin ? (
                  <span class="shrink-0 rounded-full bg-[#00FF85]/10 border border-[#00FF85]/40 px-2.5 py-1 text-[10px] font-bold text-[#00FF85] animate-pulse">
                    ● Aberto
                  </span>
                ) : status === 'aguardando' ? (
                  <span class="shrink-0 rounded-full bg-zinc-900 border border-zinc-700 px-2.5 py-1 text-[10px] text-zinc-500">
                    Aguardando
                  </span>
                ) : (
                  <span class="shrink-0 rounded-full bg-zinc-900 border border-zinc-800 px-2.5 py-1 text-[10px] text-zinc-600">
                    Encerrado
                  </span>
                )}
              </div>

              <!-- Score type + treino -->
              {(wod?.score_type || wod?.treino) && (
                <div class="mb-3 rounded-xl bg-zinc-900/80 border border-zinc-800 px-3 py-2.5">
                  {wod?.score_type && (
                    <span class="text-[10px] font-bold text-[#00FF85] uppercase tracking-widest">
                      {scoreLabel[wod.score_type] ?? wod.score_type}
                    </span>
                  )}
                  {wod?.treino && (
                    <p class="mt-1 text-xs text-zinc-400 line-clamp-2 leading-relaxed">{wod.treino}</p>
                  )}
                </div>
              )}

              <!-- Vagas -->
              <div class="flex items-center justify-between mb-3">
                {cap && cap > 0 ? (
                  <div class="flex items-center gap-2 flex-1">
                    <div class="flex-1 h-1.5 rounded-full bg-zinc-800 overflow-hidden">
                      <div
                        class={`h-full rounded-full transition-all ${semVagas ? 'bg-red-500' : 'bg-[#00FF85]'}`}
                        style={`width: ${Math.min(100, (totalCheckins / cap) * 100).toFixed(0)}%`}
                      ></div>
                    </div>
                    <span class="text-xs font-semibold text-zinc-400 shrink-0">
                      {semVagas ? (
                        <span class="text-red-400">Lotado</span>
                      ) : (
                        <span class="text-[#00FF85]">{vagasRestantes} vaga{vagasRestantes !== 1 ? 's' : ''}</span>
                      )}
                    </span>
                  </div>
                ) : (
                  <span class="text-xs text-zinc-500">
                    <svg class="inline h-3 w-3 mr-1 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0" />
                    </svg>
                    Vagas ilimitadas
                  </span>
                )}
              </div>

              <!-- Botão Ver WOD -->
              {wod?.nome && (aula as any).wod_id && (
                <button
                  class="ver-wod-btn w-full mb-2 rounded-xl py-2.5 text-sm font-semibold text-zinc-300 border border-zinc-700 hover:border-[#00FF85]/40 hover:text-[#00FF85] transition-all flex items-center justify-center gap-2"
                  data-wod-id={(aula as any).wod_id}
                  data-wod-nome={wod.nome}
                  data-score={wod.score_type}
                  data-treino={wod.treino ?? ''}>
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                  </svg>
                  Ver WOD
                </button>
              )}

              <!-- Botão de ação / resultado -->
              {jaFez ? (
                <div class="space-y-2">
                  <div class="flex items-center justify-center gap-2 py-3 rounded-xl bg-[#00FF85]/5 border border-[#00FF85]/20 text-sm font-bold text-[#00FF85]">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    Presença confirmada!
                  </div>

                  {/* Resultado + ranking — só para WODs com score mensurável */}
                  {wod?.score_type && wod.score_type !== 'pass_fail' && (() => {
                    const meuPR   = meuPRPorAula.get(aula.id);
                    const ranking = rankingPorAula.get(aula.id) ?? [];
                    const minhaPosicao = meuPR
                      ? ranking.findIndex((r: any) => r.aluno_id === user.id) + 1
                      : null;
                    return (
                      <div class="rounded-xl bg-zinc-900/60 border border-zinc-800 overflow-hidden">
                        {/* Meu resultado */}
                        {meuPR ? (
                          <div class="px-3 py-2.5 border-b border-zinc-800 flex items-center justify-between gap-2">
                            <div>
                              <p class="text-[10px] font-bold text-[#00FF85] uppercase tracking-widest">Meu resultado</p>
                              <p class="text-base font-black text-white mt-0.5">{fmtScore(meuPR)}</p>
                              <div class="flex items-center gap-2 mt-0.5">
                                {meuPR.rx && <span class="text-[9px] font-bold text-[#00FF85] bg-[#00FF85]/10 px-1.5 py-0.5 rounded">RX</span>}
                                {minhaPosicao && <span class="text-[10px] text-zinc-500">#{minhaPosicao} na turma</span>}
                                {meuPR.observacao && <span class="text-[10px] text-zinc-600 italic truncate">{meuPR.observacao}</span>}
                              </div>
                            </div>
                            <button
                              class="registrar-btn shrink-0 text-[10px] font-bold text-zinc-500 border border-zinc-700 px-2.5 py-1.5 rounded-lg hover:border-[#00FF85]/40 hover:text-[#00FF85] transition-all"
                              data-aula-id={aula.id}
                              data-score-type={wod.score_type}
                              data-wod-nome={wod.nome}>
                              Atualizar
                            </button>
                          </div>
                        ) : (
                          <button
                            class="registrar-btn w-full px-3 py-3 text-sm font-bold text-zinc-300 hover:text-[#00FF85] flex items-center justify-center gap-2 transition-colors"
                            data-aula-id={aula.id}
                            data-score-type={wod.score_type}
                            data-wod-nome={wod.nome}>
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                            </svg>
                            Registrar Resultado
                          </button>
                        )}

                        {/* Mini-ranking turma */}
                        {ranking.length > 0 && (
                          <div class="px-3 py-2">
                            <p class="text-[9px] font-bold text-zinc-600 uppercase tracking-widest mb-1.5">Ranking da Turma</p>
                            <div class="space-y-1">
                              {ranking.slice(0, 5).map((r: any, i: number) => {
                                const isMe = r.aluno_id === user.id;
                                const nome = (r.profiles as any)?.nome_completo?.split(' ')[0] ?? 'Atleta';
                                const medalhas = ['🥇','🥈','🥉'];
                                return (
                                  <div class={`flex items-center gap-2 text-xs rounded-lg px-2 py-1 ${isMe ? 'bg-[#00FF85]/5 border border-[#00FF85]/20' : ''}`}>
                                    <span class="w-5 text-center shrink-0">
                                      {i < 3 ? medalhas[i] : <span class="text-zinc-600 font-bold">{i+1}</span>}
                                    </span>
                                    <span class={`flex-1 truncate font-medium ${isMe ? 'text-[#00FF85]' : 'text-zinc-400'}`}>{nome}</span>
                                    {r.rx && <span class="text-[9px] font-bold text-[#00FF85]/60 bg-[#00FF85]/5 px-1 rounded">RX</span>}
                                    <span class={`shrink-0 font-bold ${isMe ? 'text-[#00FF85]' : 'text-zinc-300'}`}>{fmtScore(r)}</span>
                                  </div>
                                );
                              })}
                            </div>
                          </div>
                        )}
                      </div>
                    );
                  })()}
                </div>
              ) : semVagas ? (
                <button disabled class="w-full rounded-xl bg-zinc-800 py-3 text-sm font-bold text-zinc-600 cursor-not-allowed flex items-center justify-center gap-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636" />
                  </svg>
                  Turma lotada
                </button>
              ) : podeCheckin ? (
                <button
                  class="checkin-btn w-full rounded-xl py-3.5 text-sm font-black text-black transition-all active:scale-95 flex items-center justify-center gap-2"
                  style="background: #00FF85; box-shadow: 0 0 24px rgba(0,255,133,0.4);"
                  data-aula-id={aula.id}
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Confirmar Presença
                </button>
              ) : status === 'aguardando' ? (
                <button disabled class="w-full rounded-xl bg-zinc-900 border border-zinc-800 py-3 text-sm font-semibold text-zinc-500 cursor-not-allowed flex items-center justify-center gap-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Check-in indisponível no momento
                </button>
              ) : (
                <button disabled class="w-full rounded-xl bg-zinc-900 border border-zinc-800 py-3 text-sm font-semibold text-zinc-600 cursor-not-allowed flex items-center justify-center gap-2">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Check-in indisponível no momento
                </button>
              )}

            </div>
          </div>
        );
      })}
    </div>

  )}

  <!-- Modal WOD -->
  <div id="wod-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/70 backdrop-blur-sm p-4">
    <div class="w-full max-w-lg max-h-[85vh] overflow-y-auto rounded-2xl bg-[#0a0a0a] border border-zinc-800">
      <!-- Header -->
      <div class="sticky top-0 bg-[#0a0a0a] border-b border-zinc-800 px-5 py-4 flex items-center justify-between z-10">
        <div>
          <p id="wod-modal-score" class="text-[10px] font-bold text-[#00FF85] uppercase tracking-widest mb-0.5"></p>
          <h2 id="wod-modal-nome" class="text-lg font-black text-white"></h2>
        </div>
        <button onclick="document.getElementById('wod-modal').classList.add('hidden')"
          class="flex h-8 w-8 items-center justify-center rounded-full bg-zinc-800 text-zinc-400 hover:text-white transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Prescrição -->
      <div id="wod-modal-treino-wrap" class="hidden px-5 pt-4">
        <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-wider mb-1.5">Prescrição</p>
        <p id="wod-modal-treino" class="text-sm text-zinc-300 leading-relaxed whitespace-pre-line"></p>
      </div>

      <!-- Exercícios -->
      <div id="wod-modal-body" class="px-5 py-4 space-y-3"></div>
    </div>
  </div>

  <!-- Modal Registrar Resultado -->
  <div id="resultado-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm p-4">
    <div class="w-full max-w-sm rounded-2xl bg-[#0a0a0a] border border-zinc-800 shadow-2xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-zinc-800">
        <div>
          <p id="res-score-label" class="text-[10px] font-bold text-[#00FF85] uppercase tracking-widest mb-0.5"></p>
          <h2 id="res-wod-nome" class="text-sm font-black text-white"></h2>
        </div>
        <button id="res-fechar" class="flex h-8 w-8 items-center justify-center rounded-full bg-zinc-800 text-zinc-400 hover:text-white transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="resultado-form" class="px-5 py-4 space-y-4">
        <input type="hidden" id="res-aula-id" name="aula_id" />
        <input type="hidden" id="res-score-type" name="score_type" />

        <!-- Tempo -->
        <div id="campo-tempo" class="hidden">
          <label class="block text-xs text-zinc-500 mb-1.5 uppercase tracking-wider font-bold">Tempo</label>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <input id="res-min" name="valor_min" type="number" min="0" max="999" placeholder="Minutos"
                class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-3 text-white text-base font-mono text-center focus:outline-none focus:border-[#00FF85]/50" />
              <p class="text-center text-[10px] text-zinc-600 mt-1">min</p>
            </div>
            <div>
              <input id="res-sec" name="valor_sec" type="number" min="0" max="59" placeholder="Segundos"
                class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-3 text-white text-base font-mono text-center focus:outline-none focus:border-[#00FF85]/50" />
              <p class="text-center text-[10px] text-zinc-600 mt-1">seg</p>
            </div>
          </div>
        </div>

        <!-- Reps -->
        <div id="campo-reps" class="hidden">
          <label class="block text-xs text-zinc-500 mb-1.5 uppercase tracking-wider font-bold">Repetições</label>
          <input name="valor_reps" type="number" min="1" placeholder="ex: 150"
            class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-3 text-white text-base font-mono text-center focus:outline-none focus:border-[#00FF85]/50" />
        </div>

        <!-- Carga -->
        <div id="campo-carga" class="hidden">
          <label class="block text-xs text-zinc-500 mb-1.5 uppercase tracking-wider font-bold">Carga (kg)</label>
          <input name="valor_peso" type="number" min="0" step="0.5" placeholder="ex: 60"
            class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-3 text-white text-base font-mono text-center focus:outline-none focus:border-[#00FF85]/50" />
        </div>

        <!-- Rounds + Reps -->
        <div id="campo-rounds" class="hidden">
          <label class="block text-xs text-zinc-500 mb-1.5 uppercase tracking-wider font-bold">Rounds + Reps</label>
          <div class="grid grid-cols-2 gap-2">
            <div>
              <input name="valor_rounds" type="number" min="0" placeholder="Rounds"
                class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-3 text-white text-base font-mono text-center focus:outline-none focus:border-[#00FF85]/50" />
              <p class="text-center text-[10px] text-zinc-600 mt-1">rounds</p>
            </div>
            <div>
              <input name="valor_reps_extra" type="number" min="0" placeholder="+ Reps"
                class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-3 text-white text-base font-mono text-center focus:outline-none focus:border-[#00FF85]/50" />
              <p class="text-center text-[10px] text-zinc-600 mt-1">+ reps</p>
            </div>
          </div>
        </div>

        <!-- RX / Scaled -->
        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 uppercase tracking-wider font-bold">Modalidade</label>
          <div class="grid grid-cols-2 gap-2">
            <label class="cursor-pointer">
              <input type="radio" name="rx" value="false" class="sr-only peer" checked />
              <span class="block text-center py-2.5 rounded-xl border border-zinc-700 text-sm font-bold text-zinc-400
                peer-checked:border-zinc-500 peer-checked:bg-zinc-800 peer-checked:text-white transition-all">
                Scaled
              </span>
            </label>
            <label class="cursor-pointer">
              <input type="radio" name="rx" value="true" class="sr-only peer" />
              <span class="block text-center py-2.5 rounded-xl border border-zinc-700 text-sm font-bold text-zinc-400
                peer-checked:border-[#00FF85]/50 peer-checked:bg-[#00FF85]/10 peer-checked:text-[#00FF85] transition-all">
                RX
              </span>
            </label>
          </div>
        </div>

        <!-- Observação -->
        <div>
          <label class="block text-xs text-zinc-500 mb-1.5 uppercase tracking-wider font-bold">Observação <span class="normal-case font-normal">(opcional)</span></label>
          <input name="observacao" type="text" placeholder="ex: novo PR, lesão..."
            class="w-full rounded-xl border border-zinc-700 bg-zinc-900 px-3 py-2.5 text-sm text-white placeholder-zinc-600 focus:outline-none focus:border-[#00FF85]/50" />
        </div>

        <p id="res-erro" class="hidden text-xs text-red-400 text-center"></p>

        <button type="submit" id="res-submit"
          class="w-full rounded-xl py-3.5 text-sm font-black text-black transition-all"
          style="background: #00FF85;">
          Salvar Resultado
        </button>
      </form>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="hidden fixed bottom-6 left-4 right-4 z-50 max-w-sm mx-auto rounded-xl border px-4 py-3 text-sm font-bold text-center shadow-2xl"></div>

</DashboardLayout>

<style>
  @keyframes pulse-border {
    0%, 100% { box-shadow: 0 0 12px rgba(0,255,133,0.15); }
    50%       { box-shadow: 0 0 28px rgba(0,255,133,0.35); }
  }
  .animate-pulse-border { animation: pulse-border 2.5s ease-in-out infinite; }
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
</style>

<script>
  // ── Modal Registrar Resultado ────────────────────────────────────────────────
  const resModal    = document.getElementById('resultado-modal')!;
  const resForm     = document.getElementById('resultado-form') as HTMLFormElement;
  const resAulaId   = document.getElementById('res-aula-id')     as HTMLInputElement;
  const resScoreType= document.getElementById('res-score-type')   as HTMLInputElement;
  const resNome     = document.getElementById('res-wod-nome')!;
  const resLabel    = document.getElementById('res-score-label')!;
  const resErro     = document.getElementById('res-erro')!;
  const resSubmit   = document.getElementById('res-submit') as HTMLButtonElement;

  const SCORE_LABELS: Record<string, string> = {
    tempo: 'Para Tempo', reps: 'Max Reps', carga: 'Max Carga',
    rounds_reps: 'AMRAP — Rounds + Reps',
  };

  function abrirResultado(btn: HTMLElement) {
    const aulaId    = btn.dataset.aulaId ?? '';
    const scoreType = btn.dataset.scoreType ?? '';
    const wodNome   = btn.dataset.wodNome ?? '';

    // Define campos hidden ANTES de qualquer reset
    resAulaId.value    = aulaId;
    resScoreType.value = scoreType;
    resNome.textContent  = wodNome;
    resLabel.textContent = SCORE_LABELS[scoreType] ?? scoreType;

    // Limpa apenas os campos visíveis (não os hidden)
    resForm.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      'input:not([type=hidden]), textarea'
    ).forEach(el => { if (el.name !== 'rx') el.value = ''; });
    // Restaura rx para Scaled (padrão)
    const rxScaled = resForm.querySelector<HTMLInputElement>('input[name="rx"][value="false"]');
    if (rxScaled) rxScaled.checked = true;

    // Mostra campo correto
    ['campo-tempo','campo-reps','campo-carga','campo-rounds'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.classList.add('hidden');
    });
    const campoMap: Record<string, string> = {
      tempo: 'campo-tempo', reps: 'campo-reps',
      carga: 'campo-carga', rounds_reps: 'campo-rounds',
    };
    const campoId = campoMap[scoreType];
    if (campoId) document.getElementById(campoId)?.classList.remove('hidden');

    resErro.classList.add('hidden');

    // Re-confirma hidden inputs (garantia extra)
    resAulaId.value    = aulaId;
    resScoreType.value = scoreType;

    resModal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function fecharResultado() {
    resModal.classList.add('hidden');
    document.body.style.overflow = '';
  }

  document.getElementById('res-fechar')?.addEventListener('click', fecharResultado);
  resModal.addEventListener('click', e => { if (e.target === resModal) fecharResultado(); });

  document.querySelectorAll<HTMLElement>('.registrar-btn').forEach(btn => {
    btn.addEventListener('click', () => abrirResultado(btn));
  });

  resForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    resErro.classList.add('hidden');
    resSubmit.disabled = true;
    resSubmit.textContent = 'Salvando...';

    const fd = new FormData(resForm);
    // Lê aula_id e score_type diretamente dos inputs (mais robusto que FormData para hidden)
    const aulaIdVal    = resAulaId?.value    || fd.get('aula_id')    as string | null;
    const scoreTypeVal = resScoreType?.value || fd.get('score_type') as string | null;
    try {
      const res = await fetch('/api/prs/registrar', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          aula_id:          aulaIdVal,
          score_type:       scoreTypeVal,
          valor_min:        fd.get('valor_min')        || null,
          valor_sec:        fd.get('valor_sec')        || null,
          valor_reps:       fd.get('valor_reps')       || null,
          valor_peso:       fd.get('valor_peso')       || null,
          valor_rounds:     fd.get('valor_rounds')     || null,
          valor_reps_extra: fd.get('valor_reps_extra') || null,
          rx:               fd.get('rx') === 'true',
          observacao:       fd.get('observacao')       || null,
        }),
      });
      const data = await res.json();
      if (data.ok) {
        fecharResultado();
        window.location.reload();
      } else {
        resErro.textContent = data.error ?? 'Erro ao salvar.';
        resErro.classList.remove('hidden');
        resSubmit.disabled = false;
        resSubmit.textContent = 'Salvar Resultado';
      }
    } catch {
      resErro.textContent = 'Erro de conexão.';
      resErro.classList.remove('hidden');
      resSubmit.disabled = false;
      resSubmit.textContent = 'Salvar Resultado';
    }
  });

  // ── Toast ────────────────────────────────────────────────────────────────────
  const toast = document.getElementById('toast')!;

  function showToast(msg: string, ok: boolean) {
    toast.textContent = msg;
    toast.className = [
      'fixed bottom-6 left-4 right-4 z-50 max-w-sm mx-auto rounded-xl border px-4 py-3 text-sm font-bold text-center shadow-2xl',
      ok
        ? 'bg-[#0a0a0a] border-[#00FF85]/40 text-[#00FF85] shadow-[0_0_20px_rgba(0,255,133,0.2)]'
        : 'bg-[#0a0a0a] border-red-500/40 text-red-400',
    ].join(' ');
    setTimeout(() => toast.classList.add('hidden'), 4000);
  }

  document.querySelectorAll<HTMLButtonElement>('.checkin-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const aulaId = btn.dataset.aulaId;
      if (!aulaId) return;

      btn.disabled = true;
      btn.innerHTML = `
        <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Registrando…`;

      try {
        const res  = await fetch('/api/checkin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ aula_id: aulaId }),
        });
        const data = await res.json() as { ok: boolean; motivo?: string };

        if (data.ok) {
          showToast('Presença confirmada! 💪', true);
          btn.outerHTML = `
            <div class="flex items-center justify-center gap-2 py-3 rounded-xl bg-[#00FF85]/5 border border-[#00FF85]/20 text-sm font-bold text-[#00FF85]">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Presença confirmada!
            </div>`;
        } else {
          showToast(data.motivo ?? 'Erro ao confirmar presença.', false);
          btn.disabled = false;
          btn.style.cssText = 'background: #00FF85; box-shadow: 0 0 24px rgba(0,255,133,0.4);';
          btn.innerHTML = `
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Confirmar Presença`;
        }
      } catch {
        showToast('Erro de conexão. Tente novamente.', false);
        btn.disabled = false;
      }
    });
  });
</script>

<script define:vars={{ wodMap, scoreLabel }}>
  const SCORE_LABEL = scoreLabel;

  function renderExercicio(ex) {
    const nome = ex.exercicios?.nome ?? '—';
    const partes = [ex.repeticoes, ex.carga, ex.distancia].filter(Boolean).join(' · ');
    return `<div class="flex items-start gap-2.5 py-1.5">
      <span class="mt-1 h-1.5 w-1.5 rounded-full bg-[#00FF85]/60 shrink-0"></span>
      <div>
        <span class="text-sm font-semibold text-white">${nome}</span>
        ${partes ? `<span class="ml-2 text-xs text-zinc-400">${partes}</span>` : ''}
        ${ex.observacao ? `<p class="text-[11px] text-zinc-500 mt-0.5">${ex.observacao}</p>` : ''}
      </div>
    </div>`;
  }

  document.querySelectorAll('.ver-wod-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const wodId   = btn.dataset.wodId;
      const nome    = btn.dataset.wodNome;
      const score   = btn.dataset.score;
      const treino  = btn.dataset.treino;
      const modal   = document.getElementById('wod-modal');
      const body    = document.getElementById('wod-modal-body');
      const treinoWrap = document.getElementById('wod-modal-treino-wrap');

      document.getElementById('wod-modal-nome').textContent   = nome || 'WOD';
      document.getElementById('wod-modal-score').textContent  = SCORE_LABEL[score] || score || '';
      document.getElementById('wod-modal-treino').textContent = treino || '';
      treinoWrap.classList.toggle('hidden', !treino);

      const wod = wodMap[wodId] || { grupos: [], exsSemGrupo: [] };
      let html = '';

      // Grupos de rounds
      for (const g of wod.grupos) {
        const titulo = [g.nome, `${g.rounds} ROUND${g.rounds !== 1 ? 'S' : ''}`, g.tempo].filter(Boolean).join(' · ');
        html += `<div class="rounded-xl border border-zinc-800 overflow-hidden">
          <div class="px-3 py-2 bg-[#00FF85]/10 border-b border-zinc-800">
            <span class="text-xs font-bold text-[#00FF85] uppercase tracking-wider">${titulo}</span>
          </div>
          <div class="px-3 py-1 divide-y divide-zinc-900">
            ${g.exercicios.length > 0 ? g.exercicios.map(renderExercicio).join('') : '<p class="py-2 text-xs text-zinc-600">Sem exercícios cadastrados</p>'}
          </div>
        </div>`;
      }

      // Exercícios sem grupo
      if (wod.exsSemGrupo.length > 0) {
        html += `<div class="rounded-xl border border-zinc-800 px-3 py-1 divide-y divide-zinc-900">
          ${wod.exsSemGrupo.map(renderExercicio).join('')}
        </div>`;
      }

      if (!html && !treino) {
        html = '<p class="py-4 text-center text-sm text-zinc-500">Detalhes do WOD não cadastrados.</p>';
      }

      body.innerHTML = html;
      modal.classList.remove('hidden');
    });
  });

  // Fecha modal clicando fora
  document.getElementById('wod-modal').addEventListener('click', function(e) {
    if (e.target === this) this.classList.add('hidden');
  });
</script>
