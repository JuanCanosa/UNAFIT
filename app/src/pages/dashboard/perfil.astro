---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('id, role, nome_completo, telefone, ativo, criado_em, academia_id')
  .eq('id', user.id)
  .single();

if (!profile) return Astro.redirect('/login');

const { data: academia } = await supabase
  .from('academias')
  .select('id, nome, slug, logo_url')
  .eq('id', profile.academia_id!)
  .single();

let sucesso = false;
let erro = '';

const isDono = profile.role === 'dono' || profile.role === 'saas_admin';

// Busca assinatura SaaS e faturas da academia (apenas para dono)
let saasAssinatura: any = null;
let saasFaturas: any[] = [];

if (isDono) {
  const { data: ass } = await supabase
    .from('saas_assinaturas')
    .select('id, status, data_inicio, data_fim, saas_planos(nome, valor)')
    .eq('academia_id', profile.academia_id!)
    .single();
  saasAssinatura = ass;

  const { data: fat } = await supabase
    .from('saas_faturas')
    .select('id, descricao, valor, data_vencimento, data_pagamento, status, link_pagamento')
    .eq('academia_id', profile.academia_id!)
    .order('data_vencimento', { ascending: false })
    .limit(12);
  saasFaturas = fat ?? [];
}

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = (form.get('action') as string) ?? 'perfil';

  if (action === 'perfil') {
    const nome_completo  = (form.get('nome_completo') as string)?.trim();
    const telefone       = (form.get('telefone') as string)?.trim() || null;
    const nome_academia  = (form.get('nome_academia') as string)?.trim();

    if (!nome_completo) {
      erro = 'O nome é obrigatório.';
    } else {
      const { error } = await supabase.from('profiles').update({ nome_completo, telefone }).eq('id', user.id);
      if (error) {
        erro = error.message;
      } else {
        profile.nome_completo = nome_completo;
        profile.telefone = telefone;

        // Atualiza nome da academia se for dono e campo preenchido
        if (isDono && nome_academia && academia) {
          const adminClient = createSupabaseAdminClient();
          await adminClient.from('academias').update({ nome: nome_academia }).eq('id', profile.academia_id!);
          academia.nome = nome_academia;
        }
        sucesso = true;
      }
    }
  }

  if (action === 'logo' && isDono) {
    const arquivo = form.get('logo') as File | null;
    if (!arquivo || arquivo.size === 0) {
      erro = 'Selecione um arquivo de imagem.';
    } else if (!arquivo.type.startsWith('image/')) {
      erro = 'O arquivo deve ser uma imagem (PNG, JPG, SVG…).';
    } else if (arquivo.size > 2 * 1024 * 1024) {
      erro = 'A imagem deve ter no máximo 2 MB.';
    } else {
      const adminClient = createSupabaseAdminClient();
      const ext = arquivo.name.split('.').pop() ?? 'png';
      const path = `academias/${profile.academia_id}/logo.${ext}`;
      const buffer = await arquivo.arrayBuffer();

      const { error: upErr } = await adminClient.storage
        .from('academy-assets')
        .upload(path, buffer, {
          contentType: arquivo.type,
          upsert: true,
        });

      if (upErr) {
        erro = upErr.message;
      } else {
        const { data: { publicUrl } } = adminClient.storage
          .from('academy-assets')
          .getPublicUrl(path);

        const { error: dbErr } = await adminClient.from('academias').update({ logo_url: publicUrl }).eq('id', profile.academia_id!);
        if (dbErr) {
          erro = dbErr.message;
        } else {
          academia!.logo_url = publicUrl;
          sucesso = true;
        }
      }
    }
  }

  if (action === 'remover_logo' && isDono) {
    const adminClient = createSupabaseAdminClient();
    const { error: rmErr } = await adminClient.from('academias').update({ logo_url: null }).eq('id', profile.academia_id!);
    if (rmErr) erro = rmErr.message;
    else { academia!.logo_url = null; sucesso = true; }
  }
}

const roleLabels: Record<string, string> = {
  saas_admin: 'SaaS Admin',
  dono:       'Dono',
  professor:  'Professor',
  aluno:      'Aluno',
};

const saasStatusMap: Record<string, { label: string; cls: string }> = {
  pago:      { label: 'Pago',      cls: 'bg-green-900/30 text-green-400 border border-green-600/30' },
  pendente:  { label: 'Pendente',  cls: 'bg-yellow-900/30 text-yellow-400 border border-yellow-600/30' },
  vencido:   { label: 'Vencido',   cls: 'bg-red-900/30 text-red-400 border border-red-600/30' },
  cancelado: { label: 'Cancelado', cls: 'bg-zinc-900/30 text-zinc-400 border border-zinc-600/30' },
};

const saasAssinaturaStatusLabels: Record<string, string> = {
  ativa: 'Ativa', trial: 'Trial', suspensa: 'Suspensa', cancelada: 'Cancelada',
};
---

<DashboardLayout title="Meu Perfil">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Meu Perfil</h1>
    <p class="mt-1 text-sm text-muted-foreground">Visualize e edite seus dados pessoais</p>
  </div>

  {sucesso && (
    <div class="mb-5 rounded-lg border border-green-600/30 bg-green-900/20 px-4 py-3 text-sm text-green-400">
      ✓ Alterações salvas com sucesso.
    </div>
  )}
  {erro && (
    <div class="mb-5 rounded-lg border border-red-600/30 bg-red-900/20 px-4 py-3 text-sm text-red-400">
      {erro}
    </div>
  )}

  <div class="grid gap-6 lg:grid-cols-3">

    <!-- Coluna esquerda: identidade + logo -->
    <div class="lg:col-span-1 space-y-6">

      <!-- Card identidade -->
      <Card class="flex flex-col items-center text-center py-8">
        <!-- Logo da academia OU avatar inicial -->
        {academia?.logo_url
          ? (
            <div class="mb-4 w-full px-4 flex justify-center">
              <img src={academia.logo_url} alt={academia?.nome ?? 'Logo'} class="max-h-20 max-w-full object-contain" />
            </div>
          )
          : (
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-primary/15 border-2 border-primary/30 text-primary text-3xl font-bold mb-4">
              {profile.nome_completo.charAt(0).toUpperCase()}
            </div>
          )
        }
        <h2 class="text-lg font-bold text-foreground">{profile.nome_completo}</h2>
        <p class="text-sm text-muted-foreground mb-3">{user.email}</p>
        <Badge variant="primary">{roleLabels[profile.role]}</Badge>
        {academia && <p class="mt-3 text-xs font-medium text-muted-foreground">{academia.nome}</p>}
        <p class="mt-2 text-xs text-muted-foreground">
          Membro desde {new Date(profile.criado_em).toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' })}
        </p>
      </Card>

      <!-- Logo da academia (apenas dono) -->
      {isDono && (
        <Card>
          <h2 class="mb-1 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Logo da Academia</h2>
          <p class="text-xs text-zinc-500 mb-4">Aparece na barra lateral para todos os usuários.</p>

          <!-- Preview atual -->
          <div class="mb-4 rounded-lg border border-zinc-700 bg-zinc-900 flex items-center justify-center p-3 h-20 overflow-hidden">
            {academia?.logo_url
              ? <img id="logo-preview" src={academia.logo_url} alt="Logo atual" class="max-w-full max-h-full object-contain" />
              : <img id="logo-preview" src="/logo-unafit.png" alt="Logo padrão" class="max-w-full max-h-full object-contain opacity-30" />
            }
          </div>
          <p class="text-xs text-zinc-400 mb-3">
            {academia?.logo_url ? 'Logo personalizada ativa' : 'Usando logo padrão UNAFIT'} · PNG, JPG ou SVG · máx. 2 MB
          </p>

          <!-- Upload -->
          <form method="POST" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="action" value="logo" />
            <input id="input-logo" name="logo" type="file" accept="image/*" required
              class="w-full text-sm text-zinc-400 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border file:border-zinc-600 file:text-xs file:text-zinc-300 file:bg-zinc-800 hover:file:bg-zinc-700 cursor-pointer" />
            <button type="submit"
              class="w-full px-4 py-2 bg-primary hover:bg-primary/90 text-primary-foreground text-sm font-medium rounded-lg">
              Enviar logo
            </button>
          </form>

          {academia?.logo_url && (
            <form method="POST" class="mt-3 text-center">
              <input type="hidden" name="action" value="remover_logo" />
              <button type="submit" onclick="return confirm('Remover logo personalizada e voltar para o padrão UNAFIT?')"
                class="text-xs text-red-500 hover:text-red-400">
                Remover logo personalizada
              </button>
            </form>
          )}
        </Card>
      )}

    </div>

    <!-- Formulários -->
    <div class="lg:col-span-2 space-y-6">

      <!-- Dados pessoais -->
      <Card>
        <h2 class="mb-5 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Dados Pessoais</h2>
        <form method="POST" class="space-y-5">
          <input type="hidden" name="action" value="perfil" />
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Nome Completo</label>
            <input name="nome_completo" type="text" required value={profile.nome_completo}
              class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">E-mail</label>
            <input type="email" value={user.email} disabled
              class="w-full rounded-lg border border-border bg-muted px-3 py-2.5 text-sm text-muted-foreground cursor-not-allowed" />
            <p class="mt-1 text-xs text-muted-foreground">O e-mail não pode ser alterado aqui.</p>
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Telefone</label>
            <input name="telefone" type="tel" value={profile.telefone ?? ''} placeholder="(11) 99999-9999"
              class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
          </div>
          <div>
            <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Cargo</label>
            <input type="text" value={roleLabels[profile.role]} disabled
              class="w-full rounded-lg border border-border bg-muted px-3 py-2.5 text-sm text-muted-foreground cursor-not-allowed" />
          </div>
          {isDono && (
            <div>
              <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Nome da Academia</label>
              <input name="nome_academia" type="text" value={academia?.nome ?? ''} placeholder="Nome da sua academia"
                class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary" />
            </div>
          )}
          <button type="submit"
            class="rounded-lg bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors">
            Salvar Alterações
          </button>
        </form>
      </Card>

      <!-- Assinatura UNAFIT (apenas dono) -->
      {isDono && (
        <Card>
          <h2 class="mb-1 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Minha Assinatura UNAFIT</h2>
          <p class="text-xs text-zinc-500 mb-5">Plano contratado para uso do sistema.</p>

          {saasAssinatura ? (
            <div class="mb-6 flex flex-wrap gap-6 items-start">
              <div>
                <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Plano</p>
                <p class="text-base font-semibold text-foreground">{(saasAssinatura.saas_planos as any)?.nome ?? '—'}</p>
                <p class="text-sm text-muted-foreground">
                  R$ {Number((saasAssinatura.saas_planos as any)?.valor ?? 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 })}/mês
                </p>
              </div>
              <div>
                <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Status</p>
                <span class:list={[
                  'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold',
                  saasAssinatura.status === 'ativa'    && 'bg-green-900/30 text-green-400 border border-green-600/30',
                  saasAssinatura.status === 'trial'    && 'bg-blue-900/30 text-blue-400 border border-blue-600/30',
                  saasAssinatura.status === 'suspensa' && 'bg-yellow-900/30 text-yellow-400 border border-yellow-600/30',
                  saasAssinatura.status === 'cancelada'&& 'bg-zinc-900/30 text-zinc-400 border border-zinc-600/30',
                ]}>
                  {saasAssinaturaStatusLabels[saasAssinatura.status] ?? saasAssinatura.status}
                </span>
              </div>
              <div>
                <p class="text-xs text-zinc-500 uppercase tracking-wider mb-1">Início</p>
                <p class="text-sm text-foreground">
                  {new Date(saasAssinatura.data_inicio + 'T12:00:00').toLocaleDateString('pt-BR')}
                </p>
              </div>
            </div>
          ) : (
            <div class="mb-5 rounded-lg border border-yellow-600/30 bg-yellow-900/10 px-4 py-3 text-sm text-yellow-400">
              Nenhuma assinatura ativa encontrada. Entre em contato com o suporte UNAFIT.
            </div>
          )}

          <!-- Faturas SaaS -->
          <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-muted-foreground">Faturas</h3>
          {saasFaturas.length === 0 ? (
            <p class="text-sm text-muted-foreground">Nenhuma fatura registrada.</p>
          ) : (
            <div class="overflow-x-auto -mx-5">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-border">
                    <th class="px-5 pb-2 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground">Descrição</th>
                    <th class="px-5 pb-2 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground hidden sm:table-cell">Vencimento</th>
                    <th class="px-5 pb-2 text-right text-xs font-semibold uppercase tracking-wider text-muted-foreground">Valor</th>
                    <th class="px-5 pb-2 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground">Status</th>
                    <th class="px-5 pb-2 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground"></th>
                  </tr>
                </thead>
                <tbody>
                  {saasFaturas.map((f) => {
                    const s = saasStatusMap[f.status] ?? { label: f.status, cls: 'bg-zinc-800 text-zinc-400' };
                    return (
                      <tr class="border-b border-border/50 hover:bg-muted/30 transition-colors">
                        <td class="px-5 py-3 text-foreground">{f.descricao}</td>
                        <td class="px-5 py-3 text-muted-foreground hidden sm:table-cell">
                          {new Date(f.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}
                        </td>
                        <td class="px-5 py-3 text-right font-semibold text-foreground">
                          R$ {Number(f.valor).toLocaleString('pt-BR', { minimumFractionDigits: 2 })}
                        </td>
                        <td class="px-5 py-3">
                          <span class:list={['inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold', s.cls]}>
                            {s.label}
                          </span>
                        </td>
                        <td class="px-5 py-3">
                          {f.link_pagamento && f.status !== 'pago' && (
                            <a href={f.link_pagamento} target="_blank" rel="noopener noreferrer"
                              class="text-xs text-primary hover:text-primary/80 font-medium">
                              Pagar →
                            </a>
                          )}
                          {f.data_pagamento && (
                            <span class="text-xs text-muted-foreground">
                              Pago em {new Date(f.data_pagamento + 'T12:00:00').toLocaleDateString('pt-BR')}
                            </span>
                          )}
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          )}
        </Card>
      )}

    </div>
  </div>
</DashboardLayout>

<script>
  // Preview da imagem antes de enviar
  document.getElementById('input-logo')?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    const preview = document.getElementById('logo-preview') as HTMLImageElement;
    if (preview) preview.src = URL.createObjectURL(file);
  });
</script>
