---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'dono') return Astro.redirect('/dashboard');

const { data: colaboradores } = await supabase
  .from('colaboradores')
  .select('id, nome, email, telefone, cargo, status, criado_em')
  .eq('academia_id', profile.academia_id!)
  .order('nome');

const statusCores: Record<string, string> = {
  ativo:   'bg-green-900/50 text-green-400 border border-green-800/50',
  inativo: 'bg-zinc-800 text-zinc-500 border border-zinc-700',
};
---

<DashboardLayout title="Colaboradores">
  <div class="space-y-5">

    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-white">Colaboradores</h1>
        <p class="text-zinc-400 text-sm mt-0.5">
          {colaboradores?.length ?? 0} colaborador{(colaboradores?.length ?? 0) !== 1 ? 'es' : ''} cadastrado{(colaboradores?.length ?? 0) !== 1 ? 's' : ''}
        </p>
      </div>
      <a href="/dashboard/colaboradores/novo"
        class="inline-flex items-center gap-2 px-4 py-2 bg-primary hover:bg-primary/90 text-black text-sm font-bold rounded-lg transition-colors">
        + Novo Colaborador
      </a>
    </div>

    <!-- Lista -->
    {!colaboradores?.length ? (
      <div class="border border-zinc-700 rounded-xl p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-zinc-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <p class="text-zinc-400 text-lg mb-2">Nenhum colaborador cadastrado</p>
        <a href="/dashboard/colaboradores/novo" class="text-primary hover:text-primary/80 text-sm">Cadastrar primeiro colaborador →</a>
      </div>
    ) : (
      <div class="border border-zinc-700 rounded-xl overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-zinc-700 bg-zinc-900/60">
              <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider">Colaborador</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider hidden sm:table-cell">Cargo</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider hidden md:table-cell">Telefone</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider">Status</th>
              <th class="px-4 py-3"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-800">
            {colaboradores.map((c: any) => (
              <tr class="hover:bg-zinc-800/40 transition-colors">
                <td class="px-4 py-3">
                  <div class="font-medium text-white text-sm">{c.nome}</div>
                  <div class="text-zinc-500 text-xs">{c.email ?? '—'}</div>
                </td>
                <td class="px-4 py-3 hidden sm:table-cell">
                  <span class="text-sm text-zinc-300">{c.cargo ?? 'Colaborador'}</span>
                </td>
                <td class="px-4 py-3 hidden md:table-cell">
                  <span class="text-xs text-zinc-500">{c.telefone ?? '—'}</span>
                </td>
                <td class="px-4 py-3">
                  <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${statusCores[c.status] ?? ''}`}>
                    {c.status}
                  </span>
                </td>
                <td class="px-4 py-3 text-right">
                  <a href={`/dashboard/colaboradores/${c.id}`}
                    class="text-xs text-zinc-400 hover:text-white border border-zinc-700 hover:border-zinc-500 px-3 py-1 rounded-lg transition-colors">
                    Ver
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

  </div>
</DashboardLayout>
