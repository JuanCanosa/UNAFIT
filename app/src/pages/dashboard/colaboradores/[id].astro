---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';
import { enviarEmailNovaSenha, emailConfigurado } from '@/lib/email';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'dono') return Astro.redirect('/dashboard');

const { id: colaboradorId } = Astro.params;
let formError = '';

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'editar_colaborador') {
    const cpfRaw = (form.get('cpf') as string)?.replace(/\D/g, '') ?? '';
    const cpf    = cpfRaw.length === 11 ? cpfRaw : null;

    const campos: Record<string, any> = {
      nome:                 (form.get('nome') as string)?.trim(),
      email:                (form.get('email') as string)?.trim().toLowerCase() || null,
      cpf,
      telefone:             (form.get('telefone') as string)?.trim() || null,
      cargo:                (form.get('cargo') as string)?.trim() || 'Colaborador',
      status:               form.get('status') as string,
      endereco_cep:         (form.get('endereco_cep') as string)?.replace(/\D/g, '') || null,
      endereco_rua:         (form.get('endereco_rua') as string)?.trim() || null,
      endereco_numero:      (form.get('endereco_numero') as string)?.trim() || null,
      endereco_complemento: (form.get('endereco_complemento') as string)?.trim() || null,
      endereco_bairro:      (form.get('endereco_bairro') as string)?.trim() || null,
      endereco_cidade:      (form.get('endereco_cidade') as string)?.trim() || null,
      endereco_estado:      (form.get('endereco_estado') as string)?.trim().toUpperCase() || null,
      atualizado_em:        new Date().toISOString(),
    };

    const { error } = await supabase.from('colaboradores').update(campos)
      .eq('id', colaboradorId!).eq('academia_id', profile.academia_id!);

    if (error) { formError = error.message; }
    else {
      // Sincroniza nome e telefone no profile
      if (campos.nome && campos.profile_id) {
        const { data: colab } = await supabase.from('colaboradores').select('profile_id').eq('id', colaboradorId!).single();
        if (colab?.profile_id) {
          const adminClient = createSupabaseAdminClient();
          await adminClient.from('profiles').update({
            nome_completo: campos.nome,
            telefone: campos.telefone,
          }).eq('id', colab.profile_id);
        }
      }
      return Astro.redirect(`/dashboard/colaboradores/${colaboradorId}?saved=1`);
    }
  }

  if (action === 'definir_senha' || action === 'enviar_reset') {
    const adminClient = createSupabaseAdminClient();
    const { data: colab } = await supabase.from('colaboradores').select('nome, email, profile_id').eq('id', colaboradorId!).single();

    if (!colab?.email) {
      formError = 'Colaborador sem e-mail cadastrado.';
    } else {
      const { data: { users } } = await adminClient.auth.admin.listUsers({ page: 1, perPage: 50000 });
      const authUser = users.find(u => u.email?.toLowerCase() === colab.email!.toLowerCase());

      if (action === 'definir_senha') {
        const nova_senha = (form.get('nova_senha') as string)?.trim();
        if (!nova_senha || nova_senha.length < 8) {
          formError = 'A senha deve ter pelo menos 8 caracteres.';
        } else if (authUser) {
          const { error } = await adminClient.auth.admin.updateUserById(authUser.id, { password: nova_senha });
          if (error) formError = error.message;
          else return Astro.redirect(`/dashboard/colaboradores/${colaboradorId}?saved=1`);
        } else {
          formError = 'Usuário de acesso não encontrado.';
        }
      }

      if (action === 'enviar_reset') {
        if (!authUser) {
          formError = 'Usuário de acesso não encontrado.';
        } else {
          const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
          let senhaTemp = '';
          for (let i = 0; i < 10; i++) senhaTemp += chars[Math.floor(Math.random() * chars.length)];

          const { error: upErr } = await adminClient.auth.admin.updateUserById(authUser.id, { password: senhaTemp });
          if (upErr) {
            formError = upErr.message;
          } else {
            const { data: acad } = await adminClient.from('academias').select('nome, slug, logo_url').eq('id', profile.academia_id!).single();
            const siteUrl  = (process.env.SITE ?? 'https://unafit.com.br').replace(/\/$/, '');
            const loginUrl = acad?.slug ? `${siteUrl}/${acad.slug}` : `${siteUrl}/login`;

            if (!emailConfigurado()) {
              return Astro.redirect(`/dashboard/colaboradores/${colaboradorId}?reset=1&senha_temp=${encodeURIComponent(senhaTemp)}&login_url=${encodeURIComponent(loginUrl)}`);
            }

            const res = await enviarEmailNovaSenha({
              email:           colab.email,
              nomeAluno:       colab.nome,
              nomeAcademia:    acad?.nome ?? 'Academia',
              logoUrl:         acad?.logo_url ?? null,
              senhaTemporaria: senhaTemp,
              loginUrl,
            });
            if (!res.ok) formError = res.erro ?? 'Erro ao enviar e-mail.';
            else return Astro.redirect(`/dashboard/colaboradores/${colaboradorId}?reset=1`);
          }
        }
      }
    }
  }

  if (action === 'toggle_status') {
    const { data: atual } = await supabase.from('colaboradores').select('status, profile_id').eq('id', colaboradorId!).single();
    const novoStatus = atual?.status === 'ativo' ? 'inativo' : 'ativo';
    await supabase.from('colaboradores').update({ status: novoStatus, atualizado_em: new Date().toISOString() }).eq('id', colaboradorId!);

    // Sincroniza o campo ativo no profiles
    if (atual?.profile_id) {
      const adminClient = createSupabaseAdminClient();
      await adminClient.from('profiles').update({ ativo: novoStatus === 'ativo' }).eq('id', atual.profile_id);
    }
    return Astro.redirect(`/dashboard/colaboradores/${colaboradorId}`);
  }
}

// Busca dados
const urlParams     = new URL(Astro.request.url).searchParams;
const savedParam    = urlParams.get('saved');
const novoParam     = urlParams.get('novo');
const resetParam    = urlParams.get('reset');
const senhaTempParam = urlParams.get('senha_temp');
const loginUrlParam  = urlParams.get('login_url');

const { data: colaborador } = await supabase
  .from('colaboradores')
  .select('*')
  .eq('id', colaboradorId!)
  .eq('academia_id', profile.academia_id!)
  .single();

if (!colaborador) return Astro.redirect('/dashboard/colaboradores');

const cpfMascarado = colaborador.cpf
  ? colaborador.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4')
  : '';
const cepMascarado = (colaborador.endereco_cep ?? '').replace(/^(\d{5})(\d{3})$/, '$1-$2');
---

<DashboardLayout title={colaborador.nome}>
  <div class="max-w-4xl mx-auto space-y-5">

    <!-- Breadcrumb -->
    <div class="flex items-center gap-2 text-sm text-zinc-400">
      <a href="/dashboard/colaboradores" class="hover:text-white transition-colors">← Colaboradores</a>
      <span class="text-zinc-700">/</span>
      <span class="text-white">{colaborador.nome}</span>
    </div>

    <!-- Banners -->
    {(savedParam || novoParam) && (
      <div class="bg-green-900/40 border border-green-600 text-green-300 px-4 py-3 rounded-lg text-sm">
        {novoParam ? 'Colaborador cadastrado com sucesso!' : 'Alterações salvas!'}
      </div>
    )}
    {resetParam && !senhaTempParam && (
      <div class="bg-blue-900/40 border border-blue-600 text-blue-300 px-4 py-3 rounded-lg text-sm">
        ✉ E-mail com nova senha enviado para {colaborador.email}.
      </div>
    )}
    {(novoParam || resetParam) && senhaTempParam && (
      <div class="rounded-lg border border-yellow-600/40 bg-yellow-900/20 px-4 py-3 text-sm space-y-1.5">
        <p class="font-semibold text-yellow-300">Senha gerada — repasse manualmente ao colaborador:</p>
        <p class="text-yellow-200">Login: <strong>{colaborador.email}</strong></p>
        <p class="text-yellow-200">Senha: <strong class="font-mono text-lg tracking-widest">{senhaTempParam}</strong></p>
        {loginUrlParam && <p class="text-yellow-200">URL: <strong>{loginUrlParam}</strong></p>}
      </div>
    )}
    {formError && (
      <div class="bg-red-900/40 border border-red-600 text-red-300 px-4 py-3 rounded-lg text-sm">{formError}</div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Coluna esquerda -->
      <div class="space-y-4">

        <!-- Perfil -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-3">
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-lg font-bold text-white">{colaborador.nome}</h1>
              <p class="text-zinc-400 text-sm">{colaborador.cargo ?? 'Colaborador'}</p>
            </div>
            <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${
              colaborador.status === 'ativo'
                ? 'bg-green-900/50 text-green-400 border border-green-800/50'
                : 'bg-zinc-800 text-zinc-500 border border-zinc-700'
            }`}>{colaborador.status}</span>
          </div>

          <div class="space-y-1.5 text-sm text-zinc-400 border-t border-zinc-800 pt-3">
            {colaborador.email && <p><span class="text-zinc-600">Email:</span> {colaborador.email}</p>}
            {colaborador.telefone && <p><span class="text-zinc-600">Tel:</span> {colaborador.telefone}</p>}
            {colaborador.cpf && (
              <p><span class="text-zinc-600">CPF:</span> {colaborador.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4')}</p>
            )}
          </div>

          {(colaborador.endereco_rua) && (
            <div class="text-xs text-zinc-500 border-t border-zinc-800 pt-3">
              {colaborador.endereco_rua}{colaborador.endereco_numero ? `, ${colaborador.endereco_numero}` : ''}<br />
              {colaborador.endereco_bairro && `${colaborador.endereco_bairro} — `}{colaborador.endereco_cidade}/{colaborador.endereco_estado}
              {colaborador.endereco_cep && ` · ${colaborador.endereco_cep}`}
            </div>
          )}

          <button onclick="document.getElementById('modal-editar').classList.remove('hidden')"
            class="w-full py-2 border border-zinc-600 hover:border-zinc-400 text-zinc-300 text-sm rounded-lg transition-colors">
            Editar dados
          </button>
        </div>

        <!-- Acesso ao Sistema -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-4">
          <h2 class="text-sm font-semibold text-zinc-300">Acesso ao Sistema</h2>

          <div class="flex items-center gap-2 text-xs">
            <span class="text-zinc-500">Login via:</span>
            <span class="px-2 py-0.5 rounded-full font-medium bg-blue-900/40 text-blue-300">
              ✉ {colaborador.email}
            </span>
          </div>

          <!-- Definir senha -->
          <form method="POST" class="space-y-2">
            <input type="hidden" name="action" value="definir_senha" />
            <label class="block text-xs text-zinc-400">Definir senha</label>
            <div class="flex gap-2">
              <input name="nova_senha" type="password" minlength="8" required
                placeholder="Nova senha (mín. 8 car.)"
                class="flex-1 bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
              <button type="submit"
                class="px-3 py-2 bg-primary hover:bg-primary/90 text-primary-foreground text-xs font-medium rounded-lg whitespace-nowrap">
                Salvar
              </button>
            </div>
          </form>

          <!-- Enviar reset por email -->
          {colaborador.email && (
            <div class="border-t border-zinc-800 pt-3">
              <p class="text-xs text-zinc-400 mb-2">Ou envie nova senha por e-mail:</p>
              <form method="POST">
                <input type="hidden" name="action" value="enviar_reset" />
                <button type="submit"
                  class="w-full py-2 border border-zinc-700 hover:border-zinc-500 text-zinc-400 hover:text-zinc-200 text-xs rounded-lg transition-colors">
                  ✉ Enviar nova senha para {colaborador.email}
                </button>
              </form>
            </div>
          )}
        </div>

        <!-- Ativar / Desativar -->
        <form method="POST" onsubmit={`return confirm('${colaborador.status === 'ativo' ? 'Desativar' : 'Ativar'} este colaborador?')`}>
          <input type="hidden" name="action" value="toggle_status" />
          <button type="submit" class={`w-full py-2 text-sm rounded-lg border transition-colors ${
            colaborador.status === 'ativo'
              ? 'border-red-800/50 text-red-400/80 hover:border-red-700 hover:text-red-400'
              : 'border-green-800/50 text-green-400/80 hover:border-green-700 hover:text-green-400'
          }`}>
            {colaborador.status === 'ativo' ? 'Desativar colaborador' : 'Reativar colaborador'}
          </button>
        </form>

      </div>

      <!-- Coluna direita: Informações adicionais -->
      <div class="lg:col-span-2 space-y-5">

        <!-- Sobre o cargo -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5">
          <h2 class="text-sm font-semibold text-zinc-300 mb-4">Permissões do Cargo</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {[
              { label: 'Criar e visualizar WODs', ok: true },
              { label: 'Visualizar agenda de aulas', ok: true },
              { label: 'Visualizar presenças', ok: true },
              { label: 'Ver ranking de alunos', ok: true },
              { label: 'Cadastrar e editar alunos', ok: true },
              { label: 'Ver dados financeiros', ok: false },
              { label: 'Ver configurações da academia', ok: false },
              { label: 'Gerenciar colaboradores', ok: false },
            ].map(p => (
              <div class="flex items-center gap-2 text-sm">
                <span class={p.ok ? 'text-green-400' : 'text-red-400/60'}>
                  {p.ok ? '✓' : '✗'}
                </span>
                <span class={p.ok ? 'text-zinc-300' : 'text-zinc-600'}>{p.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Info de cadastro -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5">
          <h2 class="text-sm font-semibold text-zinc-300 mb-3">Informações</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-zinc-500">Cadastrado em</span>
              <span class="text-zinc-300">
                {new Date(colaborador.criado_em).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
              </span>
            </div>
            <div class="flex justify-between">
              <span class="text-zinc-500">Última atualização</span>
              <span class="text-zinc-300">
                {new Date(colaborador.atualizado_em).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}
              </span>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <!-- Modal Editar -->
  <div id="modal-editar" class="hidden fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 overflow-y-auto">
    <div class="bg-zinc-900 border border-zinc-700 rounded-2xl p-6 w-full max-w-lg my-4 space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold text-white">Editar Colaborador</h3>
        <button onclick="document.getElementById('modal-editar').classList.add('hidden')" class="text-zinc-400 hover:text-white text-xl">×</button>
      </div>
      <form method="POST" class="space-y-3">
        <input type="hidden" name="action" value="editar_colaborador" />
        <div>
          <label class="block text-sm text-zinc-400 mb-1">Nome *</label>
          <input name="nome" value={colaborador.nome} required
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">E-mail</label>
            <input name="email" type="email" value={colaborador.email ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Telefone</label>
            <input name="telefone" value={colaborador.telefone ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">CPF</label>
            <input name="cpf" id="modal-cpf-colab" value={cpfMascarado} maxlength="14" placeholder="000.000.000-00"
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Cargo</label>
            <input name="cargo" value={colaborador.cargo ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Status</label>
            <select name="status" class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none">
              <option value="ativo"   selected={colaborador.status === 'ativo'}>Ativo</option>
              <option value="inativo" selected={colaborador.status === 'inativo'}>Inativo</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">CEP</label>
            <input name="endereco_cep" id="modal-cep-colab" value={cepMascarado} maxlength="9"
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
        </div>
        <div>
          <label class="block text-sm text-zinc-400 mb-1">Rua</label>
          <input name="endereco_rua" id="modal-rua-colab" value={colaborador.endereco_rua ?? ''}
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Número</label>
            <input name="endereco_numero" value={colaborador.endereco_numero ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Bairro</label>
            <input name="endereco_bairro" id="modal-bairro-colab" value={colaborador.endereco_bairro ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Cidade</label>
            <input name="endereco_cidade" id="modal-cidade-colab" value={colaborador.endereco_cidade ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Estado (UF)</label>
            <input name="endereco_estado" maxlength="2" value={colaborador.endereco_estado ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
          </div>
        </div>
        <div class="flex gap-2 pt-2">
          <button type="button" onclick="document.getElementById('modal-editar').classList.add('hidden')"
            class="flex-1 py-2 border border-zinc-600 text-zinc-300 rounded-lg text-sm">Cancelar</button>
          <button type="submit"
            class="flex-1 py-2 bg-primary hover:bg-primary/90 text-primary-foreground rounded-lg text-sm font-medium">Salvar</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  // Máscara CPF no modal
  document.getElementById('modal-cpf-colab')?.addEventListener('input', function(this: HTMLInputElement) {
    const d = this.value.replace(/\D/g, '').slice(0, 11);
    if (d.length > 9) this.value = d.replace(/(\d{3})(\d{3})(\d{3})(\d{1,2})/, '$1.$2.$3-$4');
    else if (d.length > 6) this.value = d.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
    else if (d.length > 3) this.value = d.replace(/(\d{3})(\d{1,3})/, '$1.$2');
    else this.value = d;
  });

  // Busca CEP no modal
  document.getElementById('modal-cep-colab')?.addEventListener('blur', async function(this: HTMLInputElement) {
    const cep = this.value.replace(/\D/g, '');
    if (cep.length !== 8) return;
    try {
      const res = await fetch(`https://viacep.com.br/ws/${cep}/json/`);
      const d = await res.json();
      if (d.erro) return;
      (document.getElementById('modal-rua-colab') as HTMLInputElement).value    = d.logradouro ?? '';
      (document.getElementById('modal-bairro-colab') as HTMLInputElement).value = d.bairro ?? '';
      (document.getElementById('modal-cidade-colab') as HTMLInputElement).value = d.localidade ?? '';
    } catch {}
  });
</script>
