---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, nome_completo, academia_id')
  .eq('id', user.id)
  .single();

const hoje = new Date().toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long' });
const hojeISO = new Date().toISOString().split('T')[0];
const firstName = profile?.nome_completo?.split(' ')[0] ?? 'Admin';

// ── SaaS Admin: stats globais ─────────────────────────────────────────────────
let saasStats = {
  totalAcademias: 0,
  totalAtivas: 0,
  totalAlunos: 0,
  mrr: 0,
  inadimplentes: 0,
  academiasPorPlano: [] as { nome: string; valor: number; count: number }[],
  faturasRecentes: [] as any[],
  academiasLista: [] as any[],
};

if (profile?.role === 'saas_admin') {
  const adminClient = createSupabaseAdminClient();

  const { data: academias } = await adminClient
    .from('academias')
    .select('id, nome, slug, ativo, logo_url, saas_assinaturas(status, saas_planos(nome, valor))')
    .order('criado_em', { ascending: false });

  const { data: contagens } = await adminClient
    .from('profiles')
    .select('academia_id, role')
    .eq('role', 'aluno');

  const contagemAlunos: Record<string, number> = (contagens ?? []).reduce((acc: Record<string, number>, p: any) => {
    if (p.academia_id) acc[p.academia_id] = (acc[p.academia_id] ?? 0) + 1;
    return acc;
  }, {});

  saasStats.totalAcademias = academias?.length ?? 0;
  saasStats.totalAtivas    = academias?.filter((a: any) => a.ativo).length ?? 0;
  saasStats.totalAlunos    = (contagens ?? []).length;

  saasStats.mrr = (academias ?? []).reduce((sum: number, a: any) => {
    const assin = a.saas_assinaturas?.[0];
    if (assin?.status === 'ativa') sum += Number(assin.saas_planos?.valor ?? 0);
    return sum;
  }, 0);

  // Inadimplentes: academias ativas SEM assinatura ativa
  saasStats.inadimplentes = (academias ?? []).filter((a: any) => {
    if (!a.ativo) return false;
    const assin = a.saas_assinaturas?.[0];
    return !assin || assin.status !== 'ativa';
  }).length;

  // Academias por plano
  const planoMap: Record<string, { nome: string; valor: number; count: number }> = {};
  for (const a of academias ?? []) {
    const assin = (a as any).saas_assinaturas?.[0];
    if (assin?.status === 'ativa' && assin.saas_planos) {
      const k = assin.saas_planos.nome;
      planoMap[k] = planoMap[k] ?? { nome: k, valor: Number(assin.saas_planos.valor), count: 0 };
      planoMap[k].count++;
    }
  }
  saasStats.academiasPorPlano = Object.values(planoMap).sort((a, b) => b.valor - a.valor);

  // Últimas faturas
  const { data: faturas } = await adminClient
    .from('saas_faturas')
    .select('id, descricao, valor, data_vencimento, status, academia_id')
    .order('criado_em', { ascending: false })
    .limit(5);
  saasStats.faturasRecentes = faturas ?? [];

  // Lista academias com contagem
  saasStats.academiasLista = (academias ?? []).map((a: any) => ({
    ...a,
    totalAlunos: contagemAlunos[a.id] ?? 0,
    assin: a.saas_assinaturas?.[0] ?? null,
  }));
}

// ── Academia/colaborador: stats do dia + mês ──────────────────────────────────
let totalAulasHoje    = 0;
let totalCheckins     = 0;
let totalAulasNoMes   = 0;
let totalPresencasNoMes = 0;
let aniversariantesHoje: { id: string; nome: string }[] = [];
let aniversariantesMes:  { id: string; nome: string; data_nascimento: string }[] = [];

if (profile?.role !== 'aluno' && profile?.role !== 'saas_admin') {
  const hojeISO_BR  = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Sao_Paulo' }).format(new Date());
  const inicioMesISO = hojeISO_BR.slice(0, 7) + '-01';

  const [
    { count: aulas },
    { count: checkins },
    { count: aulasmes },
    { count: checkinsmes },
  ] = await Promise.all([
    supabase.from('aulas_agenda').select('id', { count: 'exact', head: true })
      .eq('academia_id', profile!.academia_id!).eq('data_aula', hojeISO),
    supabase.from('checkins').select('id', { count: 'exact', head: true })
      .eq('academia_id', profile!.academia_id!).gte('feito_em', `${hojeISO}T00:00:00`),
    supabase.from('aulas_agenda').select('id', { count: 'exact', head: true })
      .eq('academia_id', profile!.academia_id!).gte('data_aula', inicioMesISO).lte('data_aula', hojeISO_BR),
    supabase.from('checkins').select('id', { count: 'exact', head: true })
      .eq('academia_id', profile!.academia_id!).gte('feito_em', `${inicioMesISO}T00:00:00`),
  ]);

  totalAulasHoje      = aulas ?? 0;
  totalCheckins       = checkins ?? 0;
  totalAulasNoMes     = aulasmes ?? 0;
  totalPresencasNoMes = checkinsmes ?? 0;

  // Filtra aniversariantes em JS (igual à página /dashboard/aniversariantes)
  const mes    = hojeISO_BR.slice(5, 7);
  const dia    = hojeISO_BR.slice(8, 10);
  const hojeMMDD = `${mes}-${dia}`;

  const { data: alunosComAniv } = await supabase
    .from('alunos')
    .select('id, nome, data_nascimento')
    .eq('academia_id', profile!.academia_id!)
    .eq('status', 'ativo')
    .not('data_nascimento', 'is', null);

  const todos = alunosComAniv ?? [];
  aniversariantesHoje = todos.filter(a => a.data_nascimento.slice(5) === hojeMMDD);
  aniversariantesMes  = todos
    .filter(a => a.data_nascimento.slice(5, 7) === mes && a.data_nascimento.slice(5) !== hojeMMDD)
    .sort((a, b) => Number(a.data_nascimento.slice(8, 10)) - Number(b.data_nascimento.slice(8, 10)));
}

const statusFaturaStyle: Record<string, string> = {
  pendente: 'border-yellow-500/30 text-yellow-400 bg-yellow-500/10',
  pago:     'border-green-600/30 text-green-400 bg-green-600/10',
  vencido:  'border-red-600/30 text-red-400 bg-red-600/10',
  cancelado:'border-zinc-700 text-zinc-500 bg-zinc-800/50',
};

const brl = (v: number) => v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
const mrrFmt = brl(saasStats.mrr);
const isSaasAdmin = profile?.role === 'saas_admin';
---

<DashboardLayout title="Dashboard">
  <!-- Cabeçalho -->
  <div class="mb-7">
    <p class="text-sm text-muted-foreground capitalize">{hoje}</p>
    <h1 class="mt-1 text-2xl font-bold text-foreground">
      Olá, <span class="text-primary">{firstName}</span>
    </h1>
  </div>

  <!-- DASHBOARD SAAS ADMIN -->
  {isSaasAdmin && (
    <div>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-xs text-muted-foreground mb-1">Academias Ativas</p>
          <p class="text-3xl font-bold text-foreground">{saasStats.totalAtivas}</p>
          <p class="text-xs text-muted-foreground mt-1">de {saasStats.totalAcademias} cadastradas</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-5">
          <p class="text-xs text-muted-foreground mb-1">Total de Alunos</p>
          <p class="text-3xl font-bold text-foreground">{saasStats.totalAlunos}</p>
          <p class="text-xs text-muted-foreground mt-1">em todas as academias</p>
        </div>
        <div class="rounded-xl border border-primary/30 bg-primary/5 p-5">
          <p class="text-xs text-muted-foreground mb-1">MRR</p>
          <p class="text-3xl font-bold text-primary">{mrrFmt}</p>
          <p class="text-xs text-muted-foreground mt-1">receita recorrente mensal</p>
        </div>
        <div class={`rounded-xl border p-5 ${saasStats.inadimplentes > 0 ? 'border-red-600/30 bg-red-900/10' : 'border-border bg-card'}`}>
          <p class="text-xs text-muted-foreground mb-1">Inadimplentes</p>
          <p class={`text-3xl font-bold ${saasStats.inadimplentes > 0 ? 'text-red-400' : 'text-foreground'}`}>
            {saasStats.inadimplentes}
          </p>
          <p class="text-xs text-muted-foreground mt-1">academias sem plano ativo</p>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
        <div class="rounded-xl border border-border bg-card p-5">
          <h2 class="text-sm font-semibold text-foreground mb-4">Distribuição por Plano</h2>
          {saasStats.academiasPorPlano.length === 0 ? (
            <p class="text-sm text-muted-foreground text-center py-4">Nenhuma assinatura ativa.</p>
          ) : (
            <div class="space-y-3">
              {saasStats.academiasPorPlano.map(p => {
                const pct = saasStats.totalAtivas > 0 ? Math.round((p.count / saasStats.totalAtivas) * 100) : 0;
                const pFmt = brl(p.valor);
                return (
                  <div>
                    <div class="flex justify-between text-sm mb-1">
                      <span class="font-medium text-foreground">{p.nome}</span>
                      <span class="text-muted-foreground">{p.count} academia{p.count !== 1 ? 's' : ''}</span>
                    </div>
                    <div class="flex items-center gap-3">
                      <div class="flex-1 h-2 rounded-full bg-zinc-800 overflow-hidden">
                        <div class="h-full rounded-full bg-primary" style={`width: ${pct}%`}></div>
                      </div>
                      <span class="text-xs text-primary font-medium shrink-0">{pFmt}/mês</span>
                    </div>
                  </div>
                );
              })}
              <div class="pt-2 border-t border-border flex justify-between text-sm">
                <span class="text-muted-foreground">MRR total</span>
                <span class="font-bold text-primary">{mrrFmt}</span>
              </div>
            </div>
          )}
        </div>

        <div class="lg:col-span-2 rounded-xl border border-border bg-card p-5">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-sm font-semibold text-foreground">Academias</h2>
            <a href="/dashboard/academias" class="text-xs text-primary hover:underline">Ver todas →</a>
          </div>
          <div class="space-y-2">
            {saasStats.academiasLista.slice(0, 6).map((a: any) => (
              <a href={`/dashboard/academias/${a.id}`}
                class="flex items-center gap-3 rounded-lg border border-transparent hover:border-border hover:bg-zinc-900/60 px-3 py-2.5 transition-colors group">
                <div class="h-8 w-8 shrink-0 flex items-center justify-center rounded-lg bg-primary/10 text-primary font-bold text-sm overflow-hidden">
                  {a.logo_url
                    ? <img src={a.logo_url} alt={a.nome} class="w-full h-full object-contain p-0.5" />
                    : a.nome.charAt(0).toUpperCase()
                  }
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-foreground truncate group-hover:text-primary transition-colors">{a.nome}</p>
                  <p class="text-xs text-muted-foreground">
                    {a.totalAlunos} aluno{a.totalAlunos !== 1 ? 's' : ''}
                    {a.assin?.saas_planos?.nome ? ` · ${a.assin.saas_planos.nome}` : ' · Sem plano'}
                  </p>
                </div>
                <div class="shrink-0">
                  {a.assin?.status === 'ativa' ? (
                    <span class="text-xs px-2 py-0.5 rounded-full border border-green-600/30 text-green-400 bg-green-600/10">ativa</span>
                  ) : a.ativo ? (
                    <span class="text-xs px-2 py-0.5 rounded-full border border-red-600/30 text-red-400 bg-red-900/20">sem plano</span>
                  ) : (
                    <span class="text-xs px-2 py-0.5 rounded-full border border-zinc-700 text-zinc-500">inativa</span>
                  )}
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>

      {saasStats.faturasRecentes.length > 0 && (
        <div class="mt-5 rounded-xl border border-border bg-card p-5">
          <h2 class="text-sm font-semibold text-foreground mb-4">Faturas Recentes</h2>
          <div class="space-y-2">
            {saasStats.faturasRecentes.map((f: any) => {
              const fVencimento = new Date(f.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR');
              const fValor = brl(Number(f.valor));
              const fStyle = statusFaturaStyle[f.status] ?? 'border-border text-muted-foreground';
              return (
                <div class="flex items-center gap-3 text-sm">
                  <div class="flex-1 min-w-0">
                    <p class="text-foreground truncate">{f.descricao}</p>
                    <p class="text-xs text-muted-foreground">Vence: {fVencimento}</p>
                  </div>
                  <span class="font-semibold text-foreground shrink-0">{fValor}</span>
                  <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full border ${fStyle}`}>{f.status}</span>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  )}

  <!-- DASHBOARD ACADEMIA (dono / colaborador / aluno) -->
  {!isSaasAdmin && (
    <div>
      {/* ── Aniversário HOJE — destaque piscante ── */}
      {aniversariantesHoje.length > 0 && (
        <div class="bday-flash mb-4 relative overflow-hidden rounded-xl border-2 border-primary px-5 py-4 flex items-center gap-4">
          <div class="pointer-events-none absolute inset-0 bday-glow rounded-xl" />
          <span class="text-3xl shrink-0 bday-bounce">🎂</span>
          <div class="min-w-0 flex-1 relative">
            <p class="text-primary font-bold text-base">
              {aniversariantesHoje.length === 1 ? 'Aniversário hoje!' : `${aniversariantesHoje.length} aniversários hoje!`}
            </p>
            <p class="text-primary/80 text-sm mt-0.5 truncate">
              {aniversariantesHoje.map((a, i) => (
                <>
                  <a href={`/dashboard/alunos/${a.id}`} class="hover:text-white underline underline-offset-2 font-medium">{a.nome}</a>
                  {i < aniversariantesHoje.length - 1 ? ', ' : ''}
                </>
              ))}
            </p>
          </div>
          <a href="/dashboard/aniversariantes"
            class="shrink-0 text-xs text-primary/70 hover:text-primary border border-primary/30 px-3 py-1.5 rounded-lg transition-colors relative">
            Ver todos →
          </a>
        </div>
      )}

      {/* ── Aniversariantes do MÊS ── */}
      {profile?.role !== 'aluno' && (aniversariantesHoje.length > 0 || aniversariantesMes.length > 0) && (
        <div class="mb-6 flex items-center justify-between rounded-xl border border-zinc-700 bg-zinc-900/60 px-5 py-3">
          <div class="flex items-center gap-3">
            <span class="text-lg">🎉</span>
            <div>
              <p class="text-sm font-semibold text-white">
                {aniversariantesHoje.length + aniversariantesMes.length} aniversariante{(aniversariantesHoje.length + aniversariantesMes.length) !== 1 ? 's' : ''} este mês
              </p>
              <p class="text-xs text-zinc-500 mt-0.5">
                {aniversariantesMes.slice(0, 3).map(a => a.nome.split(' ')[0]).join(', ')}
                {aniversariantesMes.length > 3 ? ` e mais ${aniversariantesMes.length - 3}…` : ''}
              </p>
            </div>
          </div>
          <a href="/dashboard/aniversariantes"
            class="text-xs text-primary hover:text-primary/80 border border-primary/20 px-3 py-1.5 rounded-lg transition-colors">
            Ver mural →
          </a>
        </div>
      )}

      {profile?.role !== 'aluno' && (
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-7">
          <Card>
            <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Aulas Hoje</p>
            <p class="mt-2 text-3xl font-bold text-foreground">{totalAulasHoje}</p>
            <p class="mt-1 text-xs text-muted-foreground">turmas agendadas</p>
          </Card>
          <Card>
            <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Check-ins Hoje</p>
            <p class="mt-2 text-3xl font-bold text-primary">{totalCheckins}</p>
            <p class="mt-1 text-xs text-muted-foreground">presenças hoje</p>
          </Card>
          <Card>
            <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Aulas no Mês</p>
            <p class="mt-2 text-3xl font-bold text-foreground">{totalAulasNoMes}</p>
            <p class="mt-1 text-xs text-muted-foreground">turmas realizadas</p>
          </Card>
          <div class="rounded-xl border border-primary/20 bg-primary/5 p-5">
            <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Presenças no Mês</p>
            <p class="mt-2 text-3xl font-bold text-primary">{totalPresencasNoMes}</p>
            <p class="mt-1 text-xs text-muted-foreground">
              <a href="/dashboard/rankings" class="hover:text-primary transition-colors">ver ranking →</a>
            </p>
          </div>
        </div>
      )}

      <h2 class="text-sm font-semibold text-muted-foreground uppercase tracking-wider mb-3">Acesso rápido</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {profile?.role === 'aluno' && (
          <>
            <a href="/dashboard/checkin" class="group block">
              <Card class="hover:border-primary/40 transition-colors cursor-pointer">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 border border-primary/20 group-hover:bg-primary/20 transition-colors">
                    <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-foreground">Fazer Check-in</p>
                    <p class="text-xs text-muted-foreground">Aulas de hoje</p>
                  </div>
                </div>
              </Card>
            </a>
            <a href="/dashboard/resultados" class="group block">
              <Card class="hover:border-primary/40 transition-colors cursor-pointer">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 border border-primary/20 group-hover:bg-primary/20 transition-colors">
                    <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-foreground">Meus Resultados</p>
                    <p class="text-xs text-muted-foreground">Histórico de performance</p>
                  </div>
                </div>
              </Card>
            </a>
          </>
        )}
        {(profile?.role === 'colaborador' || profile?.role === 'dono') && (
          <>
            <a href="/dashboard/wods" class="group block">
              <Card class="hover:border-primary/40 transition-colors cursor-pointer">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 border border-primary/20 group-hover:bg-primary/20 transition-colors">
                    <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-foreground">Criar WOD</p>
                    <p class="text-xs text-muted-foreground">Programar treino</p>
                  </div>
                </div>
              </Card>
            </a>
            <a href="/dashboard/agenda" class="group block">
              <Card class="hover:border-primary/40 transition-colors cursor-pointer">
                <div class="flex items-center gap-3">
                  <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 border border-primary/20 group-hover:bg-primary/20 transition-colors">
                    <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <p class="font-semibold text-foreground">Agenda</p>
                    <p class="text-xs text-muted-foreground">{totalAulasHoje} aula{totalAulasHoje !== 1 ? 's' : ''} hoje</p>
                  </div>
                </div>
              </Card>
            </a>
          </>
        )}
      </div>
    </div>
  )}
</DashboardLayout>

<style>
  /* Banner pisca-pisca para aniversário do dia */
  @keyframes bday-border {
    0%, 100% { border-color: hsl(var(--primary) / 0.5); box-shadow: 0 0 0 0 hsl(var(--primary) / 0); }
    50%       { border-color: hsl(var(--primary) / 1);   box-shadow: 0 0 18px 4px hsl(var(--primary) / 0.25); }
  }
  @keyframes bday-bg {
    0%, 100% { background: hsl(var(--primary) / 0.05); }
    50%       { background: hsl(var(--primary) / 0.12); }
  }
  @keyframes bday-bounce {
    0%, 100% { transform: translateY(0); }
    40%       { transform: translateY(-6px); }
    60%       { transform: translateY(-3px); }
  }
  .bday-flash {
    animation: bday-border 1.6s ease-in-out infinite, bday-bg 1.6s ease-in-out infinite;
  }
  .bday-glow {
    background: radial-gradient(ellipse at center, hsl(var(--primary) / 0.08) 0%, transparent 70%);
    animation: bday-bg 1.6s ease-in-out infinite;
  }
  .bday-bounce {
    display: inline-block;
    animation: bday-bounce 1.6s ease-in-out infinite;
  }
</style>
