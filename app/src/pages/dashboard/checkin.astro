---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, nome_completo, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'aluno') return Astro.redirect('/dashboard');

const admin   = createSupabaseAdminClient();
// Data de hoje no fuso de Brasília (servidor roda em UTC)
const hojeISO = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Sao_Paulo' }).format(new Date());

// Academia (branding)
const { data: academia } = await admin
  .from('academias')
  .select('nome, logo_url')
  .eq('id', profile.academia_id!)
  .single();

// Aulas de hoje
const { data: aulas } = await supabase
  .from('aulas_agenda')
  .select('id, data_aula, horario_inicio, horario_fim, capacidade_max, modalidade, wods(nome, score_type, treino)')
  .eq('academia_id', profile.academia_id!)
  .eq('data_aula', hojeISO)
  .order('horario_inicio');

const aulaIds = aulas?.map(a => a.id) ?? [];

// Check-ins do aluno + total por aula (para capacidade)
const [checkinAlunoRes, todosCheckinsRes] = await Promise.all([
  aulaIds.length > 0
    ? supabase.from('checkins').select('aula_id').eq('aluno_id', user.id).in('aula_id', aulaIds)
    : Promise.resolve({ data: [] }),
  aulaIds.length > 0
    ? admin.from('checkins').select('aula_id').in('aula_id', aulaIds)
    : Promise.resolve({ data: [] }),
]);

const checkinsFeitosSet = new Set<string>(
  (checkinAlunoRes.data ?? []).map((c: any) => c.aula_id)
);
const checkinCountMap = new Map<string, number>();
(todosCheckinsRes.data ?? []).forEach((c: any) => {
  checkinCountMap.set(c.aula_id, (checkinCountMap.get(c.aula_id) ?? 0) + 1);
});

// Inadimplência — apenas para banner informativo, não bloqueia
const { count: faturasPendentes } = await admin
  .from('faturas')
  .select('id', { count: 'exact', head: true })
  .eq('aluno_id', user.id)
  .eq('academia_id', profile.academia_id!)
  .in('status', ['pendente', 'vencida']);

const temInadimplencia = (faturasPendentes ?? 0) > 0;

// ── Helpers ───────────────────────────────────────────────────────────────────
function fmt(t: string) { return t.substring(0, 5); }

type AulaStatus = 'aguardando' | 'aberto' | 'encerrado';

function getStatus(dataAula: string, inicio: string, fim: string): AulaStatus {
  const agora = new Date(); // UTC
  const hIni  = inicio.length === 5 ? inicio + ':00' : inicio;
  const hFim  = fim.length   === 5 ? fim   + ':00' : fim;
  // Offset -03:00 de Brasília para comparação correta com UTC do servidor
  const ini = new Date(`${dataAula}T${hIni}-03:00`);
  const end = new Date(`${dataAula}T${hFim}-03:00`);
  const abertura  = new Date(ini.getTime() - 10 * 60_000);
  const fechamento = new Date(end.getTime() + 10 * 60_000);
  if (agora < abertura)   return 'aguardando';
  if (agora <= fechamento) return 'aberto';
  return 'encerrado';
}

const scoreLabel: Record<string, string> = {
  tempo: 'Para Tempo', reps: 'Max Reps', carga: 'Max Carga',
  rounds_reps: 'AMRAP', pass_fail: 'Pass / Fail',
};

const hoje = new Date().toLocaleDateString('pt-BR', {
  weekday: 'long', day: 'numeric', month: 'long',
});
---

<DashboardLayout title="Check-in">

  <!-- Banner de inadimplência — informativo, não bloqueia -->
  {temInadimplencia && (
    <div class="mb-5 flex items-start gap-3 rounded-xl border border-yellow-500/30 bg-yellow-500/10 px-4 py-3">
      <svg class="mt-0.5 h-5 w-5 shrink-0 text-yellow-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
      </svg>
      <p class="text-sm text-yellow-300">
        Identificamos uma pendência em seu cadastro. Regularize na recepção quando puder!
      </p>
    </div>
  )}

  <!-- Cabeçalho -->
  <div class="mb-6">
    <p class="text-xs font-medium uppercase tracking-widest text-primary mb-1">{hoje}</p>
    <h1 class="text-2xl font-bold text-foreground">Check-in</h1>
    <p class="mt-1 text-sm text-muted-foreground">
      Bem-vindo(a), <span class="text-foreground font-medium">{profile.nome_completo?.split(' ')[0]}</span>!
    </p>
  </div>

  <!-- Lista de aulas -->
  {!aulas || aulas.length === 0 ? (

    <div class="flex flex-col items-center justify-center py-20 text-center">
      <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-full bg-zinc-800 border border-border">
        <svg class="h-8 w-8 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
      <p class="font-semibold text-foreground">Nenhuma aula hoje</p>
      <p class="mt-1 text-sm text-muted-foreground">Fale com seu professor ou acompanhe a agenda.</p>
    </div>

  ) : (

    <div class="space-y-4">
      {aulas.map((aula) => {
        const status      = getStatus(aula.data_aula, aula.horario_inicio, aula.horario_fim);
        const jaChekin    = checkinsFeitosSet.has(aula.id);
        const totalCheckins = checkinCountMap.get(aula.id) ?? 0;
        const cap         = aula.capacidade_max;
        const semVagas    = cap && cap > 0 && totalCheckins >= cap;
        const wod         = (aula.wods as any);

        const podeCheckin = status === 'aberto' && !jaChekin && !semVagas;

        // Cores por status
        const borderColor = jaChekin
          ? 'border-primary/40'
          : status === 'aberto'
          ? 'border-primary/20'
          : 'border-border';

        return (
          <div class={`relative overflow-hidden rounded-2xl border bg-card ${borderColor} transition-all`}>

            <!-- Linha decorativa de status -->
            <div class={`absolute left-0 top-0 h-full w-1 ${
              jaChekin        ? 'bg-primary' :
              status === 'aberto'    ? 'bg-primary/50' :
              status === 'encerrado' ? 'bg-zinc-600' :
              'bg-zinc-700'
            }`}></div>

            <div class="pl-5 pr-4 py-4">

              <!-- Horário + Status badge -->
              <div class="flex items-center justify-between mb-3">
                <div class="flex items-center gap-3">
                  <div class="text-center">
                    <div class="text-xl font-bold font-mono text-foreground leading-none">{fmt(aula.horario_inicio)}</div>
                    <div class="text-[10px] text-muted-foreground mt-0.5">até {fmt(aula.horario_fim)}</div>
                  </div>
                  <div class="h-8 w-px bg-border"></div>
                  <div>
                    <div class="text-xs text-muted-foreground uppercase tracking-wide">{aula.modalidade}</div>
                    <div class="font-bold text-foreground">{wod?.nome ?? 'WOD do dia'}</div>
                  </div>
                </div>

                <!-- Status badge -->
                {jaChekin ? (
                  <span class="flex items-center gap-1.5 rounded-full bg-primary/15 border border-primary/30 px-3 py-1 text-xs font-semibold text-primary">
                    <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Confirmado
                  </span>
                ) : status === 'aberto' ? (
                  <span class="rounded-full bg-primary/10 border border-primary/20 px-3 py-1 text-xs font-semibold text-primary animate-pulse">
                    Aberto para Check-in
                  </span>
                ) : status === 'aguardando' ? (
                  <span class="rounded-full bg-zinc-800 border border-border px-3 py-1 text-xs font-medium text-muted-foreground">
                    Aguardando
                  </span>
                ) : (
                  <span class="rounded-full bg-zinc-800/50 border border-zinc-700 px-3 py-1 text-xs font-medium text-zinc-500">
                    Encerrado
                  </span>
                )}
              </div>

              <!-- Score type + treino -->
              {(wod?.score_type || wod?.treino) && (
                <div class="mb-3 rounded-lg bg-zinc-900/60 border border-border px-3 py-2">
                  {wod?.score_type && (
                    <div class="text-xs text-primary font-semibold mb-1">{scoreLabel[wod.score_type] ?? wod.score_type}</div>
                  )}
                  {wod?.treino && (
                    <p class="text-xs text-muted-foreground line-clamp-2 whitespace-pre-line">{wod.treino}</p>
                  )}
                </div>
              )}

              <!-- Vagas -->
              {cap && cap > 0 && (
                <div class="mb-3 flex items-center gap-2">
                  <div class="flex-1 h-1.5 rounded-full bg-zinc-800 overflow-hidden">
                    <div
                      class={`h-full rounded-full transition-all ${totalCheckins >= cap ? 'bg-red-500' : 'bg-primary'}`}
                      style={`width: ${Math.min(100, (totalCheckins / cap) * 100).toFixed(0)}%`}
                    ></div>
                  </div>
                  <span class="text-xs text-muted-foreground shrink-0">
                    {semVagas ? 'Lotado' : `${cap - totalCheckins} vaga${cap - totalCheckins !== 1 ? 's' : ''}`}
                  </span>
                </div>
              )}

              <!-- Botão de Check-in -->
              {!jaChekin && (
                <button
                  class={`checkin-btn w-full rounded-xl py-3 text-sm font-bold transition-all active:scale-95 flex items-center justify-center gap-2 ${
                    podeCheckin
                      ? 'bg-primary text-black shadow-[0_0_20px_rgba(34,197,94,0.3)] hover:shadow-[0_0_30px_rgba(34,197,94,0.5)]'
                      : 'bg-zinc-800 text-muted-foreground cursor-not-allowed opacity-60'
                  }`}
                  data-aula-id={aula.id}
                  disabled={!podeCheckin}
                >
                  {semVagas ? (
                    <>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728L5.636 5.636" />
                      </svg>
                      Turma lotada
                    </>
                  ) : status === 'aguardando' ? (
                    <>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Check-in indisponível no momento
                    </>
                  ) : status === 'encerrado' ? (
                    <>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Check-in indisponível no momento
                    </>
                  ) : (
                    <>
                      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      Confirmar Presença
                    </>
                  )}
                </button>
              )}

              {jaChekin && (
                <div class="flex items-center justify-center gap-2 py-2 text-sm text-primary font-semibold">
                  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  Presença confirmada!
                </div>
              )}

            </div>
          </div>
        );
      })}
    </div>

  )}

  <!-- Toast -->
  <div id="toast" class="hidden fixed bottom-6 left-4 right-4 z-50 max-w-sm mx-auto rounded-xl border px-4 py-3 shadow-2xl text-sm font-semibold text-center transition-all duration-300"></div>

</DashboardLayout>

<script>
  const toast = document.getElementById('toast')!;

  function showToast(msg: string, ok: boolean) {
    toast.textContent = msg;
    toast.className = [
      'fixed bottom-6 left-4 right-4 z-50 max-w-sm mx-auto rounded-xl border px-4 py-3 shadow-2xl text-sm font-semibold text-center',
      ok
        ? 'bg-card border-primary/40 text-primary shadow-[0_0_20px_rgba(34,197,94,0.2)]'
        : 'bg-card border-red-500/40 text-red-400',
    ].join(' ');
    setTimeout(() => toast.classList.add('hidden'), 4000);
  }

  document.querySelectorAll<HTMLButtonElement>('.checkin-btn:not([disabled])').forEach(btn => {
    btn.addEventListener('click', async () => {
      const aulaId = btn.dataset.aulaId;
      if (!aulaId) return;

      btn.disabled = true;
      btn.innerHTML = `
        <svg class="h-4 w-4 animate-spin" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        Registrando…`;

      try {
        const res  = await fetch('/api/checkin', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ aula_id: aulaId }),
        });
        const data = await res.json() as { ok: boolean; motivo?: string };

        if (data.ok) {
          showToast('Presença confirmada! 💪', true);
          // Substitui o card do botão por mensagem de confirmação
          const card = btn.closest('[data-aula-id]') ?? btn.parentElement!;
          btn.outerHTML = `
            <div class="flex items-center justify-center gap-2 py-2 text-sm text-primary font-semibold">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Presença confirmada!
            </div>`;
        } else {
          showToast(data.motivo ?? 'Erro ao confirmar presença.', false);
          btn.disabled = false;
          btn.innerHTML = `
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Confirmar Presença`;
        }
      } catch {
        showToast('Erro de conexão. Tente novamente.', false);
        btn.disabled = false;
        btn.innerHTML = 'Confirmar Presença';
      }
    });
  });
</script>
