---
/**
 * /dashboard/faturas — Faturas do aluno (visão do próprio aluno).
 */
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Badge from '@/components/ui/Badge.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'aluno') return Astro.redirect('/dashboard');

const { data: aluno } = await supabase
  .from('alunos')
  .select('id, nome, email')
  .eq('academia_id', profile.academia_id!)
  .eq('email', user.email!)
  .maybeSingle();

const { data: pagamentos } = aluno
  ? await supabase
      .from('pagamentos')
      .select('id, valor, status, data_vencimento, data_pagamento, descricao, mes_referencia, link_pagamento, pix_qr_code_base64, pix_copia_cola, boleto_url, boleto_linha')
      .eq('aluno_id', aluno.id)
      .neq('status', 'cancelado')
      .order('data_vencimento', { ascending: false })
      .limit(24)
  : { data: [] };

const statusConfig: Record<string, { label: string; variant: 'success' | 'warning' | 'destructive' | 'muted' }> = {
  pago:      { label: 'Pago',      variant: 'success' },
  pendente:  { label: 'Pendente',  variant: 'warning' },
  vencido:   { label: 'Vencido',   variant: 'destructive' },
  cancelado: { label: 'Cancelado', variant: 'muted' },
};

const emAberto = pagamentos?.filter(p => p.status === 'pendente' || p.status === 'vencido')
  .reduce((acc, p) => acc + Number(p.valor), 0) ?? 0;
const totalPago = pagamentos?.filter(p => p.status === 'pago')
  .reduce((acc, p) => acc + Number(p.valor), 0) ?? 0;
---

<DashboardLayout title="Minhas Faturas">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Minhas Faturas</h1>
    <p class="mt-1 text-sm text-muted-foreground">Histórico de pagamentos e cobranças</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-2 gap-4 mb-6">
    <div class="rounded-xl border border-border bg-card p-4">
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Em aberto</p>
      <p class="mt-1 text-2xl font-bold text-destructive">
        {emAberto.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
      </p>
    </div>
    <div class="rounded-xl border border-border bg-card p-4">
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Total pago</p>
      <p class="mt-1 text-2xl font-bold text-primary">
        {totalPago.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
      </p>
    </div>
  </div>

  {!pagamentos || pagamentos.length === 0 ? (
    <div class="rounded-xl border border-border bg-card px-5 py-12 text-center text-sm text-muted-foreground">
      Nenhuma fatura encontrada.
    </div>
  ) : (
    <div class="space-y-4">
      {pagamentos.map((p: any) => {
        const cfg      = statusConfig[p.status] ?? { label: p.status, variant: 'muted' as const };
        const venceu   = new Date(p.data_vencimento + 'T12:00:00') < new Date() && p.status !== 'pago';
        const descricao = p.descricao ?? (p.mes_referencia
          ? `Mensalidade ${new Date(p.mes_referencia + 'T12:00:00').toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' })}`
          : 'Mensalidade');
        const temPagamento = p.status !== 'pago' && (p.link_pagamento || p.pix_qr_code_base64 || p.boleto_linha);
        return (
          <div class={`rounded-xl border bg-card overflow-hidden ${
            p.status === 'pago'  ? 'border-green-600/20' :
            venceu               ? 'border-red-600/30'   :
            'border-yellow-500/20'
          }`}>
            <!-- Cabeçalho -->
            <div class="flex items-center gap-3 px-4 py-3">
              <div class="flex-1 min-w-0">
                <p class="font-medium text-foreground text-sm truncate">{descricao}</p>
                <p class="text-xs text-muted-foreground mt-0.5">
                  {p.status === 'pago'
                    ? `Pago em ${new Date(p.data_pagamento + 'T12:00:00').toLocaleDateString('pt-BR')}`
                    : `Vence em ${new Date(p.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}`
                  }
                  {venceu && ' · em atraso'}
                </p>
              </div>
              <span class="font-bold text-foreground shrink-0">
                {Number(p.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
              </span>
              <Badge variant={cfg.variant}>{cfg.label}</Badge>
            </div>

            <!-- Opções de pagamento (só se não pago) -->
            {temPagamento && (
              <div class="border-t border-border/50 px-4 py-4 bg-black/10 space-y-3">

                {p.link_pagamento && (
                  <a href={p.link_pagamento} target="_blank"
                    class="flex items-center justify-center gap-2 w-full rounded-lg bg-primary py-3 text-sm font-bold text-white hover:bg-primary/90 transition-colors">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Pagar agora (PIX · Boleto · Cartão)
                  </a>
                )}

                <div class="grid sm:grid-cols-2 gap-3">
                  <!-- PIX -->
                  {p.pix_qr_code_base64 && (
                    <div class="rounded-lg border border-zinc-800 p-3 text-center space-y-2">
                      <p class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">PIX — instantâneo</p>
                      <img src={`data:image/png;base64,${p.pix_qr_code_base64}`}
                        alt="QR Code PIX" class="h-32 w-32 mx-auto rounded" />
                      {p.pix_copia_cola && (
                        <button id={`pix-${p.id}`}
                          onclick={`navigator.clipboard.writeText('${p.pix_copia_cola}').then(()=>{var b=document.getElementById('pix-${p.id}');b.textContent='Copiado!';setTimeout(()=>b.textContent='Copiar código PIX',2000)})`}
                          class="w-full py-2 rounded-lg border border-zinc-700 text-xs text-zinc-400 hover:text-primary hover:border-primary/40 transition-colors">
                          Copiar código PIX
                        </button>
                      )}
                    </div>
                  )}

                  <!-- Boleto -->
                  {p.boleto_linha && (
                    <div class="rounded-lg border border-zinc-800 p-3 space-y-2">
                      <p class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">Boleto bancário</p>
                      <p class="text-[10px] font-mono text-zinc-500 break-all leading-relaxed bg-zinc-950 rounded p-2">
                        {p.boleto_linha}
                      </p>
                      <button id={`bol-${p.id}`}
                        onclick={`navigator.clipboard.writeText('${p.boleto_linha}').then(()=>{var b=document.getElementById('bol-${p.id}');b.textContent='Copiado!';setTimeout(()=>b.textContent='Copiar código',2000)})`}
                        class="w-full py-2 rounded-lg border border-zinc-700 text-xs text-zinc-400 hover:text-primary hover:border-primary/40 transition-colors">
                        Copiar código de barras
                      </button>
                      {p.boleto_url && (
                        <a href={p.boleto_url} target="_blank"
                          class="block text-center text-xs text-primary hover:underline">
                          Ver boleto (PDF)
                        </a>
                      )}
                    </div>
                  )}
                </div>

                <p class="text-xs text-zinc-600 text-center">
                  Após o pagamento, a confirmação é automática em até 5 minutos.
                </p>
              </div>
            )}
          </div>
        );
      })}
    </div>
  )}
</DashboardLayout>
