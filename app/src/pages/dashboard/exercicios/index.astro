---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles').select('role, academia_id').eq('id', user.id).single();

if (!profile || !['dono', 'colaborador', 'saas_admin'].includes(profile.role))
  return Astro.redirect('/dashboard');

let sucesso = '';
let erro    = '';

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'criar_exercicio') {
    const nome           = (form.get('nome') as string)?.trim();
    const tipo_resultado = (form.get('tipo_resultado') as string) || 'reps';
    if (!nome) { erro = 'Informe o nome do exercício.'; }
    else {
      const { error } = await supabase.from('exercicios').insert({
        academia_id: profile.academia_id, nome, tipo_resultado,
      });
      if (error) erro = error.message.includes('unique') ? `Exercício "${nome}" já existe.` : error.message;
      else sucesso = `Exercício "${nome}" criado!`;
    }
  }

  if (action === 'editar_nome') {
    const id   = form.get('exercicio_id') as string;
    const nome = (form.get('nome') as string)?.trim();
    if (!nome) { erro = 'Informe o novo nome.'; }
    else {
      const { error } = await supabase.from('exercicios')
        .update({ nome })
        .eq('id', id)
        .eq('academia_id', profile.academia_id!);
      if (error) erro = error.message.includes('unique') ? `Já existe um exercício com esse nome.` : error.message;
      else sucesso = `Exercício renomeado para "${nome}".`;
    }
  }

  if (action === 'editar_tipo') {
    const id             = form.get('exercicio_id') as string;
    const tipo_resultado = form.get('tipo_resultado') as string;
    const { error } = await supabase.from('exercicios')
      .update({ tipo_resultado })
      .eq('id', id)
      .eq('academia_id', profile.academia_id!);
    if (error) erro = error.message;
    else sucesso = 'Tipo de resultado atualizado.';
  }

  if (action === 'excluir_exercicio') {
    const id = form.get('exercicio_id') as string;
    const { error } = await supabase.from('exercicios')
      .delete().eq('id', id).eq('academia_id', profile.academia_id!);
    if (error) erro = 'Não foi possível excluir. O exercício pode estar vinculado a WODs.';
    else sucesso = 'Exercício removido.';
  }
}

const { data: exercicios } = await supabase
  .from('exercicios')
  .select('id, nome, tipo_resultado')
  .eq('academia_id', profile.academia_id!)
  .order('nome');

const TIPOS = [
  { valor: 'peso',        label: 'Carga (kg)',       ex: 'ex: Squat 1RM, Deadlift' },
  { valor: 'tempo',       label: 'Tempo (mm:ss)',    ex: 'ex: Fran, Cindy' },
  { valor: 'reps',        label: 'Repetições',       ex: 'ex: Max Pull-ups, Burpees' },
  { valor: 'rounds_reps', label: 'Rounds + Reps',    ex: 'ex: AMRAP 20min' },
];

const TIPO_LABEL: Record<string, string> = {
  peso: 'Carga (kg)', tempo: 'Tempo', reps: 'Reps', rounds_reps: 'Rounds+Reps',
};
const TIPO_COR: Record<string, string> = {
  peso:        'bg-blue-500/10 text-blue-400 border-blue-500/20',
  tempo:       'bg-orange-500/10 text-orange-400 border-orange-500/20',
  reps:        'bg-green-500/10 text-green-400 border-green-500/20',
  rounds_reps: 'bg-purple-500/10 text-purple-400 border-purple-500/20',
};
---

<DashboardLayout title="Exercícios">
  <div class="mb-6 flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-foreground">Exercícios</h1>
      <p class="mt-1 text-sm text-muted-foreground">Biblioteca de exercícios da academia — configure o tipo de resultado para os rankings</p>
    </div>
    <button id="btn-novo-ex" type="button"
      class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors shrink-0">
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
      </svg>
      Novo Exercício
    </button>
  </div>

  {sucesso && <div class="mb-4 rounded-lg border border-green-600/30 bg-green-900/20 px-4 py-3 text-sm text-green-400">✓ {sucesso}</div>}
  {erro    && <div class="mb-4 rounded-lg border border-red-600/30 bg-red-900/20 px-4 py-3 text-sm text-red-400">{erro}</div>}

  <!-- Info sobre tipos -->
  <div class="mb-6 grid grid-cols-2 lg:grid-cols-4 gap-3">
    {TIPOS.map(t => (
      <div class:list={['rounded-lg border p-3', TIPO_COR[t.valor] ?? '']}>
        <p class="text-xs font-semibold mb-0.5">{t.label}</p>
        <p class="text-[10px] opacity-70">{t.ex}</p>
      </div>
    ))}
  </div>

  <!-- Lista de exercícios -->
  <div class="rounded-xl border border-border bg-card overflow-hidden">
    {(exercicios ?? []).length === 0 ? (
      <div class="p-12 text-center">
        <p class="text-sm text-muted-foreground">Nenhum exercício cadastrado.</p>
        <p class="text-xs text-zinc-600 mt-1">Os exercícios são criados aqui ou automaticamente ao adicionar ao WOD.</p>
      </div>
    ) : (
      <div class="divide-y divide-border/50">
        {(exercicios ?? []).map(ex => (
          <div class="flex items-center gap-3 px-5 py-3.5 hover:bg-muted/10 transition-colors group">
            <p class="flex-1 text-sm font-medium text-foreground truncate">{ex.nome}</p>

            <!-- Tipo: form inline para editar -->
            <form method="POST" class="flex items-center gap-2 shrink-0">
              <input type="hidden" name="action" value="editar_tipo" />
              <input type="hidden" name="exercicio_id" value={ex.id} />
              <select name="tipo_resultado"
                onchange="this.closest('form').submit()"
                class:list={['rounded-lg border px-2.5 py-1.5 text-xs font-medium bg-transparent focus:outline-none focus:ring-2 focus:ring-primary/50 cursor-pointer transition-colors', TIPO_COR[ex.tipo_resultado ?? 'reps'] ?? '']}>
                {TIPOS.map(t => (
                  <option value={t.valor} selected={ex.tipo_resultado === t.valor} class="bg-zinc-900 text-white">{t.label}</option>
                ))}
              </select>
            </form>

            <!-- Renomear -->
            <button type="button"
              data-action="renomear-ex"
              data-id={ex.id}
              data-nome={ex.nome}
              class="p-1.5 rounded-lg text-zinc-600 hover:text-zinc-300 hover:bg-muted/40 transition-colors opacity-0 group-hover:opacity-100">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
            </button>

            <!-- Excluir -->
            <form method="POST" class="shrink-0">
              <input type="hidden" name="action" value="excluir_exercicio" />
              <input type="hidden" name="exercicio_id" value={ex.id} />
              <button type="submit"
                onclick={`return confirm('Excluir "${ex.nome}"?\\nExercícios usados em WODs não podem ser excluídos.')`}
                class="p-1.5 rounded-lg text-zinc-600 hover:text-red-400 hover:bg-red-900/10 transition-colors opacity-0 group-hover:opacity-100">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
              </button>
            </form>
          </div>
        ))}
      </div>
    )}
  </div>

  <!-- Modal: Novo Exercício -->
  <div id="modal-novo-ex" class="hidden fixed inset-0 z-50 bg-black/70 backdrop-blur-sm">
    <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm rounded-2xl border border-zinc-700 bg-zinc-900 shadow-2xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-zinc-800">
        <h2 class="text-sm font-bold text-foreground">Novo Exercício</h2>
        <button id="btn-fechar-ex" type="button"
          class="text-zinc-500 hover:text-zinc-300 transition-colors p-1 rounded-lg hover:bg-zinc-800">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form method="POST" class="px-5 py-5 space-y-4">
        <input type="hidden" name="action" value="criar_exercicio" />
        <div>
          <label class="block text-xs text-muted-foreground mb-1">Nome</label>
          <input name="nome" type="text" required placeholder="ex: Back Squat, Fran, Cindy..."
            class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50" />
        </div>
        <div>
          <label class="block text-xs text-muted-foreground mb-2">Tipo de resultado</label>
          <div class="space-y-2">
            {TIPOS.map((t, i) => (
              <label class="flex items-start gap-3 cursor-pointer rounded-lg border border-border p-3 hover:border-primary/40 has-[:checked]:border-primary has-[:checked]:bg-primary/5 transition-colors">
                <input type="radio" name="tipo_resultado" value={t.valor} checked={i === 0} class="mt-0.5 accent-primary" />
                <div>
                  <p class="text-sm font-medium text-foreground">{t.label}</p>
                  <p class="text-xs text-muted-foreground">{t.ex}</p>
                </div>
              </label>
            ))}
          </div>
        </div>
        <button type="submit"
          class="w-full rounded-lg bg-primary py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
          Criar Exercício
        </button>
      </form>
    </div>
  </div>

  <!-- Modal: Renomear Exercício -->
  <div id="modal-renomear-ex" class="hidden fixed inset-0 z-50 bg-black/70 backdrop-blur-sm">
    <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm rounded-2xl border border-zinc-700 bg-zinc-900 shadow-2xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-zinc-800">
        <h2 class="text-sm font-bold text-foreground">Renomear Exercício</h2>
        <button id="btn-fechar-renomear" type="button"
          class="text-zinc-500 hover:text-zinc-300 transition-colors p-1 rounded-lg hover:bg-zinc-800">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form method="POST" class="px-5 py-5 space-y-4">
        <input type="hidden" name="action" value="editar_nome" />
        <input type="hidden" name="exercicio_id" id="renomear-ex-id" />
        <div>
          <label class="block text-xs text-muted-foreground mb-1.5">Nome do exercício</label>
          <input id="renomear-ex-nome" name="nome" type="text" required
            class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50" />
        </div>
        <div class="flex gap-3">
          <button type="button" id="btn-cancelar-renomear"
            class="flex-1 rounded-lg border border-border py-2.5 text-sm font-medium text-muted-foreground hover:bg-muted transition-colors">
            Cancelar
          </button>
          <button type="submit"
            class="flex-1 rounded-lg bg-primary py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
            Salvar
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Modal Novo Exercício
    const modal = document.getElementById('modal-novo-ex')!;
    document.getElementById('btn-novo-ex')?.addEventListener('click', () => {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    });
    document.getElementById('btn-fechar-ex')?.addEventListener('click', () => {
      modal.classList.add('hidden');
      document.body.style.overflow = '';
    });
    modal.addEventListener('click', e => {
      if (e.target === modal) { modal.classList.add('hidden'); document.body.style.overflow = ''; }
    });

    // Modal Renomear
    const modalRen  = document.getElementById('modal-renomear-ex')!;
    const inputId   = document.getElementById('renomear-ex-id') as HTMLInputElement;
    const inputNome = document.getElementById('renomear-ex-nome') as HTMLInputElement;

    function abrirRenomear(id: string, nome: string) {
      inputId.value   = id;
      inputNome.value = nome;
      modalRen.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      setTimeout(() => { inputNome.select(); }, 50);
    }
    function fecharRenomear() {
      modalRen.classList.add('hidden');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('[data-action="renomear-ex"]').forEach(btn => {
      btn.addEventListener('click', () => abrirRenomear(btn.dataset.id!, btn.dataset.nome!));
    });
    document.getElementById('btn-fechar-renomear')?.addEventListener('click', fecharRenomear);
    document.getElementById('btn-cancelar-renomear')?.addEventListener('click', fecharRenomear);
    modalRen.addEventListener('click', e => {
      if (e.target === modalRen) fecharRenomear();
    });
  </script>
</DashboardLayout>
