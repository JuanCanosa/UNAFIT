---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase   = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || !['dono', 'colaborador'].includes(profile.role))
  return Astro.redirect('/dashboard');

const adminClient = createSupabaseAdminClient();

// POST: toggle avaliação
if (Astro.request.method === 'POST') {
  const form    = await Astro.request.formData();
  const wodId   = form.get('wod_id') as string;
  const aberto  = form.get('aberto') === '1';
  await adminClient.from('wods')
    .update({ aberto_para_avaliacao: aberto })
    .eq('id', wodId)
    .eq('academia_id', profile.academia_id);
  return Astro.redirect('/dashboard/coach-control');
}

const url   = new URL(Astro.request.url);
const view  = url.searchParams.get('view') || 'abertos';

// Carrega WODs
const query = adminClient
  .from('wods')
  .select('id, nome, score_type, data_aplicacao, aberto_para_avaliacao')
  .eq('academia_id', profile.academia_id)
  .order('data_aplicacao', { ascending: false })
  .limit(60);

const { data: wodsRaw } = await query;

// Contagem de resultados por WOD
const wodIds = (wodsRaw ?? []).map((w: any) => w.id);
const { data: contagemRaw } = wodIds.length
  ? await adminClient.from('wod_resultados')
      .select('wod_id')
      .in('wod_id', wodIds)
  : { data: [] };

const contagem = new Map<string, number>();
for (const r of (contagemRaw ?? [])) {
  contagem.set(r.wod_id, (contagem.get(r.wod_id) ?? 0) + 1);
}

type Wod = { id: string; nome: string; score_type: string; data_aplicacao: string; aberto_para_avaliacao: boolean };
const wods = (wodsRaw ?? []) as Wod[];
const abertos  = wods.filter(w => w.aberto_para_avaliacao);
const fechados = wods.filter(w => !w.aberto_para_avaliacao);
const lista    = view === 'abertos' ? abertos : fechados;

function scoreLabel(s: string) {
  if (s === 'tempo') return 'Para Tempo';
  if (s === 'carga') return 'Carga Máx';
  return 'Max Reps';
}
function formatDate(d: string) {
  if (!d) return '';
  const [y, m, dia] = d.split('-');
  return `${dia}/${m}/${y}`;
}
---
<DashboardLayout title="Coach Control">
  <div class="max-w-3xl mx-auto space-y-5">

    <div>
      <h1 class="text-2xl font-bold text-foreground">Coach Control</h1>
      <p class="text-sm text-muted-foreground mt-0.5">
        Abra WODs para que os alunos registrem seus resultados.
      </p>
    </div>

    <!-- Tabs -->
    <div class="flex gap-1 rounded-lg bg-card border border-border p-1 w-fit">
      {(['abertos','historico'] as const).map(t => (
        <a href={`?view=${t}`}
          class:list={[
            'rounded-md px-4 py-1.5 text-sm font-medium transition-colors',
            view === t ? 'bg-primary text-primary-foreground' : 'text-muted-foreground hover:text-foreground'
          ]}>
          {t === 'abertos' ? `Abertos (${abertos.length})` : `Histórico (${fechados.length})`}
        </a>
      ))}
    </div>

    {lista.length === 0 && (
      <div class="rounded-xl border border-border bg-card p-10 text-center text-muted-foreground text-sm">
        {view === 'abertos'
          ? 'Nenhum WOD aberto para avaliação. Ative um WOD abaixo em "Histórico".'
          : 'Nenhum WOD encontrado.'}
      </div>
    )}

    <div class="space-y-3">
      {lista.map(w => {
        const n = contagem.get(w.id) ?? 0;
        return (
          <div class="rounded-xl border border-border bg-card p-4">
            <div class="flex items-start gap-3">
              <!-- Info -->
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <a href={`/dashboard/coach-control/wod/${w.id}`}
                    class="font-semibold text-foreground hover:text-primary transition-colors">
                    {w.nome}
                  </a>
                  <span class:list={[
                    'px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide',
                    w.score_type === 'tempo' ? 'bg-blue-500/15 text-blue-400' :
                    w.score_type === 'carga' ? 'bg-orange-500/15 text-orange-400' :
                                               'bg-purple-500/15 text-purple-400'
                  ]}>
                    {scoreLabel(w.score_type)}
                  </span>
                </div>
                <div class="flex items-center gap-3 mt-1 text-xs text-muted-foreground">
                  <span>{formatDate(w.data_aplicacao)}</span>
                  {n > 0 && (
                    <a href={`/dashboard/coach-control/wod/${w.id}`}
                      class="text-primary hover:underline font-medium">
                      {n} resultado{n !== 1 ? 's' : ''}
                    </a>
                  )}
                </div>
              </div>

              <!-- Toggle -->
              <form method="POST" class="flex items-center gap-2 shrink-0">
                <input type="hidden" name="wod_id" value={w.id} />
                <input type="hidden" name="aberto" value={w.aberto_para_avaliacao ? '0' : '1'} />
                <button type="submit"
                  class:list={[
                    'relative inline-flex h-6 w-11 shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors',
                    w.aberto_para_avaliacao ? 'bg-primary' : 'bg-muted'
                  ]}
                  title={w.aberto_para_avaliacao ? 'Fechar avaliação' : 'Abrir para avaliação'}
                >
                  <span class:list={[
                    'pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow transition duration-200',
                    w.aberto_para_avaliacao ? 'translate-x-5' : 'translate-x-0'
                  ]} />
                </button>
                <span class="text-xs text-muted-foreground w-16">
                  {w.aberto_para_avaliacao ? 'Aberto' : 'Fechado'}
                </span>
              </form>
            </div>
          </div>
        );
      })}
    </div>

  </div>
</DashboardLayout>
