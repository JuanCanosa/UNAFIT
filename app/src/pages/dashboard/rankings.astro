---
/**
 * /dashboard/rankings
 * Ranking geral da academia — visível para dono, professor e saas_admin.
 * Exibe top atletas por número de check-ins.
 */
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role === 'aluno') return Astro.redirect('/dashboard');

// Ranking de presença: checkins agrupados por aluno
const { data: checkins } = await supabase
  .from('checkins')
  .select('aluno_id, profiles ( nome_completo )')
  .eq('academia_id', profile.academia_id!);

// Agrupa por aluno no servidor
const contagem: Record<string, { nome: string; total: number }> = {};
for (const c of checkins ?? []) {
  const id   = c.aluno_id;
  const nome = (c.profiles as any)?.nome_completo ?? '?';
  if (!contagem[id]) contagem[id] = { nome, total: 0 };
  contagem[id]!.total++;
}
const ranking = Object.values(contagem)
  .sort((a, b) => b.total - a.total)
  .slice(0, 20);

// Últimos resultados do mês
const mesISO = new Date().toISOString().slice(0, 7) + '-01';

const { data: resultadosRecentes } = await supabase
  .from('ranking_geral')
  .select('resultado_id, tempo, rx_scaled, registrado_em, aluno_nome, wod_nome, data_aula')
  .eq('academia_id', profile.academia_id!)
  .gte('registrado_em', mesISO + 'T00:00:00')
  .order('registrado_em', { ascending: false })
  .limit(20);

const medalhas = ['🥇', '🥈', '🥉'];
---

<DashboardLayout title="Rankings">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Rankings</h1>
    <p class="mt-1 text-sm text-muted-foreground">Desempenho e presença dos atletas</p>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">

    <!-- Ranking de Presença -->
    <Card>
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
        🏋️ Top Presença
      </h2>

      {ranking.length === 0 ? (
        <p class="py-6 text-center text-sm text-muted-foreground">Sem dados de check-in ainda.</p>
      ) : (
        <div class="space-y-2">
          {ranking.map((r, i) => (
            <div class:list={[
              'flex items-center gap-3 rounded-lg px-3 py-2.5 transition-colors',
              i === 0 ? 'bg-primary/10 border border-primary/20' : 'hover:bg-muted/30',
            ]}>
              <span class="text-lg w-7 text-center">
                {i < 3 ? medalhas[i] : <span class="text-sm font-bold text-muted-foreground">{i + 1}</span>}
              </span>
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">
                {r.nome.charAt(0).toUpperCase()}
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground truncate">{r.nome}</p>
              </div>
              <div class="text-right">
                <p class="text-sm font-bold text-primary">{r.total}</p>
                <p class="text-xs text-muted-foreground">check-ins</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </Card>

    <!-- Últimos Resultados -->
    <Card>
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
        ⏱ Resultados Recentes
      </h2>

      {!resultadosRecentes || resultadosRecentes.length === 0 ? (
        <p class="py-6 text-center text-sm text-muted-foreground">Nenhum resultado registrado este mês.</p>
      ) : (
        <div class="space-y-3">
          {resultadosRecentes.map((r) => {
            const data = r.data_aula
              ? new Date(r.data_aula + 'T12:00:00').toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' })
              : '—';

            let score = '—';
            if (r.tempo) {
              const parts = r.tempo.toString().split(':');
              score = parts.length >= 2 ? `${parts[parts.length-2]}:${parts[parts.length-1].split('.')[0]}` : r.tempo.toString();
            }

            return (
              <div class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/30 transition-colors">
                <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">
                  {(r.aluno_nome as string).charAt(0).toUpperCase()}
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-foreground truncate">{r.aluno_nome}</p>
                  <p class="text-xs text-muted-foreground truncate">{r.wod_nome ?? 'WOD'} · {data}</p>
                </div>
                <div class="text-right shrink-0">
                  <p class="text-sm font-bold text-primary">{score}</p>
                  <Badge variant={r.rx_scaled ? 'primary' : 'muted'} class="text-[10px]">
                    {r.rx_scaled ? 'RX' : 'Scaled'}
                  </Badge>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </Card>

  </div>

</DashboardLayout>
