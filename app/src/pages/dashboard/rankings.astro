---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles').select('role, academia_id').eq('id', user.id).single();
if (!profile) return Astro.redirect('/login');

const isAluno = profile.role === 'aluno';
const adminClient = createSupabaseAdminClient();

const urlParams = new URL(Astro.request.url).searchParams;
const tabAtiva  = urlParams.get('tab') ?? (isAluno ? 'wod' : 'presenca');

// ── PRESENÇA ─────────────────────────────────────────────────────────────────
const hojeISO_BR = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Sao_Paulo' }).format(new Date());
const inicioMes  = hojeISO_BR.slice(0, 7) + '-01';
const mesFmt = new Date(inicioMes + 'T12:00:00Z').toLocaleDateString('pt-BR', { month: 'long', year: 'numeric' });
const periodoSelecionado = urlParams.get('periodo') === 'semana' ? 'semana' : 'mes';
const modalidadeSelecionada = urlParams.get('mod') ?? '';

const hojeDate = new Date(hojeISO_BR + 'T12:00:00Z');
const diaSemanaAtual = hojeDate.getUTCDay();
const diasDesdeSegunda = diaSemanaAtual === 0 ? 6 : diaSemanaAtual - 1;
const segundaDate = new Date(hojeDate);
segundaDate.setUTCDate(hojeDate.getUTCDate() - diasDesdeSegunda);
const inicioSemana = segundaDate.toISOString().slice(0, 10);

const dataInicioPeriodo = periodoSelecionado === 'semana' ? inicioSemana : inicioMes;
const labelPeriodo      = periodoSelecionado === 'semana' ? 'Esta Semana' : 'Este Mês';

function hrefPresenca(over: { periodo?: string; mod?: string } = {}): string {
  const params = new URLSearchParams();
  params.set('tab', 'presenca');
  const mod    = over.mod     !== undefined ? over.mod    : modalidadeSelecionada;
  const periodo = over.periodo !== undefined ? over.periodo : periodoSelecionado;
  if (mod) params.set('mod', mod);
  if (periodo === 'semana') params.set('periodo', 'semana');
  return `/dashboard/rankings?${params.toString()}`;
}

// ── WOD DO DIA ────────────────────────────────────────────────────────────────
const wodDataFiltro = urlParams.get('data') ?? hojeISO_BR;
const catWodFiltro  = urlParams.get('catwod') ?? '';

function hrefWod(over: { data?: string; catwod?: string } = {}): string {
  const params = new URLSearchParams();
  params.set('tab', 'wod');
  const data = over.data   !== undefined ? over.data   : wodDataFiltro;
  const cat  = over.catwod !== undefined ? over.catwod : catWodFiltro;
  params.set('data', data);
  if (cat) params.set('catwod', cat);
  return `/dashboard/rankings?${params.toString()}`;
}

const catLabels: Record<string, string> = {
  rx: 'RX', intermediario: 'Intermediário', scaled: 'Scaled', iniciante: 'Iniciante',
};

const scoreTypeLabel: Record<string, string> = {
  tempo: 'Para Tempo', reps: 'Max Reps', carga: 'Carga Máx',
  rounds_reps: 'Rounds + Reps', pass_fail: 'Pass/Fail',
};

// ── DATA FETCHING ─────────────────────────────────────────────────────────────
const [
  { data: aulasDoPeriodo },
  { data: checkinsDoPeriodo },
  { data: modalidadesAcademia },
  { data: wodsDodia },
] = await Promise.all([
  !isAluno
    ? supabase.from('aulas_agenda')
        .select('id, data_aula, horario_inicio, modalidade, capacidade_max, wods(nome)')
        .eq('academia_id', profile.academia_id!)
        .gte('data_aula', dataInicioPeriodo)
        .lte('data_aula', hojeISO_BR)
        .order('data_aula', { ascending: false })
    : Promise.resolve({ data: [] }),

  !isAluno
    ? supabase.from('checkins')
        .select('aula_id, aluno_id, profiles(nome_completo)')
        .eq('academia_id', profile.academia_id!)
        .gte('feito_em', `${dataInicioPeriodo}T00:00:00`)
    : Promise.resolve({ data: [] }),

  !isAluno
    ? supabase.from('modalidades')
        .select('id, nome, cor')
        .eq('academia_id', profile.academia_id!)
        .eq('ativo', true)
        .order('ordem')
    : Promise.resolve({ data: [] }),

  adminClient.from('wods')
    .select('id, nome, score_type, time_cap_min')
    .eq('academia_id', profile.academia_id!)
    .eq('data_aplicacao', wodDataFiltro)
    .eq('aberto_para_avaliacao', true)
    .order('criado_em'),
]);

// Busca resultados para os WODs do dia
const wodIds = (wodsDodia ?? []).map((w: any) => w.id as string);
const { data: resultadosRaw } = wodIds.length > 0
  ? await adminClient.from('wod_resultados')
      .select('id, wod_id, aluno_id, categoria, deu_cap, tempo_segundos, repeticoes, carga_kg, pse, profiles(nome_completo)')
      .in('wod_id', wodIds)
      .eq('academia_id', profile.academia_id!)
  : { data: [] as any[] };

type WodResultadoRow = {
  id: string; wod_id: string; aluno_id: string; categoria: string;
  deu_cap: boolean; tempo_segundos: number | null; repeticoes: number | null;
  carga_kg: number | null; pse: number | null;
  profiles: { nome_completo: string } | null;
};

// Agrupa resultados por wod_id
const resultadosPorWod = new Map<string, WodResultadoRow[]>();
for (const r of (resultadosRaw ?? []) as WodResultadoRow[]) {
  if (!resultadosPorWod.has(r.wod_id)) resultadosPorWod.set(r.wod_id, []);
  resultadosPorWod.get(r.wod_id)!.push(r);
}

function sortarResultados(resultados: WodResultadoRow[], scoreType: string): WodResultadoRow[] {
  return [...resultados].sort((a, b) => {
    if (scoreType === 'tempo') {
      if (!a.deu_cap && b.deu_cap) return -1;
      if (a.deu_cap && !b.deu_cap) return 1;
      if (!a.deu_cap && !b.deu_cap) return (a.tempo_segundos ?? 999999) - (b.tempo_segundos ?? 999999);
      return (b.repeticoes ?? 0) - (a.repeticoes ?? 0);
    }
    if (scoreType === 'carga') return (Number(b.carga_kg) || 0) - (Number(a.carga_kg) || 0);
    return (b.repeticoes ?? 0) - (a.repeticoes ?? 0);
  });
}

function fmtWodScore(r: WodResultadoRow, scoreType: string): string {
  if (scoreType === 'tempo') {
    if (r.deu_cap) return `CAP+${r.repeticoes ?? 0}`;
    if (r.tempo_segundos != null) {
      const m = Math.floor(r.tempo_segundos / 60);
      const s = r.tempo_segundos % 60;
      return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
    }
    return '—';
  }
  if (scoreType === 'carga') return r.carga_kg != null ? `${r.carga_kg} kg` : '—';
  return r.repeticoes != null ? `${r.repeticoes} reps` : '—';
}

function fmtDataWod(iso: string): string {
  if (iso === hojeISO_BR) return 'Hoje';
  const d = new Date(iso + 'T12:00:00Z');
  return d.toLocaleDateString('pt-BR', { weekday: 'long', day: 'numeric', month: 'long', timeZone: 'UTC' });
}

// ── PROCESSAMENTO PRESENÇA ────────────────────────────────────────────────────
const aulaIdParaModalidade: Record<string, string> = {};
for (const a of (aulasDoPeriodo ?? []) as any[]) {
  if (a.id) aulaIdParaModalidade[a.id] = a.modalidade ?? '';
}

const aulasFiltradas = modalidadeSelecionada
  ? ((aulasDoPeriodo ?? []) as any[]).filter(a => a.modalidade === modalidadeSelecionada)
  : (aulasDoPeriodo ?? []) as any[];
const checkinsFiltrados = modalidadeSelecionada
  ? ((checkinsDoPeriodo ?? []) as any[]).filter(c => aulaIdParaModalidade[c.aula_id ?? ''] === modalidadeSelecionada)
  : (checkinsDoPeriodo ?? []) as any[];

const presencasPorAula: Record<string, number> = {};
const rankingPresenca: Record<string, { nome: string; total: number }> = {};
for (const c of checkinsFiltrados) {
  if (c.aula_id) presencasPorAula[c.aula_id] = (presencasPorAula[c.aula_id] ?? 0) + 1;
  const nome = (c.profiles as any)?.nome_completo ?? '?';
  if (!rankingPresenca[c.aluno_id]) rankingPresenca[c.aluno_id] = { nome, total: 0 };
  rankingPresenca[c.aluno_id]!.total++;
}
const topPresenca = Object.entries(rankingPresenca)
  .map(([id, v]) => ({ id, ...v }))
  .sort((a, b) => b.total - a.total)
  .slice(0, 20);

const totalAulas     = aulasFiltradas.length;
const totalPresencas = checkinsFiltrados.length;
const alunosUnicos   = Object.keys(rankingPresenca).length;
const mediaPresenca  = totalAulas > 0 ? (totalPresencas / totalAulas).toFixed(1) : '—';

const medalhas = ['🥇', '🥈', '🥉'];
---

<DashboardLayout title="Rankings">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Rankings</h1>
    <p class="mt-1 text-sm text-muted-foreground capitalize">Desempenho da academia · {mesFmt}</p>
  </div>

  <!-- Tabs -->
  <div class="flex gap-1 mb-6 border-b border-border">
    {!isAluno && (
      <a href="/dashboard/rankings?tab=presenca"
        class:list={['px-4 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px',
          tabAtiva === 'presenca' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground']}>
        Presença
      </a>
    )}
    <a href={hrefWod({ catwod: catWodFiltro })}
      class:list={['px-4 py-2.5 text-sm font-medium transition-colors border-b-2 -mb-px',
        tabAtiva === 'wod' ? 'border-primary text-primary' : 'border-transparent text-muted-foreground hover:text-foreground']}>
      WOD do Dia
    </a>
  </div>

  <!-- ── TAB PRESENÇA ─────────────────────────────────────────────────────── -->
  {tabAtiva === 'presenca' && !isAluno && (
    <div>
      <div class="mb-5 flex flex-wrap items-center gap-x-6 gap-y-3">
        <div class="flex flex-wrap items-center gap-3">
          <label class="text-sm text-muted-foreground shrink-0">Período:</label>
          <div class="flex flex-wrap gap-2">
            <a href={hrefPresenca({ periodo: 'mes' })}
              class:list={['rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors',
                periodoSelecionado === 'mes'
                  ? 'border-primary bg-primary/10 text-primary'
                  : 'border-border text-muted-foreground hover:text-foreground hover:border-primary/40']}>
              Mês
            </a>
            <a href={hrefPresenca({ periodo: 'semana' })}
              class:list={['rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors',
                periodoSelecionado === 'semana'
                  ? 'border-primary bg-primary/10 text-primary'
                  : 'border-border text-muted-foreground hover:text-foreground hover:border-primary/40']}>
              Semana
            </a>
          </div>
        </div>

        {(modalidadesAcademia ?? []).length > 0 && (
          <div class="flex flex-wrap items-center gap-3">
            <label class="text-sm text-muted-foreground shrink-0">Modalidade:</label>
            <div class="flex flex-wrap gap-2">
              <a href={hrefPresenca({ mod: '' })}
                class:list={['rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors',
                  !modalidadeSelecionada
                    ? 'border-primary bg-primary/10 text-primary'
                    : 'border-border text-muted-foreground hover:text-foreground hover:border-primary/40']}>
                Todas
              </a>
              {(modalidadesAcademia ?? []).map((m: any) => (
                <a href={hrefPresenca({ mod: m.nome })}
                  class:list={['rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors',
                    modalidadeSelecionada === m.nome
                      ? 'border-primary bg-primary/10 text-primary'
                      : 'border-border text-muted-foreground hover:text-foreground hover:border-primary/40']}>
                  {m.nome}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Aulas — {labelPeriodo}</p>
          <p class="mt-1.5 text-3xl font-bold text-foreground">{totalAulas}</p>
        </div>
        <div class="rounded-xl border border-primary/20 bg-primary/5 p-4">
          <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Presenças</p>
          <p class="mt-1.5 text-3xl font-bold text-primary">{totalPresencas}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Média / Aula</p>
          <p class="mt-1.5 text-3xl font-bold text-foreground">{mediaPresenca}</p>
        </div>
        <div class="rounded-xl border border-border bg-card p-4">
          <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Alunos Ativos</p>
          <p class="mt-1.5 text-3xl font-bold text-foreground">{alunosUnicos}</p>
        </div>
      </div>

      <div class="grid gap-6 lg:grid-cols-2">
        <!-- Top Presença -->
        <div class="rounded-xl border border-border bg-card p-5">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
            Top Presença — {labelPeriodo}{modalidadeSelecionada && <span class="normal-case text-foreground/70"> · {modalidadeSelecionada}</span>}
          </h2>
          {topPresenca.length === 0 ? (
            <p class="py-8 text-center text-sm text-muted-foreground">
              {modalidadeSelecionada
                ? `Nenhum check-in de ${modalidadeSelecionada} registrado n${periodoSelecionado === 'semana' ? 'esta semana' : 'este mês'}.`
                : `Nenhum check-in registrado n${periodoSelecionado === 'semana' ? 'esta semana' : 'este mês'}.`}
            </p>
          ) : (
            <div class="space-y-1.5">
              {topPresenca.map((r, i) => (
                <div class:list={['flex items-center gap-3 rounded-lg px-3 py-2.5',
                  i === 0 ? 'bg-primary/10 border border-primary/20' : 'hover:bg-muted/30']}>
                  <span class="w-7 text-center">
                    {i < 3
                      ? <span class="text-lg">{medalhas[i]}</span>
                      : <span class="text-sm font-bold text-muted-foreground">{i + 1}</span>}
                  </span>
                  <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">
                    {r.nome.charAt(0).toUpperCase()}
                  </div>
                  <p class="flex-1 min-w-0 text-sm font-medium text-foreground truncate">{r.nome}</p>
                  <div class="text-right shrink-0">
                    <p class="text-sm font-bold text-primary">{r.total}</p>
                    <p class="text-[10px] text-muted-foreground">check-in{r.total !== 1 ? 's' : ''}</p>
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>

        <!-- Histórico de Aulas -->
        <div class="rounded-xl border border-border bg-card p-5">
          <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
            Histórico de Aulas — {labelPeriodo}{modalidadeSelecionada && <span class="normal-case text-foreground/70"> · {modalidadeSelecionada}</span>}
          </h2>
          {aulasFiltradas.length === 0 ? (
            <p class="py-8 text-center text-sm text-muted-foreground">
              {modalidadeSelecionada
                ? `Nenhuma aula de ${modalidadeSelecionada} registrada n${periodoSelecionado === 'semana' ? 'esta semana' : 'este mês'}.`
                : `Nenhuma aula registrada n${periodoSelecionado === 'semana' ? 'esta semana' : 'este mês'}.`}
            </p>
          ) : (
            <div class="space-y-1.5 max-h-[520px] overflow-y-auto pr-1">
              {aulasFiltradas.map((a: any) => {
                const presencas = presencasPorAula[a.id] ?? 0;
                const cap = Number(a.capacidade_max) || 0;
                const pct = cap > 0 ? Math.min(100, Math.round((presencas / cap) * 100)) : null;
                const nomeAula = (a.wods as any)?.nome ?? a.modalidade ?? 'Aula';
                const dataObj = new Date(a.data_aula + 'T12:00:00Z');
                return (
                  <div class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/30">
                    <div class="flex h-10 w-10 shrink-0 flex-col items-center justify-center rounded-lg bg-muted text-center">
                      <span class="text-sm font-bold text-foreground leading-none">{dataObj.getUTCDate()}</span>
                      <span class="text-[9px] text-muted-foreground uppercase">{dataObj.toLocaleDateString('pt-BR', { month: 'short', timeZone: 'UTC' }).replace('.', '')}</span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm font-medium text-foreground truncate">{nomeAula}</p>
                      <p class="text-xs text-muted-foreground">{a.horario_inicio?.slice(0, 5)}{cap > 0 ? ` · cap. ${cap}` : ''}</p>
                      {pct !== null && (
                        <div class="mt-1.5 h-1 w-full rounded-full bg-zinc-800 overflow-hidden">
                          <div class:list={['h-full rounded-full', pct >= 90 ? 'bg-red-500' : pct >= 60 ? 'bg-yellow-500' : 'bg-primary']}
                            style={`width: ${pct}%`} />
                        </div>
                      )}
                    </div>
                    <div class="text-right shrink-0 min-w-[48px]">
                      <p class="text-sm font-bold text-foreground">{presencas}</p>
                      <p class="text-[10px] text-muted-foreground">{cap > 0 ? `de ${cap}` : `presente${presencas !== 1 ? 's' : ''}`}</p>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  <!-- ── TAB WOD DO DIA ──────────────────────────────────────────────────── -->
  {tabAtiva === 'wod' && (
    <div>
      <!-- Filtros: data + categoria -->
      <div class="mb-5 flex flex-wrap items-center gap-x-6 gap-y-3">
        <!-- Seletor de data -->
        <div class="flex items-center gap-3">
          <label class="text-sm text-muted-foreground shrink-0">Data:</label>
          <div class="flex items-center gap-2">
            <input
              id="wod-data-input"
              type="date"
              value={wodDataFiltro}
              max={hojeISO_BR}
              class="rounded-lg border border-border bg-background px-3 py-1.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
            />
            <span class="text-sm text-muted-foreground capitalize hidden sm:inline">
              {fmtDataWod(wodDataFiltro)}
            </span>
          </div>
        </div>

        <!-- Filtro por categoria -->
        <div class="flex flex-wrap items-center gap-3">
          <label class="text-sm text-muted-foreground shrink-0">Categoria:</label>
          <div class="flex flex-wrap gap-2">
            {(['', 'rx', 'intermediario', 'scaled', 'iniciante'] as const).map(cat => (
              <a href={hrefWod({ catwod: cat })}
                class:list={['rounded-lg border px-3 py-1.5 text-xs font-medium transition-colors',
                  catWodFiltro === cat
                    ? 'border-primary bg-primary/10 text-primary'
                    : 'border-border text-muted-foreground hover:text-foreground hover:border-primary/40']}>
                {cat === '' ? 'Geral' : catLabels[cat]}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Leaderboard por WOD -->
      {(wodsDodia ?? []).length === 0 ? (
        <div class="rounded-xl border border-border bg-card p-12 text-center">
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-primary/10">
            <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <p class="text-sm font-medium text-foreground mb-1">Nenhum WOD aberto nesta data</p>
          <p class="text-xs text-muted-foreground">
            {wodDataFiltro === hojeISO_BR
              ? 'O professor ainda não abriu nenhum WOD para avaliação hoje.'
              : 'Nenhum WOD com avaliação aberta encontrado para esta data.'}
          </p>
        </div>
      ) : (
        <div class="space-y-6">
          {(wodsDodia ?? []).map((wod: any) => {
            const todos = resultadosPorWod.get(wod.id) ?? [];
            const filtrados: WodResultadoRow[] = catWodFiltro
              ? todos.filter(r => r.categoria === catWodFiltro)
              : todos;
            const sorted = sortarResultados(filtrados, wod.score_type);

            return (
              <div class="rounded-xl border border-border bg-card overflow-hidden">
                <!-- Header do WOD -->
                <div class="px-5 py-4 border-b border-border flex items-center justify-between gap-3">
                  <div>
                    <h2 class="font-semibold text-foreground">{wod.nome}</h2>
                    <p class="text-xs text-muted-foreground mt-0.5">
                      {scoreTypeLabel[wod.score_type] ?? wod.score_type}
                      {wod.score_type === 'tempo' ? ' · menor é melhor' : ' · maior é melhor'}
                      {' · '}{sorted.length} resultado{sorted.length !== 1 ? 's' : ''}
                      {catWodFiltro && <span class="text-primary"> · {catLabels[catWodFiltro]}</span>}
                    </p>
                  </div>
                  {wod.time_cap_min && (
                    <span class="shrink-0 rounded px-2 py-1 text-xs font-semibold bg-orange-500/10 text-orange-400">
                      Cap {wod.time_cap_min}min
                    </span>
                  )}
                </div>

                <!-- Leaderboard -->
                {sorted.length === 0 ? (
                  <p class="py-10 text-center text-sm text-muted-foreground">
                    {catWodFiltro
                      ? `Nenhum resultado ${catLabels[catWodFiltro]} registrado ainda.`
                      : 'Nenhum resultado registrado ainda.'}
                  </p>
                ) : (
                  <div class="divide-y divide-border/50">
                    {sorted.map((r, i) => {
                      const isMe = r.aluno_id === user.id;
                      const nome = r.profiles?.nome_completo ?? 'Atleta';
                      return (
                        <div class:list={[
                          'flex items-center gap-4 px-5 py-3.5 transition-colors',
                          i === 0 ? 'bg-primary/5' : isMe ? 'bg-blue-500/5' : 'hover:bg-muted/20',
                        ]}>
                          <!-- Posição -->
                          <span class="w-8 text-center shrink-0">
                            {i < 3
                              ? <span class="text-xl">{medalhas[i]}</span>
                              : <span class="text-sm font-bold text-muted-foreground">{i + 1}</span>}
                          </span>

                          <!-- Avatar -->
                          <div class:list={[
                            'flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-xs font-bold',
                            isMe ? 'bg-blue-500/20 text-blue-400' : 'bg-primary/15 text-primary',
                          ]}>
                            {nome.charAt(0).toUpperCase()}
                          </div>

                          <!-- Nome + categoria -->
                          <div class="flex-1 min-w-0">
                            <p class="text-sm font-medium text-foreground truncate">
                              {nome}
                              {isMe && <span class="ml-2 text-[10px] text-blue-400 font-semibold">VOCÊ</span>}
                            </p>
                            <p class="text-xs text-muted-foreground">
                              {catLabels[r.categoria] ?? r.categoria}
                              {r.pse ? ` · PSE ${r.pse}` : ''}
                            </p>
                          </div>

                          <!-- Score -->
                          <div class="text-right shrink-0">
                            <p class:list={['text-base font-bold',
                              i === 0 ? 'text-primary' : isMe ? 'text-blue-400' : 'text-foreground']}>
                              {fmtWodScore(r, wod.score_type)}
                            </p>
                            {r.deu_cap && wod.score_type === 'tempo' && (
                              <p class="text-[10px] text-orange-400 font-medium">CAP</p>
                            )}
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  )}
</DashboardLayout>

<script define:vars={{ catWodFiltro }}>
  const input = document.getElementById('wod-data-input');
  if (input) {
    input.addEventListener('change', () => {
      const params = new URLSearchParams({ tab: 'wod', data: (input as HTMLInputElement).value });
      if (catWodFiltro) params.set('catwod', catWodFiltro);
      window.location.href = '/dashboard/rankings?' + params.toString();
    });
  }
</script>
