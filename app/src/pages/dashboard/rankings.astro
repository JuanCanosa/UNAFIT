---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role === 'aluno') return Astro.redirect('/dashboard');

// Mês atual em horário de Brasília
const hojeISO_BR = new Intl.DateTimeFormat('en-CA', { timeZone: 'America/Sao_Paulo' }).format(new Date());
const inicioMes  = hojeISO_BR.slice(0, 7) + '-01';

const mesFmt = new Date(inicioMes + 'T12:00:00Z').toLocaleDateString('pt-BR', {
  month: 'long', year: 'numeric',
});

// Busca paralela: aulas do mês + checkins do mês
const [
  { data: aulasDoMes },
  { data: checkinsDoMes },
] = await Promise.all([
  supabase
    .from('aulas_agenda')
    .select('id, data_aula, horario_inicio, modalidade, capacidade_max, wods(nome)')
    .eq('academia_id', profile.academia_id!)
    .gte('data_aula', inicioMes)
    .lte('data_aula', hojeISO_BR)
    .order('data_aula', { ascending: false }),

  supabase
    .from('checkins')
    .select('aula_id, aluno_id, profiles(nome_completo)')
    .eq('academia_id', profile.academia_id!)
    .gte('feito_em', `${inicioMes}T00:00:00`),
]);

// Processa em JS: presença por aula + ranking de alunos
const presencasPorAula: Record<string, number> = {};
const rankingMap: Record<string, { nome: string; total: number }> = {};

for (const c of checkinsDoMes ?? []) {
  if (c.aula_id) {
    presencasPorAula[c.aula_id] = (presencasPorAula[c.aula_id] ?? 0) + 1;
  }
  const nome = (c.profiles as any)?.nome_completo ?? '?';
  if (!rankingMap[c.aluno_id]) rankingMap[c.aluno_id] = { nome, total: 0 };
  rankingMap[c.aluno_id]!.total++;
}

const topAlunos = Object.values(rankingMap)
  .sort((a, b) => b.total - a.total)
  .slice(0, 20);

const totalAulasNoMes     = aulasDoMes?.length ?? 0;
const totalPresencasNoMes = checkinsDoMes?.length ?? 0;
const alunosUnicos        = Object.keys(rankingMap).length;
const mediaPresenca       = totalAulasNoMes > 0
  ? (totalPresencasNoMes / totalAulasNoMes).toFixed(1)
  : '—';

const medalhas = ['🥇', '🥈', '🥉'];
---

<DashboardLayout title="Rankings">

  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Rankings</h1>
    <p class="mt-1 text-sm text-muted-foreground capitalize">Desempenho e presença dos atletas · {mesFmt}</p>
  </div>

  <!-- Stats do mês -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 mb-6">
    <div class="rounded-xl border border-border bg-card p-4">
      <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Aulas no Mês</p>
      <p class="mt-1.5 text-3xl font-bold text-foreground">{totalAulasNoMes}</p>
      <p class="text-xs text-muted-foreground mt-1">turmas realizadas</p>
    </div>
    <div class="rounded-xl border border-primary/20 bg-primary/5 p-4">
      <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Presenças</p>
      <p class="mt-1.5 text-3xl font-bold text-primary">{totalPresencasNoMes}</p>
      <p class="text-xs text-muted-foreground mt-1">check-ins no mês</p>
    </div>
    <div class="rounded-xl border border-border bg-card p-4">
      <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Média / Aula</p>
      <p class="mt-1.5 text-3xl font-bold text-foreground">{mediaPresenca}</p>
      <p class="text-xs text-muted-foreground mt-1">alunos por turma</p>
    </div>
    <div class="rounded-xl border border-border bg-card p-4">
      <p class="text-xs text-muted-foreground uppercase tracking-wider font-medium">Alunos Ativos</p>
      <p class="mt-1.5 text-3xl font-bold text-foreground">{alunosUnicos}</p>
      <p class="text-xs text-muted-foreground mt-1">treinaram este mês</p>
    </div>
  </div>

  <!-- Grid principal -->
  <div class="grid gap-6 lg:grid-cols-2">

    <!-- TOP PRESENÇA -->
    <Card>
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
        🏋️ Top Presença — Este Mês
      </h2>

      {topAlunos.length === 0 ? (
        <p class="py-8 text-center text-sm text-muted-foreground">Nenhum check-in registrado este mês.</p>
      ) : (
        <div class="space-y-1.5">
          {topAlunos.map((r, i) => (
            <div class:list={[
              'flex items-center gap-3 rounded-lg px-3 py-2.5 transition-colors',
              i === 0 ? 'bg-primary/10 border border-primary/20' : 'hover:bg-muted/30',
            ]}>
              <span class="w-7 text-center">
                {i < 3
                  ? <span class="text-lg">{medalhas[i]}</span>
                  : <span class="text-sm font-bold text-muted-foreground">{i + 1}</span>
                }
              </span>
              <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">
                {r.nome.charAt(0).toUpperCase()}
              </div>
              <p class="flex-1 min-w-0 text-sm font-medium text-foreground truncate">{r.nome}</p>
              <div class="text-right shrink-0">
                <p class="text-sm font-bold text-primary">{r.total}</p>
                <p class="text-[10px] text-muted-foreground">check-in{r.total !== 1 ? 's' : ''}</p>
              </div>
            </div>
          ))}
        </div>
      )}
    </Card>

    <!-- HISTÓRICO DE AULAS -->
    <Card>
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">
        📋 Histórico de Aulas — Este Mês
      </h2>

      {!aulasDoMes || aulasDoMes.length === 0 ? (
        <p class="py-8 text-center text-sm text-muted-foreground">Nenhuma aula registrada este mês.</p>
      ) : (
        <div class="space-y-1.5 max-h-[520px] overflow-y-auto pr-1">
          {aulasDoMes.map((a: any) => {
            const presencas = presencasPorAula[a.id] ?? 0;
            const cap       = Number(a.capacidade_max) || 0;
            const pct       = cap > 0 ? Math.min(100, Math.round((presencas / cap) * 100)) : null;
            const nomeAula  = (a.wods as any)?.nome ?? a.modalidade ?? 'Aula';
            const dataObj   = new Date(a.data_aula + 'T12:00:00Z');
            return (
              <div class="flex items-center gap-3 rounded-lg px-3 py-2.5 hover:bg-muted/30 transition-colors">
                <!-- Data -->
                <div class="flex h-10 w-10 shrink-0 flex-col items-center justify-center rounded-lg bg-muted text-center">
                  <span class="text-sm font-bold text-foreground leading-none">
                    {dataObj.getUTCDate()}
                  </span>
                  <span class="text-[9px] text-muted-foreground uppercase tracking-wide">
                    {dataObj.toLocaleDateString('pt-BR', { month: 'short', timeZone: 'UTC' }).replace('.', '')}
                  </span>
                </div>
                <!-- Info -->
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-foreground truncate">{nomeAula}</p>
                  <p class="text-xs text-muted-foreground">
                    {a.horario_inicio?.slice(0, 5)}
                    {cap > 0 ? ` · cap. ${cap}` : ''}
                  </p>
                  {pct !== null && (
                    <div class="mt-1.5 h-1 w-full rounded-full bg-zinc-800 overflow-hidden">
                      <div
                        class:list={[
                          'h-full rounded-full transition-all',
                          pct >= 90 ? 'bg-red-500' : pct >= 60 ? 'bg-yellow-500' : 'bg-primary',
                        ]}
                        style={`width: ${pct}%`}
                      />
                    </div>
                  )}
                </div>
                <!-- Presenças -->
                <div class="text-right shrink-0 min-w-[48px]">
                  <p class="text-sm font-bold text-foreground">{presencas}</p>
                  <p class="text-[10px] text-muted-foreground">
                    {cap > 0 ? `de ${cap}` : 'presente' + (presencas !== 1 ? 's' : '')}
                  </p>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </Card>

  </div>
</DashboardLayout>
