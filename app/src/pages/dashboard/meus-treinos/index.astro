---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase   = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role !== 'aluno') return Astro.redirect('/dashboard');

const adminClient = createSupabaseAdminClient();

const [
  { data: wodsRaw },
  { data: meusResultados },
] = await Promise.all([
  adminClient.from('wods')
    .select('id, nome, score_type, data_aplicacao, treino, time_cap_min')
    .eq('academia_id', profile.academia_id)
    .eq('aberto_para_avaliacao', true)
    .order('data_aplicacao', { ascending: false }),
  adminClient.from('wod_resultados')
    .select('wod_id, categoria, deu_cap, tempo_segundos, repeticoes, carga_kg, pse')
    .eq('aluno_id', user.id),
]);

type Wod = { id: string; nome: string; score_type: string; data_aplicacao: string; treino: string; time_cap_min: number | null };
type MeuResultado = { wod_id: string; categoria: string; deu_cap: boolean; tempo_segundos: number | null; repeticoes: number | null; carga_kg: number | null; pse: number | null };

const wods = (wodsRaw ?? []) as Wod[];
const resultadosPorWod = new Map<string, MeuResultado>();
for (const r of (meusResultados ?? []) as MeuResultado[]) {
  resultadosPorWod.set(r.wod_id, r);
}

const pendentes  = wods.filter(w => !resultadosPorWod.has(w.id));
const concluidos = wods.filter(w => resultadosPorWod.has(w.id));

function scoreLabel(s: string) {
  if (s === 'tempo') return 'Para Tempo';
  if (s === 'carga') return 'Carga Máx';
  return 'Max Reps';
}
function formatScore(r: MeuResultado, scoreType: string) {
  if (scoreType === 'tempo') {
    if (r.deu_cap) return `CAP → ${r.repeticoes ?? 0} reps`;
    if (r.tempo_segundos) {
      const m = Math.floor(r.tempo_segundos / 60).toString().padStart(2, '0');
      const s = (r.tempo_segundos % 60).toString().padStart(2, '0');
      return `${m}:${s}`;
    }
  }
  if (scoreType === 'carga') return `${r.carga_kg} kg`;
  if (scoreType === 'reps')  return `${r.repeticoes} reps`;
  return '—';
}
function catLabel(c: string) {
  if (c === 'rx') return 'RX';
  if (c === 'intermediario') return 'Intermediário';
  if (c === 'scaled') return 'Scaled';
  return 'Iniciante';
}
function formatDate(d: string) {
  if (!d) return '';
  const [y, m, dia] = d.split('-');
  return `${dia}/${m}`;
}
---
<DashboardLayout title="Meus Treinos">
  <div class="max-w-2xl mx-auto space-y-6">

    <div>
      <h1 class="text-2xl font-bold text-foreground">Meus Treinos</h1>
      <p class="text-sm text-muted-foreground mt-0.5">WODs abertos para registro de resultado.</p>
    </div>

    <!-- Pendentes (call to action) -->
    {pendentes.length > 0 && (
      <section>
        <p class="text-xs font-semibold text-primary uppercase tracking-widest mb-3">
          Aguardando seu resultado ({pendentes.length})
        </p>
        <div class="space-y-3">
          {pendentes.map(w => (
            <a href={`/dashboard/meus-treinos/wod/${w.id}`}
              class="group flex items-center gap-4 rounded-xl border border-primary/30 bg-primary/5 hover:bg-primary/10 hover:border-primary/50 transition-all p-4">
              <!-- Date bubble -->
              <div class="flex flex-col items-center justify-center rounded-lg h-14 w-14 shrink-0 bg-primary text-primary-foreground text-center">
                <span class="text-xl font-bold leading-tight">{formatDate(w.data_aplicacao).split('/')[0]}</span>
                <span class="text-[10px] uppercase font-semibold">
                  {new Date(w.data_aplicacao + 'T12:00').toLocaleDateString('pt-BR', { month: 'short' })}
                </span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-foreground truncate">{w.nome}</p>
                <span class:list={[
                  'inline-block mt-1 px-1.5 py-0.5 rounded text-[10px] font-semibold uppercase tracking-wide',
                  w.score_type === 'tempo' ? 'bg-blue-500/15 text-blue-400' :
                  w.score_type === 'carga' ? 'bg-orange-500/15 text-orange-400' :
                                             'bg-purple-500/15 text-purple-400'
                ]}>
                  {scoreLabel(w.score_type)}
                </span>
              </div>
              <div class="flex flex-col items-center gap-1">
                <span class="text-xs text-primary font-semibold group-hover:underline">Registrar</span>
                <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {wods.length === 0 && (
      <div class="rounded-xl border border-border bg-card p-10 text-center">
        <svg class="h-8 w-8 text-muted-foreground/30 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <p class="text-muted-foreground text-sm">Nenhum WOD aberto para avaliação no momento.</p>
        <p class="text-muted-foreground/60 text-xs mt-1">Aguarde o professor abrir o próximo WOD.</p>
      </div>
    )}

    <!-- Concluídos -->
    {concluidos.length > 0 && (
      <section>
        <p class="text-xs font-semibold text-muted-foreground uppercase tracking-widest mb-3">
          Já registrados ({concluidos.length})
        </p>
        <div class="space-y-2">
          {concluidos.map(w => {
            const r = resultadosPorWod.get(w.id)!;
            return (
              <a href={`/dashboard/meus-treinos/wod/${w.id}`}
                class="group flex items-center gap-4 rounded-xl border border-border bg-card hover:border-primary/30 transition-colors p-4">
                <div class="flex flex-col items-center justify-center rounded-lg h-12 w-12 shrink-0 bg-muted text-muted-foreground text-center">
                  <span class="text-lg font-bold leading-tight">{formatDate(w.data_aplicacao).split('/')[0]}</span>
                  <span class="text-[10px] uppercase font-medium">
                    {new Date(w.data_aplicacao + 'T12:00').toLocaleDateString('pt-BR', { month: 'short' })}
                  </span>
                </div>
                <div class="flex-1 min-w-0">
                  <p class="font-semibold text-sm text-foreground truncate">{w.nome}</p>
                  <div class="flex items-center gap-2 mt-0.5">
                    <span class="text-xs font-bold text-primary">{formatScore(r, w.score_type)}</span>
                    <span class="text-[10px] text-muted-foreground">{catLabel(r.categoria)}</span>
                    {r.pse && <span class="text-[10px] text-muted-foreground">· PSE {r.pse}</span>}
                  </div>
                </div>
                <svg class="h-4 w-4 text-muted-foreground group-hover:text-primary transition-colors shrink-0"
                  fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </div>
</DashboardLayout>
