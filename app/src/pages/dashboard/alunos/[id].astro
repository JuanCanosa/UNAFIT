---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';
import { enviarEmailNovaSenha, enviarEmailAtualizacaoCadastro, emailConfigurado } from '@/lib/email';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role === 'aluno') return Astro.redirect('/dashboard');

const { id: alunoId } = Astro.params;
const canEdit          = profile.role === 'dono' || profile.role === 'colaborador' || profile.role === 'saas_admin';
const canVerFinanceiro = profile.role === 'dono' || profile.role === 'saas_admin';

let formError = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'editar_aluno') {
    const adminClient = createSupabaseAdminClient();

    // Busca dados atuais ANTES de atualizar (para detectar o que mudou)
    const { data: alunoAtual } = await adminClient.from('alunos')
      .select('nome, email, cpf, academia_id')
      .eq('id', alunoId!).eq('academia_id', profile.academia_id!)
      .single();

    const { data: academiaAtual } = await adminClient.from('academias')
      .select('nome, logo_url').eq('id', profile.academia_id!).single();

    const novoNome   = (form.get('nome') as string)?.trim();
    const novoEmail  = (form.get('email') as string)?.trim().toLowerCase() || null;
    const novoCpfRaw = (form.get('cpf') as string)?.replace(/\D/g, '') ?? alunoAtual?.cpf ?? '';
    const novoCpf    = novoCpfRaw.length === 11 ? novoCpfRaw : (alunoAtual?.cpf ?? '');

    if (novoCpfRaw && novoCpfRaw.length !== 11) {
      formError = 'CPF inválido — deve ter 11 dígitos.';
    } else {
      const campos: Record<string, any> = {
        nome:                 novoNome,
        email:                novoEmail,
        cpf:                  novoCpf,
        telefone:             (form.get('telefone') as string)?.trim(),
        data_nascimento:      (form.get('data_nascimento') as string) || null,
        categoria_id:         form.get('categoria_id') || null,
        status:               form.get('status') as string,
        endereco_cep:         form.get('endereco_cep') || null,
        endereco_rua:         form.get('endereco_rua') || null,
        endereco_numero:      form.get('endereco_numero') || null,
        endereco_complemento: form.get('endereco_complemento') || null,
        endereco_bairro:      form.get('endereco_bairro') || null,
        endereco_cidade:      form.get('endereco_cidade') || null,
        endereco_estado:      form.get('endereco_estado') || null,
      };

      const { error } = await supabase.from('alunos').update(campos)
        .eq('id', alunoId!).eq('academia_id', profile.academia_id!);

      if (error) {
        formError = error.message;
      } else {
        // ── Detecta mudanças em CPF e e-mail ──────────────────────────────────
        const emailMudou = novoEmail !== alunoAtual?.email;
        const cpfMudou   = novoCpf   !== alunoAtual?.cpf;
        const alteracoes: { campo: string; novoValor: string }[] = [];

        if (cpfMudou) alteracoes.push({
          campo: 'CPF',
          novoValor: novoCpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4'),
        });
        if (emailMudou && novoEmail) alteracoes.push({ campo: 'E-mail', novoValor: novoEmail });

        if ((cpfMudou || emailMudou) && alunoAtual) {
          // Busca o profile_id do aluno para atualizar o auth
          const { data: vinculo } = await adminClient.from('aluno_academias')
            .select('profile_id').eq('aluno_id', alunoId!).maybeSingle();
          const profileId = vinculo?.profile_id;

          if (profileId) {
            if (emailMudou && novoEmail) {
              // Atualiza o email de autenticação
              await adminClient.auth.admin.updateUserById(profileId, {
                email: novoEmail, email_confirm: true,
              });
            } else if (cpfMudou && !alunoAtual.email) {
              // Aluno usa CPF como login — atualiza o email fictício
              await adminClient.auth.admin.updateUserById(profileId, {
                email: `${novoCpf}@aluno.unafit.com.br`, email_confirm: true,
              });
            }
          }

          // ── Envia notificação por e-mail se houver email real ────────────────
          const emailNotificacao = novoEmail || alunoAtual.email;
          if (emailNotificacao && alteracoes.length > 0 && emailConfigurado()) {
            await enviarEmailAtualizacaoCadastro({
              email: emailNotificacao,
              nomeAluno: novoNome,
              nomeAcademia: academiaAtual?.nome ?? 'Academia',
              logoUrl: academiaAtual?.logo_url ?? null,
              alteracoes,
            });
          }
        }

        return Astro.redirect(`/dashboard/alunos/${alunoId}?saved=1`);
      }
    }
  }

  if (action === 'adicionar_plano') {
    const plano_id = form.get('plano_id') as string;
    if (plano_id) {
      // Cancela planos ativos anteriores
      await supabase.from('aluno_planos').update({ status: 'cancelado', data_fim: new Date().toISOString().split('T')[0] })
        .eq('aluno_id', alunoId!).eq('status', 'ativo');
      await supabase.from('aluno_planos').insert({
        academia_id: profile.academia_id, aluno_id: alunoId, plano_id,
      });
    }
    return Astro.redirect(`/dashboard/alunos/${alunoId}?saved=1`);
  }

  if (action === 'cancelar_plano') {
    const ap_id = form.get('aluno_plano_id') as string;
    await supabase.from('aluno_planos').update({ status: 'cancelado', data_fim: new Date().toISOString().split('T')[0] })
      .eq('id', ap_id).eq('academia_id', profile.academia_id!);
    return Astro.redirect(`/dashboard/alunos/${alunoId}`);
  }

  if (action === 'registrar_pagamento') {
    const pagamento_id = form.get('pagamento_id') as string;
    await supabase.from('pagamentos').update({ status: 'pago', data_pagamento: new Date().toISOString().split('T')[0] })
      .eq('id', pagamento_id).eq('academia_id', profile.academia_id!);
    return Astro.redirect(`/dashboard/alunos/${alunoId}?saved=1`);
  }

  // Busca aluno para as ações de acesso
  const { data: alunoAcesso } = await supabase
    .from('alunos').select('nome, email, cpf, telefone').eq('id', alunoId!).eq('academia_id', profile.academia_id!).single();

  if ((action === 'definir_senha' || action === 'enviar_reset') && alunoAcesso && (profile.role === 'dono' || profile.role === 'saas_admin')) {
    const adminClient = createSupabaseAdminClient();

    // Determina o email de autenticação (real ou CPF-fictício)
    const cpfDigits = (alunoAcesso.cpf ?? '').replace(/\D/g, '');
    const authEmailAcesso = alunoAcesso.email || `${cpfDigits}@aluno.unafit.com.br`;

    // Encontra auth user pelo email correto
    const { data: { users } } = await adminClient.auth.admin.listUsers({ page: 1, perPage: 50000 });
    const authUser = users.find(u => u.email?.toLowerCase() === authEmailAcesso.toLowerCase());

    if (action === 'definir_senha') {
      const nova_senha = (form.get('nova_senha') as string)?.trim();
      if (!nova_senha || nova_senha.length < 8) {
        formError = 'A senha deve ter pelo menos 8 caracteres.';
      } else if (authUser) {
        // Usuário existe — atualiza senha
        const { error } = await adminClient.auth.admin.updateUserById(authUser.id, { password: nova_senha });
        if (error) formError = error.message;
        else return Astro.redirect(`/dashboard/alunos/${alunoId}?saved=1`);
      } else {
        // Usuário não existe ainda — cria com senha
        const { data: newUser, error: cErr } = await adminClient.auth.admin.createUser({
          email: authEmailAcesso,
          password: nova_senha,
          email_confirm: true,
          user_metadata: { nome_completo: alunoAcesso.nome },
        });
        if (cErr) { formError = cErr.message; }
        else if (newUser?.user) {
          await adminClient.from('profiles').upsert({
            id: newUser.user.id,
            nome_completo: alunoAcesso.nome,
            telefone: alunoAcesso.telefone,
            role: 'aluno',
            academia_id: profile.academia_id,
            ativo: true,
          }, { onConflict: 'id' });
          // Ativa o aluno
          await supabase.from('alunos').update({ status: 'ativo' }).eq('id', alunoId!);
          return Astro.redirect(`/dashboard/alunos/${alunoId}?saved=1`);
        }
      }
    }

    if (action === 'enviar_reset') {
      if (!authUser) {
        formError = 'Este aluno ainda não tem conta de acesso. Defina uma senha primeiro.';
      } else {
        // Gera senha temporária aleatória (10 chars: letras + números)
        const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghjkmnpqrstuvwxyz23456789';
        let senhaTemp = '';
        for (let i = 0; i < 10; i++) senhaTemp += chars[Math.floor(Math.random() * chars.length)];

        // Atualiza a senha no Supabase Auth via admin
        const { error: updateErr } = await adminClient.auth.admin.updateUserById(authUser.id, {
          password: senhaTemp,
        });

        if (updateErr) {
          formError = updateErr.message;
        } else {
          // Busca dados da academia para o email branded
          const { data: acad } = await adminClient
            .from('academias')
            .select('nome, slug, logo_url')
            .eq('id', profile.academia_id!)
            .single();

          const siteUrl = (process.env.SITE ?? 'https://unafit.com.br').replace(/\/$/, '');
          const loginUrl = acad?.slug ? `${siteUrl}/${acad.slug}` : `${siteUrl}/login`;

          if (!emailConfigurado()) {
            return Astro.redirect(`/dashboard/alunos/${alunoId}?reset_enviado=1&senha_temp=${encodeURIComponent(senhaTemp)}&login_url=${encodeURIComponent(loginUrl)}`);
          }

          const resultado = await enviarEmailNovaSenha({
            email:         alunoAcesso.email,
            nomeAluno:     alunoAcesso.nome,
            nomeAcademia:  acad?.nome ?? 'Academia',
            logoUrl:       acad?.logo_url ?? null,
            senhaTemporaria: senhaTemp,
            loginUrl,
          });

          if (!resultado.ok) formError = resultado.erro ?? 'Erro ao enviar e-mail.';
          else return Astro.redirect(`/dashboard/alunos/${alunoId}?reset_enviado=1`);
        }
      }
    }
  }
}

const urlParams         = new URL(Astro.request.url).searchParams;
const savedParam        = urlParams.get('saved');
const novoParam         = urlParams.get('novo');
const resetEnviadoParam = urlParams.get('reset_enviado');
const senhaTempParam    = urlParams.get('senha_temp');
const loginUrlParam     = urlParams.get('login_url');

// Busca dados do aluno
const { data: aluno } = await supabase
  .from('alunos')
  .select(`*, categorias_alunos(id, nome, cor)`)
  .eq('id', alunoId!)
  .eq('academia_id', profile.academia_id!)
  .single();

if (!aluno) return Astro.redirect('/dashboard/alunos');

const cpfMascarado = aluno.cpf
  ? aluno.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4')
  : '—';

const [
  { data: matriculas },
  { data: pagamentos },
  { data: categorias },
  { data: planos },
  { data: linkAluno },
] = await Promise.all([
  supabase.from('aluno_planos').select('*, planos(id, nome, valor, vencimento_dia)')
    .eq('aluno_id', alunoId!).order('created_at', { ascending: false }),
  supabase.from('pagamentos').select('*').eq('aluno_id', alunoId!).order('data_vencimento', { ascending: false }).limit(12),
  supabase.from('categorias_alunos').select('id, nome, cor').eq('academia_id', profile.academia_id!).order('nome'),
  supabase.from('planos').select('id, nome, valor').eq('academia_id', profile.academia_id!).eq('ativo', true).order('nome'),
  // aluno_id na tabela alunos ≠ aluno_id em checkins (checkins usa profiles.id)
  supabase.from('aluno_academias').select('profile_id').eq('aluno_id', alunoId!).maybeSingle(),
]);

// checkins.aluno_id = profiles.id — precisa do profile_id do vínculo
const profileIdAluno = linkAluno?.profile_id ?? null;
const { data: checkins } = profileIdAluno
  ? await supabase
      .from('checkins')
      .select('id, feito_em, aulas_agenda(id, data_aula, horario_inicio, modalidade, wods(id, nome))')
      .eq('aluno_id', profileIdAluno)
      .order('feito_em', { ascending: false })
      .limit(50)
  : { data: [] as any[] };

const matriculaAtiva = matriculas?.find((m: any) => m.status === 'ativo');

const statusPagCores: Record<string, string> = {
  pago:      'text-green-400 bg-green-900/30',
  pendente:  'text-yellow-400 bg-yellow-900/30',
  vencido:   'text-red-400 bg-red-900/30',
  cancelado: 'text-zinc-500 bg-zinc-800',
};
---

<DashboardLayout title={aluno.nome}>
  <div class="p-6 max-w-5xl mx-auto space-y-6">

    <!-- Breadcrumb + Banner -->
    <div class="flex items-center gap-3 text-sm">
      <a href="/dashboard/alunos" class="text-zinc-400 hover:text-white">← Alunos</a>
      <span class="text-zinc-700">/</span>
      <span class="text-white">{aluno.nome}</span>
    </div>

    {(savedParam || novoParam) && (
      <div class="bg-green-900/40 border border-green-600 text-green-300 px-4 py-3 rounded-lg text-sm">
        {novoParam ? 'Aluno cadastrado com sucesso!' : 'Alterações salvas com sucesso!'}
      </div>
    )}
    {resetEnviadoParam && !senhaTempParam && (
      <div class="bg-blue-900/40 border border-blue-600 text-blue-300 px-4 py-3 rounded-lg text-sm">
        ✉ E-mail com nova senha enviado para {aluno.email}.
      </div>
    )}
    {resetEnviadoParam && senhaTempParam && (
      <div class="rounded-lg border border-yellow-600/40 bg-yellow-900/20 px-4 py-3 text-sm space-y-1.5">
        <p class="font-semibold text-yellow-300">Senha gerada — e-mail não configurado. Repasse manualmente ao aluno:</p>
        <p class="text-yellow-200">Login: <strong>{aluno.email || aluno.cpf}</strong></p>
        <p class="text-yellow-200">Senha: <strong class="font-mono text-lg tracking-widest">{senhaTempParam}</strong></p>
        {loginUrlParam && <p class="text-yellow-200">URL: <strong>{loginUrlParam}</strong></p>}
      </div>
    )}
    {formError && (
      <div class="bg-red-900/40 border border-red-600 text-red-300 px-4 py-3 rounded-lg text-sm">{formError}</div>
    )}

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Coluna esquerda: Perfil -->
      <div class="lg:col-span-1 space-y-4">
        <!-- Card perfil -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-3">
          <div class="flex items-start justify-between">
            <div>
              <h1 class="text-lg font-bold text-white">{aluno.nome}</h1>
              <p class="text-zinc-400 text-sm">{aluno.email}</p>
            </div>
            <span class={`text-xs px-2 py-0.5 rounded-full ${
              aluno.status === 'ativo' ? 'bg-green-900/50 text-green-400' :
              aluno.status === 'pendente' ? 'bg-yellow-900/50 text-yellow-400' :
              'bg-zinc-800 text-zinc-500'
            }`}>{aluno.status}</span>
          </div>

          <div class="space-y-1.5 text-sm text-zinc-400 border-t border-zinc-800 pt-3">
            <p><span class="text-zinc-600">Tel:</span> {aluno.telefone}</p>
            <p><span class="text-zinc-600">CPF:</span> {aluno.cpf.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4')}</p>
            {aluno.data_nascimento && (
              <p>
                <span class="text-zinc-600">Nasc.:</span>{' '}
                {new Date(aluno.data_nascimento + 'T12:00:00').toLocaleDateString('pt-BR')}
              </p>
            )}
            {aluno.categorias_alunos && (
              <p class="flex items-center gap-1.5">
                <span class="w-2 h-2 rounded-full" style={`background:${aluno.categorias_alunos.cor}`}></span>
                {aluno.categorias_alunos.nome}
              </p>
            )}
          </div>

          {(aluno.endereco_rua) && (
            <div class="text-xs text-zinc-500 border-t border-zinc-800 pt-3">
              {aluno.endereco_rua}{aluno.endereco_numero ? `, ${aluno.endereco_numero}` : ''}<br />
              {aluno.endereco_bairro && `${aluno.endereco_bairro} — `}{aluno.endereco_cidade}/{aluno.endereco_estado}
              {aluno.endereco_cep && ` · ${aluno.endereco_cep}`}
            </div>
          )}

          {canEdit && (
            <button onclick="document.getElementById('modal-editar').classList.remove('hidden')"
              class="w-full py-2 border border-zinc-600 hover:border-zinc-400 text-zinc-300 text-sm rounded-lg">
              Editar dados
            </button>
          )}
        </div>

        <!-- Acesso ao sistema (só dono) -->
        {(profile.role === 'dono' || profile.role === 'saas_admin') && (
          <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-4">
            <h2 class="text-sm font-semibold text-zinc-300">Acesso ao Sistema</h2>

            <!-- Tipo de login -->
            {(() => {
              const temEmail = !!aluno.email;
              const cpfNum = (aluno.cpf ?? '').replace(/\D/g, '');
              return (
                <div class="flex items-center gap-2 text-xs">
                  <span class="text-zinc-500">Login via:</span>
                  <span class={`px-2 py-0.5 rounded-full font-medium ${temEmail ? 'bg-blue-900/40 text-blue-300' : 'bg-amber-900/40 text-amber-300'}`}>
                    {temEmail ? `✉ ${aluno.email}` : `🪪 CPF ${aluno.cpf}`}
                  </span>
                </div>
              );
            })()}

            <!-- Definir/redefinir senha -->
            <form method="POST" class="space-y-2">
              <input type="hidden" name="action" value="definir_senha" />
              <label class="block text-xs text-zinc-400">Definir senha do aluno</label>
              <div class="flex gap-2">
                <input name="nova_senha" type="password" minlength="8" required
                  placeholder="Nova senha (mín. 8 car.)"
                  class="flex-1 bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm focus:border-primary focus:outline-none" />
                <button type="submit"
                  class="px-3 py-2 bg-primary hover:bg-primary/90 text-primary-foreground text-xs font-medium rounded-lg whitespace-nowrap">
                  Salvar
                </button>
              </div>
              <p class="text-xs text-zinc-600">
                {aluno.email
                  ? `Entra com ${aluno.email} + senha.`
                  : `Entra com CPF ${aluno.cpf} + senha.`}
              </p>
            </form>

            <!-- Enviar email de redefinição (só se tiver email real) -->
            {aluno.email && (
              <div class="border-t border-zinc-800 pt-3">
                <p class="text-xs text-zinc-400 mb-2">Ou envie um link para o aluno criar a própria senha:</p>
                <form method="POST">
                  <input type="hidden" name="action" value="enviar_reset" />
                  <button type="submit"
                    class="w-full py-2 border border-zinc-700 hover:border-zinc-500 text-zinc-400 hover:text-zinc-200 text-xs rounded-lg transition-colors">
                    ✉ Enviar e-mail de redefinição para {aluno.email}
                  </button>
                </form>
              </div>
            )}
          </div>
        )}

        <!-- Plano atual -->
        <div class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-3">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold text-zinc-300">Plano atual</h2>
            {canVerFinanceiro && (
              <button onclick="document.getElementById('modal-plano').classList.remove('hidden')"
                class="text-xs text-red-400 hover:text-red-300">Trocar</button>
            )}
          </div>
          {matriculaAtiva ? (
            <div>
              <p class="text-white font-medium">{(matriculaAtiva as any).planos?.nome}</p>
              {canVerFinanceiro && (
                <>
                  <p class="text-green-400 text-sm">R$ {Number((matriculaAtiva as any).planos?.valor).toFixed(2).replace('.', ',')}/mês</p>
                  <p class="text-zinc-500 text-xs">Vence dia {(matriculaAtiva as any).planos?.vencimento_dia}</p>
                  <form method="POST" class="mt-3">
                    <input type="hidden" name="action" value="cancelar_plano" />
                    <input type="hidden" name="aluno_plano_id" value={(matriculaAtiva as any).id} />
                    <button class="text-xs text-red-500 hover:text-red-400" onclick="return confirm('Cancelar matrícula?')">
                      Cancelar matrícula
                    </button>
                  </form>
                </>
              )}
            </div>
          ) : (
            <p class="text-zinc-500 text-sm">Sem plano ativo</p>
          )}
        </div>
      </div>

      <!-- Coluna direita -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Pagamentos — visível apenas para dono/saas_admin -->
        {canVerFinanceiro && (
          <section class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-3">
            <h2 class="text-sm font-semibold text-zinc-300">Mensalidades</h2>
            {!pagamentos?.length ? (
              <p class="text-zinc-500 text-sm">Nenhum pagamento registrado.</p>
            ) : (
              <div class="space-y-2">
                {pagamentos.map((p: any) => (
                  <div class="flex items-center justify-between py-2 border-b border-zinc-800 last:border-0">
                    <div>
                      <p class="text-sm text-white">
                        Venc. {new Date(p.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}
                      </p>
                      <p class="text-xs text-zinc-500">R$ {Number(p.valor).toFixed(2).replace('.', ',')}</p>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class={`text-xs px-2 py-0.5 rounded-full ${statusPagCores[p.status]}`}>
                        {p.status}
                      </span>
                      {(p.status === 'pendente' || p.status === 'vencido') && (
                        <form method="POST">
                          <input type="hidden" name="action" value="registrar_pagamento" />
                          <input type="hidden" name="pagamento_id" value={p.id} />
                          <button class="text-xs text-green-400 hover:text-green-300 border border-green-800 px-2 py-0.5 rounded">
                            Marcar pago
                          </button>
                        </form>
                      )}
                      {p.link_pagamento && (
                        <a href={p.link_pagamento} target="_blank"
                          class="text-xs text-blue-400 hover:text-blue-300 border border-blue-900 px-2 py-0.5 rounded">
                          Pagar
                        </a>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </section>
        )}

        <!-- Histórico de checkins -->
        <section class="bg-zinc-900 border border-zinc-700 rounded-xl p-5 space-y-3">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold text-zinc-300">Histórico de Aulas</h2>
            <span class="text-xs text-zinc-600">{checkins?.length ?? 0} check-in{(checkins?.length ?? 0) !== 1 ? 's' : ''}</span>
          </div>
          {!profileIdAluno ? (
            <p class="text-zinc-500 text-sm">Aluno sem conta de acesso vinculada.</p>
          ) : !checkins?.length ? (
            <p class="text-zinc-500 text-sm">Nenhum check-in registrado ainda.</p>
          ) : (
            <div class="space-y-1">
              {checkins.map((c: any) => {
                const aula = c.aulas_agenda;
                const dataStr = aula?.data_aula
                  ? new Date(aula.data_aula + 'T12:00:00Z').toLocaleDateString('pt-BR', { weekday: 'short', day: '2-digit', month: 'short' })
                  : new Date(c.feito_em).toLocaleDateString('pt-BR', { day: '2-digit', month: 'short' });
                const nomeAula = aula?.wods?.nome ?? aula?.modalidade ?? 'Aula';
                return (
                  <div class="flex items-center gap-3 py-2 border-b border-zinc-800 last:border-0">
                    <div class="flex h-9 w-9 shrink-0 flex-col items-center justify-center rounded-lg bg-zinc-800 text-center">
                      <span class="text-sm font-bold text-white leading-none">
                        {aula?.data_aula
                          ? new Date(aula.data_aula + 'T12:00:00Z').getUTCDate()
                          : new Date(c.feito_em).getDate()}
                      </span>
                      <span class="text-[9px] text-zinc-500 uppercase">
                        {aula?.data_aula
                          ? new Date(aula.data_aula + 'T12:00:00Z').toLocaleDateString('pt-BR', { month: 'short', timeZone: 'UTC' }).replace('.', '')
                          : new Date(c.feito_em).toLocaleDateString('pt-BR', { month: 'short' }).replace('.', '')}
                      </span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <p class="text-sm text-white font-medium truncate">{nomeAula}</p>
                      <p class="text-xs text-zinc-500">
                        {dataStr}{aula?.horario_inicio ? ` · ${aula.horario_inicio.slice(0, 5)}` : ''}
                      </p>
                    </div>
                    <span class="text-xs text-primary font-bold shrink-0">✓</span>
                  </div>
                );
              })}
            </div>
          )}
        </section>

      </div>
    </div>
  </div>

  <!-- Modal Editar Aluno -->
  <div id="modal-editar" class="hidden fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4 overflow-y-auto">
    <div class="bg-zinc-900 border border-zinc-700 rounded-2xl p-6 w-full max-w-lg my-4 space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold text-white">Editar Aluno</h3>
        <button onclick="document.getElementById('modal-editar').classList.add('hidden')" class="text-zinc-400 hover:text-white text-xl">×</button>
      </div>
      <form method="POST" class="space-y-3">
        <input type="hidden" name="action" value="editar_aluno" />
        <div>
          <label class="block text-sm text-zinc-400 mb-1">Nome *</label>
          <input name="nome" value={aluno.nome} required
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">CPF</label>
            <input id="modal-cpf" name="cpf" type="text" value={cpfMascarado}
              maxlength="14" placeholder="000.000.000-00"
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Telefone *</label>
            <input name="telefone" value={aluno.telefone} required
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-sm text-zinc-400 mb-1">E-mail <span class="text-zinc-600">(opcional)</span></label>
          <input name="email" type="email" value={aluno.email ?? ''}
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm"
            placeholder="Sem e-mail, aluno entra com CPF" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Data de nascimento</label>
            <input name="data_nascimento" type="date" value={aluno.data_nascimento ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Complemento</label>
            <input name="endereco_complemento" value={aluno.endereco_complemento ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Categoria</label>
            <select name="categoria_id"
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm">
              <option value="">Sem categoria</option>
              {categorias?.map((c: any) => (
                <option value={c.id} selected={c.id === aluno.categoria_id}>{c.nome}</option>
              ))}
            </select>
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Status</label>
            <select name="status"
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm">
              <option value="ativo" selected={aluno.status === 'ativo'}>Ativo</option>
              <option value="pendente" selected={aluno.status === 'pendente'}>Pendente</option>
              <option value="inativo" selected={aluno.status === 'inativo'}>Inativo</option>
            </select>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">CEP</label>
            <input name="endereco_cep" value={aluno.endereco_cep ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Estado</label>
            <input name="endereco_estado" value={aluno.endereco_estado ?? ''} maxlength="2"
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-sm text-zinc-400 mb-1">Rua</label>
          <input name="endereco_rua" value={aluno.endereco_rua ?? ''}
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Número</label>
            <input name="endereco_numero" value={aluno.endereco_numero ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
          <div>
            <label class="block text-sm text-zinc-400 mb-1">Bairro</label>
            <input name="endereco_bairro" value={aluno.endereco_bairro ?? ''}
              class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
          </div>
        </div>
        <div>
          <label class="block text-sm text-zinc-400 mb-1">Cidade</label>
          <input name="endereco_cidade" value={aluno.endereco_cidade ?? ''}
            class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm" />
        </div>
        <div class="flex gap-2 pt-2">
          <button type="button" onclick="document.getElementById('modal-editar').classList.add('hidden')"
            class="flex-1 py-2 border border-zinc-600 text-zinc-300 rounded-lg text-sm">Cancelar</button>
          <button type="submit"
            class="flex-1 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium">Salvar</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal Trocar Plano -->
  <div id="modal-plano" class="hidden fixed inset-0 bg-black/60 flex items-center justify-center z-50 p-4">
    <div class="bg-zinc-900 border border-zinc-700 rounded-2xl p-6 w-full max-w-sm space-y-4">
      <div class="flex items-center justify-between">
        <h3 class="text-lg font-bold text-white">Trocar Plano</h3>
        <button onclick="document.getElementById('modal-plano').classList.add('hidden')" class="text-zinc-400 hover:text-white text-xl">×</button>
      </div>
      <form method="POST" class="space-y-3">
        <input type="hidden" name="action" value="adicionar_plano" />
        <select name="plano_id" required
          class="w-full bg-zinc-800 border border-zinc-700 rounded-lg px-3 py-2 text-white text-sm">
          <option value="">Selecione um plano...</option>
          {planos?.map((p: any) => (
            <option value={p.id}>{p.nome} — R$ {Number(p.valor).toFixed(2).replace('.', ',')}</option>
          ))}
        </select>
        <div class="flex gap-2 pt-1">
          <button type="button" onclick="document.getElementById('modal-plano').classList.add('hidden')"
            class="flex-1 py-2 border border-zinc-600 text-zinc-300 rounded-lg text-sm">Cancelar</button>
          <button type="submit"
            class="flex-1 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium">Confirmar</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  // Máscara CPF no modal de edição
  const cpfInput = document.getElementById('modal-cpf') as HTMLInputElement | null;
  cpfInput?.addEventListener('input', () => {
    const digits = cpfInput.value.replace(/\D/g, '').slice(0, 11);
    let masked = digits;
    if (digits.length > 9) masked = digits.replace(/(\d{3})(\d{3})(\d{3})(\d{2})/, '$1.$2.$3-$4');
    else if (digits.length > 6) masked = digits.replace(/(\d{3})(\d{3})(\d{1,3})/, '$1.$2.$3');
    else if (digits.length > 3) masked = digits.replace(/(\d{3})(\d{1,3})/, '$1.$2');
    cpfInput.value = masked;
  });
</script>
