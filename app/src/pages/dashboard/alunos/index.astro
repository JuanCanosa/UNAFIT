---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || profile.role === 'aluno') return Astro.redirect('/dashboard');

const url          = new URL(Astro.request.url);
const busca        = url.searchParams.get('q')         || '';
const filtroStatus = url.searchParams.get('status')    || '';
const filtroPlano  = url.searchParams.get('plano')     || '';
const filtroCat    = url.searchParams.get('categoria') || '';
const paginaAtual  = Math.max(1, parseInt(url.searchParams.get('page') || '1'));
const PER_PAGE     = 20;
const offset       = (paginaAtual - 1) * PER_PAGE;

// Se filtrar por plano, resolve IDs no banco antes (evita paginação errada)
let filtroAlunoIds: string[] | null = null;
if (filtroPlano) {
  const { data: apResult } = await supabase
    .from('aluno_planos')
    .select('aluno_id')
    .eq('plano_id', filtroPlano)
    .eq('status', 'ativo');
  filtroAlunoIds = (apResult ?? []).map((ap: any) => ap.aluno_id);
}

let query = supabase
  .from('alunos')
  .select(`
    id, nome, email, telefone, cpf, status, categoria_id, created_at,
    categorias_alunos(id, nome, cor),
    aluno_planos(id, status, planos(id, nome)),
    aluno_modalidades(modalidade)
  `, { count: 'exact' })
  .eq('academia_id', profile.academia_id!)
  .order('nome')
  .range(offset, offset + PER_PAGE - 1);

if (busca)          query = query.or(`nome.ilike.%${busca}%,email.ilike.%${busca}%,cpf.ilike.%${busca}%`);
if (filtroStatus)   query = query.eq('status', filtroStatus);
if (filtroCat)      query = query.eq('categoria_id', filtroCat);
if (filtroAlunoIds !== null) {
  // Se nenhum aluno bate com o plano, garante resultado vazio
  query = filtroAlunoIds.length > 0
    ? query.in('id', filtroAlunoIds)
    : query.eq('id', '00000000-0000-0000-0000-000000000000');
}

const [
  { data: alunos, count: totalCount },
  { data: planos },
  { data: categorias },
] = await Promise.all([
  query,
  supabase.from('planos').select('id, nome').eq('academia_id', profile.academia_id!).eq('ativo', true).order('nome'),
  supabase.from('categorias_alunos').select('id, nome, cor').eq('academia_id', profile.academia_id!).order('nome'),
]);

const totalAlunos = totalCount ?? 0;
const totalPages  = Math.ceil(totalAlunos / PER_PAGE);

// Monta URL base preservando filtros (sem page)
function buildUrl(page: number) {
  const p = new URLSearchParams();
  if (busca)        p.set('q',         busca);
  if (filtroStatus) p.set('status',    filtroStatus);
  if (filtroPlano)  p.set('plano',     filtroPlano);
  if (filtroCat)    p.set('categoria', filtroCat);
  if (page > 1)     p.set('page',      String(page));
  const qs = p.toString();
  return `/dashboard/alunos${qs ? `?${qs}` : ''}`;
}

// Páginas a exibir no paginador (máx 7 botões)
function getPaginasBotoes(atual: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const set = new Set([1, total, atual, atual - 1, atual + 1].filter(p => p >= 1 && p <= total));
  const sorted = [...set].sort((a, b) => a - b);
  const result: (number | '...')[] = [];
  for (let i = 0; i < sorted.length; i++) {
    if (i > 0 && (sorted[i] as number) - (sorted[i - 1] as number) > 1) result.push('...');
    result.push(sorted[i]);
  }
  return result;
}

const statusCores: Record<string, string> = {
  ativo:    'bg-green-900/50 text-green-400 border border-green-800/50',
  inativo:  'bg-zinc-800 text-zinc-500 border border-zinc-700',
  pendente: 'bg-yellow-900/50 text-yellow-400 border border-yellow-800/50',
};

const canEdit   = profile.role === 'dono' || profile.role === 'colaborador' || profile.role === 'saas_admin';
const temFiltro = busca || filtroStatus || filtroPlano || filtroCat;
const inicioPag = totalAlunos === 0 ? 0 : offset + 1;
const fimPag    = Math.min(offset + PER_PAGE, totalAlunos);
---

<DashboardLayout title="Alunos">
  <div class="space-y-5">

    <!-- Header -->
    <div class="flex items-center justify-between gap-3">
      <div>
        <h1 class="text-2xl font-bold text-white">Alunos</h1>
        <p class="text-zinc-400 text-sm mt-0.5">
          {totalAlunos} aluno{totalAlunos !== 1 ? 's' : ''} encontrado{totalAlunos !== 1 ? 's' : ''}
          {totalPages > 1 && <span class="text-zinc-600"> · {inicioPag}–{fimPag}</span>}
        </p>
      </div>
      <div class="flex items-center gap-2 shrink-0">
        <button id="btn-csv" title="Exportar CSV"
          class="inline-flex items-center gap-1.5 px-3 py-2.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 hover:text-white text-sm rounded-xl transition-colors no-print">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="hidden sm:inline">CSV</span>
        </button>
        <button id="btn-pdf" title="Exportar PDF"
          class="inline-flex items-center gap-1.5 px-3 py-2.5 bg-zinc-800 hover:bg-zinc-700 border border-zinc-700 text-zinc-300 hover:text-white text-sm rounded-xl transition-colors no-print">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
          </svg>
          <span class="hidden sm:inline">PDF</span>
        </button>
        {canEdit && (
          <a href="/dashboard/alunos/novo"
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-primary hover:bg-primary/90 text-black text-sm font-bold rounded-xl transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
            <span class="hidden sm:inline">Novo Aluno</span>
            <span class="sm:hidden">Novo</span>
          </a>
        )}
      </div>
    </div>

    <!-- Filtros -->
    <form method="GET" class="space-y-2">
      <!-- Busca -->
      <input
        name="q" value={busca}
        placeholder="Buscar por nome, email ou CPF..."
        class="w-full bg-zinc-900 border border-zinc-700 rounded-xl px-4 py-3 text-white text-base placeholder-zinc-500 focus:outline-none focus:ring-1 focus:ring-primary/50 focus:border-primary/50"
      />
      <!-- Filtros secundários -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
        <select name="categoria" class="bg-zinc-900 border border-zinc-700 rounded-xl px-3 py-3 text-base text-zinc-300 focus:outline-none focus:ring-1 focus:ring-primary/50">
          <option value="">Categorias</option>
          {categorias?.map(c => (
            <option value={c.id} selected={filtroCat === c.id}>{c.nome}</option>
          ))}
        </select>
        <select name="plano" class="bg-zinc-900 border border-zinc-700 rounded-xl px-3 py-3 text-base text-zinc-300 focus:outline-none focus:ring-1 focus:ring-primary/50">
          <option value="">Planos</option>
          {planos?.map(p => (
            <option value={p.id} selected={filtroPlano === p.id}>{p.nome}</option>
          ))}
        </select>
        <select name="status" class="bg-zinc-900 border border-zinc-700 rounded-xl px-3 py-3 text-base text-zinc-300 focus:outline-none focus:ring-1 focus:ring-primary/50">
          <option value="">Status</option>
          <option value="ativo"    selected={filtroStatus === 'ativo'}>Ativo</option>
          <option value="pendente" selected={filtroStatus === 'pendente'}>Pendente</option>
          <option value="inativo"  selected={filtroStatus === 'inativo'}>Inativo</option>
        </select>
        <div class="flex gap-2">
          <button type="submit" class="flex-1 px-3 py-3 bg-zinc-700 hover:bg-zinc-600 text-white text-base font-semibold rounded-xl transition-colors">
            Filtrar
          </button>
          {temFiltro && (
            <a href="/dashboard/alunos" class="shrink-0 px-4 py-3 border border-zinc-700 text-zinc-400 text-base rounded-xl hover:text-white transition-colors flex items-center">
              ✕
            </a>
          )}
        </div>
      </div>
    </form>

    <!-- Lista de alunos -->
    {!alunos.length ? (
      <div class="border border-zinc-700 rounded-xl p-12 text-center">
        <svg class="mx-auto h-10 w-10 text-zinc-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0" />
        </svg>
        <p class="text-zinc-400 text-lg mb-2">Nenhum aluno encontrado</p>
        {canEdit && (
          <a href="/dashboard/alunos/novo" class="text-primary hover:text-primary/80 text-sm">Cadastrar primeiro aluno →</a>
        )}
      </div>
    ) : (
      <div id="tabela-alunos">

        <!-- ── MOBILE: cards ─────────────────────────────────────── -->
        <div class="sm:hidden space-y-3" id="cards-alunos">
          {canEdit && (
            <label class="flex items-center gap-2.5 px-1 pb-1 text-sm text-zinc-400 cursor-pointer select-none">
              <input type="checkbox" id="chk-todos-mobile"
                class="h-4 w-4 rounded border-zinc-600 bg-zinc-800 text-primary focus:ring-primary/40 cursor-pointer" />
              Selecionar todos
            </label>
          )}
          {alunos.map((a: any) => {
            const planoAtivo = a.aluno_planos?.find((ap: any) => ap.status === 'ativo');
            const cat = a.categorias_alunos;
            return (
              <div class="aluno-row border border-zinc-700 rounded-xl bg-zinc-900/60 overflow-hidden active:bg-zinc-800/80"
                data-id={a.id} data-nome={a.nome} data-email={a.email ?? ''} data-cpf={a.cpf ?? ''}
                data-plano={planoAtivo?.planos?.nome ?? ''} data-categoria={cat?.nome ?? ''} data-status={a.status}>
                <div class="flex items-center gap-3 px-4 py-4">
                  {canEdit && (
                    <input type="checkbox" class="chk-aluno h-5 w-5 rounded border-zinc-600 bg-zinc-800 text-primary focus:ring-primary/40 cursor-pointer shrink-0"
                      data-id={a.id} />
                  )}
                  <!-- Avatar -->
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-base font-bold">
                    {a.nome.charAt(0).toUpperCase()}
                  </div>
                  <!-- Info -->
                  <div class="flex-1 min-w-0">
                    <div class="font-semibold text-white text-base leading-tight truncate">{a.nome}</div>
                    <div class="text-zinc-400 text-sm mt-0.5 truncate">{a.email}</div>
                    <div class="flex items-center gap-2 mt-2 flex-wrap">
                      <span class={`text-sm px-2.5 py-0.5 rounded-full font-medium ${statusCores[a.status] ?? ''}`}>
                        {a.status}
                      </span>
                      {planoAtivo && (
                        <span class="text-sm text-zinc-400">{planoAtivo.planos?.nome}</span>
                      )}
                      {cat && (
                        <span class="inline-flex items-center gap-1.5 text-sm text-zinc-500">
                          <span class="w-2 h-2 rounded-full shrink-0" style={`background:${cat.cor}`}></span>
                          {cat.nome}
                        </span>
                      )}
                    </div>
                  </div>
                  <!-- Ação -->
                  <a href={`/dashboard/alunos/${a.id}`}
                    class="shrink-0 flex items-center justify-center h-11 w-11 rounded-xl bg-zinc-800 border border-zinc-700 text-zinc-400 hover:text-white hover:border-zinc-500 transition-colors"
                    aria-label="Ver aluno">
                    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </div>
            );
          })}
        </div>

        <!-- ── DESKTOP: tabela ───────────────────────────────────── -->
        <div class="hidden sm:block border border-zinc-700 rounded-xl overflow-hidden">
          <table class="w-full">
            <thead>
              <tr class="border-b border-zinc-700 bg-zinc-900/60">
                {canEdit && (
                  <th class="px-4 py-3 w-10 no-print">
                    <input type="checkbox" id="chk-todos"
                      class="rounded border-zinc-600 bg-zinc-800 text-primary focus:ring-primary/40 cursor-pointer" />
                  </th>
                )}
                <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider">Aluno</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider hidden md:table-cell">Plano</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider hidden lg:table-cell">Modalidade</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-zinc-400 uppercase tracking-wider">Status</th>
                <th class="px-4 py-3 no-print w-16"></th>
              </tr>
            </thead>
            <tbody class="divide-y divide-zinc-800" id="tbody-alunos">
              {alunos.map((a: any) => {
                const planoAtivo = a.aluno_planos?.find((ap: any) => ap.status === 'ativo');
                const mods: string[] = (a.aluno_modalidades ?? []).map((m: any) => m.modalidade);
                return (
                  <tr class="hover:bg-zinc-800/40 transition-colors aluno-row"
                    data-id={a.id} data-nome={a.nome} data-email={a.email ?? ''} data-cpf={a.cpf ?? ''}
                    data-plano={planoAtivo?.planos?.nome ?? ''} data-modalidade={mods.join(', ')} data-status={a.status}>
                    {canEdit && (
                      <td class="px-4 py-3 w-10 no-print">
                        <input type="checkbox" class="chk-aluno rounded border-zinc-600 bg-zinc-800 text-primary focus:ring-primary/40 cursor-pointer"
                          data-id={a.id} />
                      </td>
                    )}
                    <td class="px-4 py-3">
                      <div class="font-medium text-white text-sm">{a.nome}</div>
                      <div class="text-zinc-500 text-xs">{a.email}</div>
                    </td>
                    <td class="px-4 py-3 hidden md:table-cell">
                      {planoAtivo ? (
                        <span class="text-sm text-zinc-300">{planoAtivo.planos?.nome}</span>
                      ) : (
                        <span class="text-xs text-zinc-600">Sem plano</span>
                      )}
                    </td>
                    <td class="px-4 py-3 hidden lg:table-cell">
                      {mods.length > 0 ? (
                        <div class="flex flex-wrap gap-1">
                          {mods.map(m => (
                            <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 border border-primary/20 text-primary font-medium">
                              {m}
                            </span>
                          ))}
                        </div>
                      ) : (
                        <span class="text-xs text-zinc-600">—</span>
                      )}
                    </td>
                    <td class="px-4 py-3">
                      <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${statusCores[a.status] ?? ''}`}>
                        {a.status}
                      </span>
                    </td>
                    <td class="px-4 py-3 text-right no-print">
                      <a href={`/dashboard/alunos/${a.id}`}
                        class="text-xs text-zinc-400 hover:text-white border border-zinc-700 hover:border-zinc-500 px-3 py-1.5 rounded-lg transition-colors whitespace-nowrap">
                        Ver
                      </a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>

      <!-- ── Paginador ─────────────────────────────────────────────────── -->
      {totalPages > 1 && (
        <div class="flex items-center justify-center gap-1.5 pt-4 pb-1 no-print">
          {paginaAtual > 1 ? (
            <a href={buildUrl(paginaAtual - 1)}
              class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-700 bg-zinc-900 text-zinc-400 hover:border-zinc-500 hover:text-white transition-colors">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
            </a>
          ) : (
            <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-800 text-zinc-700 cursor-not-allowed">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
            </span>
          )}
          {getPaginasBotoes(paginaAtual, totalPages).map(p =>
            p === '...' ? (
              <span class="flex h-9 w-9 items-center justify-center text-zinc-600 text-sm select-none">…</span>
            ) : p === paginaAtual ? (
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-primary text-black text-sm font-bold">
                {p}
              </span>
            ) : (
              <a href={buildUrl(p as number)}
                class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-700 bg-zinc-900 text-zinc-400 hover:border-zinc-500 hover:text-white text-sm transition-colors">
                {p}
              </a>
            )
          )}
          {paginaAtual < totalPages ? (
            <a href={buildUrl(paginaAtual + 1)}
              class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-700 bg-zinc-900 text-zinc-400 hover:border-zinc-500 hover:text-white transition-colors">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ) : (
            <span class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-800 text-zinc-700 cursor-not-allowed">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          )}
        </div>
      )}

      </div>
    )}

  </div>

  <!-- ── Barra flutuante de ações em massa ──────────────────────────────────── -->
  {canEdit && (
    <div id="bulk-bar"
      class="hidden fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-3 px-5 py-3 rounded-2xl bg-zinc-900 border border-zinc-700 shadow-2xl shadow-black/60 min-w-[340px]">
      <span id="bulk-count" class="text-sm font-semibold text-white shrink-0">0 selecionados</span>
      <div class="flex-1 h-px bg-zinc-700"></div>
      <button id="bulk-inativar"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-yellow-600/20 border border-yellow-600/30 text-yellow-400 hover:bg-yellow-600/30 text-xs font-semibold transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/>
        </svg>
        Inativar
      </button>
      <button id="bulk-excluir"
        class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-red-600/20 border border-red-600/30 text-red-400 hover:bg-red-600/30 text-xs font-semibold transition-colors">
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Excluir
      </button>
      <button id="bulk-cancelar"
        class="text-zinc-500 hover:text-white ml-1 transition-colors" title="Cancelar seleção">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  )}

  <!-- ── Modal de confirmação ───────────────────────────────────────────────── -->
  {canEdit && (
    <div id="modal-bulk"
      class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
      <div class="w-full max-w-sm rounded-2xl border border-zinc-700 bg-zinc-900 shadow-2xl p-6">
        <div id="modal-bulk-icon" class="flex h-12 w-12 items-center justify-center rounded-full mb-4 mx-auto"></div>
        <h3 id="modal-bulk-titulo" class="text-base font-bold text-white text-center mb-2"></h3>
        <p id="modal-bulk-desc" class="text-sm text-zinc-400 text-center mb-6 leading-relaxed"></p>
        <div class="flex gap-3">
          <button id="modal-bulk-cancelar"
            class="flex-1 px-4 py-2.5 rounded-xl border border-zinc-700 text-zinc-300 text-sm font-semibold hover:bg-zinc-800 transition-colors">
            Cancelar
          </button>
          <button id="modal-bulk-confirmar"
            class="flex-1 px-4 py-2.5 rounded-xl text-white text-sm font-semibold transition-colors">
            Confirmar
          </button>
        </div>
      </div>
    </div>
  )}

</DashboardLayout>

<style>
  @media print {
    .no-print { display: none !important; }
    body { background: white !important; color: black !important; }
    table { border-collapse: collapse; width: 100%; }
    th, td { border: 1px solid #ccc; padding: 8px; color: black !important; font-size: 12px; }
    th { background: #f5f5f5 !important; }
  }
</style>

<script>
  // ── Export helpers ───────────────────────────────────────────────────────────
  function getLinhas() {
    return Array.from(document.querySelectorAll<HTMLTableRowElement>('#tbody-alunos tr')).map(tr => ({
      nome:       tr.dataset.nome       ?? '',
      email:      tr.dataset.email      ?? '',
      cpf:        tr.dataset.cpf        ?? '',
      plano:      tr.dataset.plano      ?? '',
      modalidade: tr.dataset.modalidade ?? '',
      status:     tr.dataset.status     ?? '',
    }));
  }

  document.getElementById('btn-csv')?.addEventListener('click', () => {
    const linhas = getLinhas();
    const header = ['Nome', 'Email', 'CPF', 'Plano', 'Modalidade', 'Status'];
    const rows   = linhas.map(l =>
      [l.nome, l.email, l.cpf, l.plano, l.modalidade, l.status]
        .map(v => `"${v.replace(/"/g, '""')}"`)
        .join(',')
    );
    const csv  = [header.join(','), ...rows].join('\n');
    const blob = new Blob(['﻿' + csv], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href  = URL.createObjectURL(blob);
    link.download = `alunos-${new Date().toISOString().split('T')[0]}.csv`;
    link.click();
    URL.revokeObjectURL(link.href);
  });

  document.getElementById('btn-pdf')?.addEventListener('click', () => window.print());

  // ── Seleção em massa ─────────────────────────────────────────────────────────
  // Checkboxes "selecionar todos" — desktop (#chk-todos) e mobile (#chk-todos-mobile)
  const chkTodos       = document.getElementById('chk-todos')        as HTMLInputElement | null;
  const chkTodosMobile = document.getElementById('chk-todos-mobile') as HTMLInputElement | null;
  const bulkBar     = document.getElementById('bulk-bar')!;
  const bulkCount   = document.getElementById('bulk-count')!;
  const btnInativar = document.getElementById('bulk-inativar')!;
  const btnExcluir  = document.getElementById('bulk-excluir')!;
  const btnCancelar = document.getElementById('bulk-cancelar')!;
  const modal       = document.getElementById('modal-bulk')!;
  const modalIcon   = document.getElementById('modal-bulk-icon')!;
  const modalTitulo = document.getElementById('modal-bulk-titulo')!;
  const modalDesc   = document.getElementById('modal-bulk-desc')!;
  const modalCancel = document.getElementById('modal-bulk-cancelar')!;
  const modalOk     = document.getElementById('modal-bulk-confirmar')!;

  // Deduplica por data-id — mobile e desktop têm checkboxes separados para o mesmo aluno
  function getSelecionados(): string[] {
    const seen = new Set<string>();
    document.querySelectorAll<HTMLInputElement>('.chk-aluno:checked').forEach(c => {
      if (c.dataset.id) seen.add(c.dataset.id);
    });
    return [...seen];
  }

  function getTotalAlunos(): number {
    const seen = new Set<string>();
    document.querySelectorAll<HTMLInputElement>('.chk-aluno').forEach(c => {
      if (c.dataset.id) seen.add(c.dataset.id);
    });
    return seen.size;
  }

  function atualizarBarra() {
    const ids   = getSelecionados();
    const total = getTotalAlunos();

    if (ids.length === 0) {
      bulkBar.classList.add('hidden');
      [chkTodos, chkTodosMobile].forEach(c => {
        if (c) { c.indeterminate = false; c.checked = false; }
      });
    } else {
      bulkBar.classList.remove('hidden');
      bulkCount.textContent = `${ids.length} selecionado${ids.length > 1 ? 's' : ''}`;
      [chkTodos, chkTodosMobile].forEach(c => {
        if (!c) return;
        c.checked       = ids.length === total;
        c.indeterminate = ids.length > 0 && ids.length < total;
      });
    }
  }

  function selecionarTodos(checked: boolean) {
    document.querySelectorAll<HTMLInputElement>('.chk-aluno').forEach(c => c.checked = checked);
    atualizarBarra();
  }

  chkTodos?.addEventListener('change',       () => selecionarTodos(chkTodos.checked));
  chkTodosMobile?.addEventListener('change', () => selecionarTodos(chkTodosMobile.checked));

  document.querySelectorAll<HTMLInputElement>('.chk-aluno').forEach(c => {
    c.addEventListener('change', atualizarBarra);
  });

  btnCancelar?.addEventListener('click', () => {
    document.querySelectorAll<HTMLInputElement>('.chk-aluno').forEach(c => c.checked = false);
    [chkTodos, chkTodosMobile].forEach(c => { if (c) c.checked = false; });
    atualizarBarra();
  });

  // ── Modal de confirmação ─────────────────────────────────────────────────────
  let pendingAction: 'inativar' | 'excluir' | null = null;

  function abrirModal(action: 'inativar' | 'excluir') {
    const ids = getSelecionados();
    pendingAction = action;

    if (action === 'inativar') {
      modalIcon.className = 'flex h-12 w-12 items-center justify-center rounded-full mb-4 mx-auto bg-yellow-600/20 text-yellow-400';
      modalIcon.innerHTML = `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>`;
      modalTitulo.textContent = `Inativar ${ids.length} aluno${ids.length > 1 ? 's' : ''}?`;
      modalDesc.textContent   = 'Os alunos serão marcados como inativos e seus planos ativos serão cancelados. Esta ação pode ser revertida individualmente em cada cadastro.';
      modalOk.className = 'flex-1 px-4 py-2.5 rounded-xl text-white text-sm font-semibold transition-colors bg-yellow-600 hover:bg-yellow-500';
      modalOk.textContent = 'Inativar';
    } else {
      modalIcon.className = 'flex h-12 w-12 items-center justify-center rounded-full mb-4 mx-auto bg-red-600/20 text-red-400';
      modalIcon.innerHTML = `<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>`;
      modalTitulo.textContent = `Excluir ${ids.length} aluno${ids.length > 1 ? 's' : ''}?`;
      modalDesc.textContent   = `Esta ação é permanente e não pode ser desfeita. Todos os dados dos ${ids.length} aluno${ids.length > 1 ? 's' : ''} (check-ins, pagamentos, histórico) serão removidos.`;
      modalOk.className = 'flex-1 px-4 py-2.5 rounded-xl text-white text-sm font-semibold transition-colors bg-red-600 hover:bg-red-500';
      modalOk.textContent = 'Excluir definitivamente';
    }

    modal.classList.remove('hidden');
  }

  btnInativar?.addEventListener('click', () => abrirModal('inativar'));
  btnExcluir?.addEventListener('click',  () => abrirModal('excluir'));
  modalCancel?.addEventListener('click', () => { modal.classList.add('hidden'); pendingAction = null; });
  modal?.addEventListener('click', e => { if (e.target === modal) { modal.classList.add('hidden'); pendingAction = null; } });

  // Confirmar ação
  modalOk?.addEventListener('click', async () => {
    if (!pendingAction) return;
    const ids = getSelecionados();
    modal.classList.add('hidden');

    const btnOriginal = modalOk.textContent;
    modalOk.textContent = 'Aguarde...';
    (modalOk as HTMLButtonElement).disabled = true;

    try {
      const res  = await fetch('/api/alunos/bulk-action', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: pendingAction, ids }),
      });
      const data = await res.json();

      if (data.ok) {
        window.location.reload();
      } else {
        alert(`Erro: ${data.erro ?? 'Tente novamente.'}`);
      }
    } catch {
      alert('Erro de conexão. Tente novamente.');
    } finally {
      if (modalOk) { modalOk.textContent = btnOriginal; (modalOk as HTMLButtonElement).disabled = false; }
      pendingAction = null;
    }
  });
</script>
