---
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';
import { createAsaasClient } from '@/lib/asaas';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles').select('role, academia_id').eq('id', user.id).single();

if (!profile || profile.role !== 'dono') return Astro.redirect('/dashboard');

const admin = createSupabaseAdminClient();
const { data: academia } = await admin
  .from('academias')
  .select('id, nome, asaas_api_key, asaas_sandbox, asaas_webhook_token')
  .eq('id', profile.academia_id!)
  .single();

let sucesso = '';
let erro = '';

if (Astro.request.method === 'POST') {
  const form   = await Astro.request.formData();
  const action = form.get('action') as string;

  if (action === 'salvar_asaas') {
    const api_key       = (form.get('asaas_api_key') as string)?.trim();
    const sandbox       = form.get('asaas_sandbox') === 'true';
    const webhook_token = (form.get('asaas_webhook_token') as string)?.trim() || null;

    const cli = createAsaasClient(api_key, sandbox);
    const ok  = await cli.testarConexao();
    if (!ok) {
      erro = 'Chave inválida ou sem acesso à API Asaas. Verifique e tente novamente.';
    } else {
      await admin.from('academias')
        .update({ asaas_api_key: api_key, asaas_sandbox: sandbox, asaas_webhook_token: webhook_token })
        .eq('id', academia!.id);
      sucesso = 'Integração Asaas salva e testada com sucesso!';
    }
  }

  if (action === 'excluir_asaas') {
    await admin.from('academias')
      .update({ asaas_api_key: null, asaas_sandbox: true, asaas_webhook_token: null })
      .eq('id', academia!.id);
    sucesso = 'Integração Asaas removida com sucesso.';
  }

  if (action === 'adicionar_modalidade') {
    const nome = (form.get('modal_nome') as string)?.trim();
    const cor  = (form.get('modal_cor') as string)?.trim() || 'azul';
    if (nome) {
      const { data: ultima } = await supabase
        .from('modalidades').select('ordem').eq('academia_id', profile.academia_id!).order('ordem', { ascending: false }).limit(1).single();
      const proxOrdem = ((ultima as any)?.ordem ?? -1) + 1;
      const { error: mErr } = await supabase.from('modalidades').insert({
        academia_id: profile.academia_id,
        nome,
        cor,
        ordem: proxOrdem,
      });
      if (mErr) erro = mErr.message.includes('unique') ? `Modalidade "${nome}" já existe.` : mErr.message;
      else sucesso = `Modalidade "${nome}" criada com sucesso!`;
    }
  }

  if (action === 'excluir_modalidade') {
    const modal_id = form.get('modal_id') as string;
    await supabase.from('modalidades').delete().eq('id', modal_id).eq('academia_id', profile.academia_id!);
    sucesso = 'Modalidade removida.';
  }

  if (action === 'editar_modalidade') {
    const modal_id = form.get('modal_id') as string;
    const nome     = (form.get('modal_nome') as string)?.trim();
    const cor      = (form.get('modal_cor')  as string)?.trim() || 'azul';
    if (nome && modal_id) {
      const { error: mErr } = await supabase.from('modalidades')
        .update({ nome, cor })
        .eq('id', modal_id)
        .eq('academia_id', profile.academia_id!);
      if (mErr) erro = mErr.message.includes('unique') ? `Modalidade "${nome}" já existe.` : mErr.message;
      else sucesso = 'Modalidade atualizada com sucesso!';
    }
  }
}

// Recarrega após POST
const { data: acad } = await admin
  .from('academias').select('asaas_api_key, asaas_sandbox').eq('id', profile.academia_id!).single();

const temChave  = !!(acad?.asaas_api_key);
const isSandbox = acad?.asaas_sandbox !== false;
const chaveExibida = acad?.asaas_api_key
  ? acad.asaas_api_key.slice(0, 12) + '••••••••••••••••••••••••' + acad.asaas_api_key.slice(-4)
  : '';

// Modalidades da academia
const { data: modalidadesConfig } = await supabase
  .from('modalidades')
  .select('id, nome, cor, ativo')
  .eq('academia_id', profile.academia_id!)
  .order('ordem');

const CORES_OPCOES = [
  { valor: 'vermelho', label: 'Vermelho', classe: 'bg-red-500' },
  { valor: 'verde',    label: 'Verde',    classe: 'bg-green-500' },
  { valor: 'laranja',  label: 'Laranja',  classe: 'bg-orange-500' },
  { valor: 'azul',     label: 'Azul',     classe: 'bg-blue-500' },
  { valor: 'roxo',     label: 'Roxo',     classe: 'bg-purple-500' },
  { valor: 'amarelo',  label: 'Amarelo',  classe: 'bg-yellow-500' },
  { valor: 'rosa',     label: 'Rosa',     classe: 'bg-pink-500' },
  { valor: 'cinza',    label: 'Cinza',    classe: 'bg-zinc-500' },
];

const COR_BADGE: Record<string, string> = {
  vermelho: 'bg-primary/15 text-primary',
  verde:    'bg-green-500/15 text-green-400',
  laranja:  'bg-orange-500/15 text-orange-400',
  azul:     'bg-blue-500/15 text-blue-400',
  roxo:     'bg-purple-500/15 text-purple-400',
  amarelo:  'bg-yellow-500/15 text-yellow-400',
  rosa:     'bg-pink-500/15 text-pink-400',
  cinza:    'bg-zinc-500/15 text-zinc-400',
};

// Diagnóstico: alunos com plano ativo mas sem assinatura Asaas
let semSync = 0;
let totalAtivos = 0;
if (temChave) {
  const { data: apAtivos } = await admin
    .from('aluno_planos')
    .select('id, asaas_subscription_id, planos(valor)')
    .eq('academia_id', profile.academia_id!)
    .eq('status', 'ativo');

  if (apAtivos) {
    const comValor = apAtivos.filter(ap => Number((ap as any).planos?.valor ?? 0) > 0);
    totalAtivos = comValor.length;
    semSync = comValor.filter(ap => !ap.asaas_subscription_id).length;
  }
}
---

<DashboardLayout title="Configurações">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-foreground">Configurações</h1>
    <p class="mt-1 text-sm text-muted-foreground">Integrações e preferências da academia</p>
  </div>

  {sucesso && (
    <div class="mb-6 rounded-lg border border-green-600/30 bg-green-900/20 px-4 py-3 text-sm text-green-400">✓ {sucesso}</div>
  )}
  {erro && (
    <div class="mb-6 rounded-lg border border-red-600/30 bg-red-900/20 px-4 py-3 text-sm text-red-400">{erro}</div>
  )}

  <!-- Integração Asaas -->
  <div class="rounded-xl border border-border bg-card p-6 max-w-2xl">
    <div class="flex items-start gap-4 mb-6">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-blue-500/10 border border-blue-500/20">
        <svg class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
        </svg>
      </div>
      <div class="flex-1">
        <div class="flex items-center gap-2 flex-wrap">
          <h2 class="text-sm font-semibold text-foreground">Integração Asaas</h2>
          {temChave ? (
            <span class={`text-xs px-2 py-0.5 rounded-full border ${isSandbox ? 'border-yellow-500/30 text-yellow-400 bg-yellow-500/10' : 'border-green-600/30 text-green-400 bg-green-600/10'}`}>
              {isSandbox ? 'Sandbox' : 'Produção'}
            </span>
          ) : (
            <span class="text-xs px-2 py-0.5 rounded-full border border-zinc-700 text-zinc-500">Não configurado</span>
          )}
          <!-- Botão tutorial -->
          <button
            id="btn-tutorial-asaas"
            type="button"
            class="ml-auto flex items-center gap-1.5 text-xs text-blue-400 hover:text-blue-300 border border-blue-500/30 bg-blue-500/5 hover:bg-blue-500/10 rounded-lg px-2.5 py-1 transition-colors">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Ver tutorial passo a passo
          </button>
        </div>
        <p class="text-xs text-muted-foreground mt-1">
          Conecte sua conta Asaas para gerar cobranças automáticas (PIX, Boleto, Cartão) para os alunos ao atribuir planos.
        </p>
        {temChave && (
          <p class="text-xs text-zinc-500 mt-2 font-mono">{chaveExibida}</p>
        )}
      </div>
    </div>

    {temChave ? (
      <!-- Estado: conectado — apenas exibe info + botão de excluir -->
      <div class="space-y-4">
        <div class="rounded-lg border border-border bg-zinc-950/60 p-4 space-y-3">
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs text-muted-foreground">API Key</span>
            <span class="text-xs font-mono text-zinc-300">{chaveExibida}</span>
          </div>
          <div class="flex items-center justify-between gap-2">
            <span class="text-xs text-muted-foreground">Ambiente</span>
            <span class={`text-xs font-medium ${isSandbox ? 'text-yellow-400' : 'text-green-400'}`}>
              {isSandbox ? 'Sandbox (testes)' : 'Produção (real)'}
            </span>
          </div>
          {(acad as any)?.asaas_webhook_token && (
            <div class="flex items-center justify-between gap-2">
              <span class="text-xs text-muted-foreground">Webhook Token</span>
              <span class="text-xs text-green-400 flex items-center gap-1">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                Configurado
              </span>
            </div>
          )}
        </div>

        <form method="POST" id="form-excluir-asaas">
          <input type="hidden" name="action" value="excluir_asaas" />
          <button
            type="button"
            id="btn-excluir-asaas"
            class="flex items-center gap-2 rounded-lg border border-red-600/40 bg-red-900/10 px-4 py-2.5 text-sm font-medium text-red-400 hover:bg-red-900/20 hover:border-red-600/60 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
            </svg>
            Excluir integração
          </button>
        </form>
      </div>
    ) : (
      <!-- Estado: não configurado — exibe formulário de nova integração -->
      <form method="POST" class="space-y-4">
        <input type="hidden" name="action" value="salvar_asaas" />

        <div>
          <label class="block text-xs text-muted-foreground mb-1">
            API Key do Asaas
            <a href="https://www.asaas.com/config/permissoes" target="_blank"
              class="ml-1 text-primary hover:underline">onde encontrar →</a>
          </label>
          <input
            name="asaas_api_key"
            type="password"
            autocomplete="off"
            placeholder="$aact_..."
            required
            class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground font-mono focus:outline-none focus:ring-2 focus:ring-primary/50"
          />
        </div>

        <div>
          <label class="block text-xs text-muted-foreground mb-1">
            Token de autenticação do Webhook
            <span class="text-zinc-600 ml-1">(recomendado)</span>
          </label>
          <input
            name="asaas_webhook_token"
            type="text"
            autocomplete="off"
            placeholder="Cole aqui o token gerado no painel Asaas"
            class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground font-mono focus:outline-none focus:ring-2 focus:ring-primary/50"
          />
          <p class="text-xs text-zinc-600 mt-1">Gere em: Asaas → Configurações → Webhooks → Token de autenticação → Gerar Token.</p>
        </div>

        <div>
          <label class="block text-xs text-muted-foreground mb-2">Ambiente</label>
          <div class="flex gap-3">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="asaas_sandbox" value="true" checked class="accent-primary" />
              <span class="text-sm text-foreground">Sandbox <span class="text-xs text-muted-foreground">(testes)</span></span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="asaas_sandbox" value="false" class="accent-primary" />
              <span class="text-sm text-foreground">Produção <span class="text-xs text-muted-foreground">(real)</span></span>
            </label>
          </div>
        </div>

        <div class="pt-2">
          <button type="submit"
            class="rounded-lg bg-primary px-6 py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
            Salvar e testar conexão
          </button>
        </div>
      </form>
    )}

    {temChave && (
      <div class="mt-6 pt-5 border-t border-border">
        <h3 class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-3">Webhook Asaas</h3>
        <p class="text-xs text-zinc-400 mb-2">
          Configure no painel Asaas em <strong class="text-zinc-300">Configurações → Integrações → Webhooks</strong> com a URL abaixo para receber atualizações de pagamento automáticas:
        </p>
        <div class="flex items-center gap-2 rounded-lg bg-zinc-950 border border-zinc-800 px-3 py-2">
          <code class="text-xs text-primary flex-1 font-mono break-all">
            https://unafit.com.br/api/webhooks/asaas-academia
          </code>
          <button
            onclick="navigator.clipboard.writeText('https://unafit.com.br/api/webhooks/asaas-academia').then(()=>this.textContent='✓').catch(()=>{}); setTimeout(()=>this.textContent='Copiar',2000)"
            class="text-xs text-zinc-500 hover:text-primary shrink-0 transition-colors">
            Copiar
          </button>
        </div>
        <p class="text-xs text-zinc-600 mt-2">Eventos necessários: PAYMENT_CREATED, PAYMENT_RECEIVED, PAYMENT_CONFIRMED, PAYMENT_OVERDUE, PAYMENT_CANCELLED.</p>
      </div>
    )}
  </div>
  <!-- ── Diagnóstico Asaas ──────────────────────────────────────────────────── -->
  {temChave && (
    <div class="mt-4 rounded-xl border border-border bg-card p-5 max-w-2xl">
      <h3 class="text-sm font-semibold text-foreground mb-4 flex items-center gap-2">
        <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Diagnóstico da Integração
      </h3>

      <div class="grid grid-cols-2 gap-3 mb-5">
        <div class="rounded-lg bg-zinc-900 border border-zinc-800 p-3 text-center">
          <div class="text-2xl font-bold text-foreground">{totalAtivos}</div>
          <div class="text-xs text-muted-foreground mt-0.5">alunos com plano pago</div>
        </div>
        <div class={`rounded-lg border p-3 text-center ${semSync > 0 ? 'bg-yellow-900/20 border-yellow-600/30' : 'bg-green-900/20 border-green-600/30'}`}>
          <div class={`text-2xl font-bold ${semSync > 0 ? 'text-yellow-400' : 'text-green-400'}`}>{semSync}</div>
          <div class="text-xs text-muted-foreground mt-0.5">sem assinatura no Asaas</div>
        </div>
      </div>

      {semSync > 0 ? (
        <div class="rounded-lg border border-yellow-600/30 bg-yellow-900/10 px-4 py-3 mb-4">
          <p class="text-xs text-yellow-300 leading-relaxed">
            <strong>{semSync} aluno(s)</strong> têm plano ativo mas ainda não foram sincronizados no Asaas.
            Isso normalmente acontece quando a chave API foi configurada <em>depois</em> que os planos foram atribuídos,
            ou quando houve um erro anterior na criação da assinatura.
          </p>
        </div>
      ) : (
        <div class="rounded-lg border border-green-600/30 bg-green-900/10 px-4 py-3 mb-4">
          <p class="text-xs text-green-300">✓ Todos os alunos com plano pago estão sincronizados no Asaas.</p>
        </div>
      )}

      <div class="flex items-center gap-3 flex-wrap">
        {semSync > 0 && (
          <button
            id="btn-sync-asaas"
            type="button"
            class="flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90 transition-colors disabled:opacity-50">
            <svg id="sync-icon" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            Sincronizar {semSync} aluno(s) no Asaas
          </button>
        )}
        <a href="/dashboard/alunos" class="text-xs text-muted-foreground hover:text-foreground transition-colors">
          Ver alunos →
        </a>
      </div>

      <div id="sync-resultado" class="mt-3 hidden"></div>

      <div class="mt-5 pt-4 border-t border-border">
        <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">Como funciona a sincronização</p>
        <ul class="text-xs text-zinc-500 space-y-1 leading-relaxed">
          <li>→ O cliente Asaas é criado <strong class="text-zinc-400">automaticamente</strong> quando você atribui um plano a um aluno</li>
          <li>→ A cobrança mensal é gerada pelo Asaas e o aluno recebe o link de pagamento</li>
          <li>→ O webhook notifica o UNAFIT quando o pagamento é confirmado</li>
          <li>→ Use o botão acima para sincronizar alunos que foram adicionados antes da integração ser configurada</li>
        </ul>
      </div>
    </div>
  )}

  <!-- ── Modalidades de Aula ──────────────────────────────────────────────── -->
  <div class="mt-4 rounded-xl border border-border bg-card p-6 max-w-2xl">
    <div class="flex items-start gap-4 mb-5">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-primary/10 border border-primary/20">
        <svg class="h-5 w-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
        </svg>
      </div>
      <div class="flex-1">
        <h2 class="text-sm font-semibold text-foreground">Modalidades de Aula</h2>
        <p class="text-xs text-muted-foreground mt-1">
          Defina as modalidades disponíveis para criar aulas na agenda. Cada modalidade pode ter uma cor própria.
        </p>
      </div>
    </div>

    <!-- Lista de modalidades -->
    <div class="space-y-2 mb-5">
      {(modalidadesConfig ?? []).length === 0 ? (
        <p class="text-xs text-muted-foreground text-center py-4">Nenhuma modalidade cadastrada.</p>
      ) : (modalidadesConfig ?? []).map(m => (
        <div class="flex items-center justify-between gap-3 rounded-lg border border-border bg-muted/20 px-3 py-2.5">
          <div class="flex items-center gap-2.5">
            <span class:list={['rounded-md px-2.5 py-1 text-xs font-semibold', COR_BADGE[m.cor] ?? COR_BADGE['azul']]}>
              {m.nome}
            </span>
          </div>
          <div class="flex items-center gap-2">
            <button type="button"
              data-id={m.id}
              data-nome={m.nome}
              data-cor={m.cor}
              data-action="editar-modalidade"
              class="flex items-center gap-1 rounded-lg border border-zinc-700/50 bg-zinc-800/30 px-2.5 py-1.5 text-xs text-zinc-400 hover:bg-zinc-800/60 hover:text-zinc-200 transition-colors">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
              </svg>
              Editar
            </button>
            <form method="POST">
              <input type="hidden" name="action" value="excluir_modalidade" />
              <input type="hidden" name="modal_id" value={m.id} />
              <button type="submit"
                onclick={`return confirm('Remover a modalidade "${m.nome}"?\\nAulas já criadas não serão afetadas.')`}
                class="flex items-center gap-1 rounded-lg border border-red-700/30 bg-red-900/10 px-2.5 py-1.5 text-xs text-red-400 hover:bg-red-900/20 hover:border-red-600/40 transition-colors">
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                </svg>
                Remover
              </button>
            </form>
          </div>
        </div>
      ))}
    </div>

    <!-- Formulário para adicionar nova modalidade -->
    <div class="border-t border-border pt-5">
      <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-3">Adicionar Modalidade</p>
      <form method="POST" class="space-y-3">
        <input type="hidden" name="action" value="adicionar_modalidade" />
        <div class="flex gap-3">
          <input
            name="modal_nome"
            type="text"
            placeholder="Nome da modalidade (ex: Yoga, Natação...)"
            required
            maxlength="40"
            class="flex-1 rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
        <div>
          <label class="block text-xs text-muted-foreground mb-2">Cor</label>
          <div class="flex flex-wrap gap-2">
            {CORES_OPCOES.map((c, i) => (
              <label class="cursor-pointer" title={c.label}>
                <input type="radio" name="modal_cor" value={c.valor} class="sr-only peer" checked={i === 0} />
                <span class:list={[
                  'block h-7 w-7 rounded-full ring-2 ring-offset-2 ring-transparent ring-offset-card peer-checked:ring-white/80 peer-checked:scale-110 transition-all hover:scale-105',
                  c.classe
                ]}></span>
              </label>
            ))}
          </div>
        </div>
        <button type="submit"
          class="inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
          </svg>
          Adicionar Modalidade
        </button>
      </form>
    </div>
  </div>

  <!-- ── Modal Editar Modalidade ─────────────────────────────────────────── -->
  <div id="modal-editar-modalidade"
    class="hidden fixed inset-0 z-50 bg-black/70 backdrop-blur-sm">
    <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm rounded-2xl border border-zinc-700 bg-zinc-900 shadow-2xl">
      <div class="flex items-center justify-between px-5 py-4 border-b border-zinc-800">
        <h2 class="text-sm font-bold text-foreground">Editar Modalidade</h2>
        <button type="button" id="btn-fechar-editar-modal"
          class="text-zinc-500 hover:text-zinc-300 transition-colors p-1 rounded-lg hover:bg-zinc-800">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form method="POST" class="px-5 py-5 space-y-4">
        <input type="hidden" name="action" value="editar_modalidade" />
        <input type="hidden" name="modal_id" id="edit-modal-id" />
        <div>
          <label class="block text-xs text-muted-foreground mb-1">Nome</label>
          <input
            id="edit-modal-nome"
            name="modal_nome"
            type="text"
            required
            maxlength="40"
            class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
        <div>
          <label class="block text-xs text-muted-foreground mb-2">Cor</label>
          <div class="flex flex-wrap gap-2">
            {CORES_OPCOES.map(c => (
              <label class="cursor-pointer" title={c.label}>
                <input type="radio" name="modal_cor" value={c.valor} class="sr-only peer" />
                <span class:list={[
                  'block h-7 w-7 rounded-full ring-2 ring-offset-2 ring-transparent ring-offset-zinc-900 peer-checked:ring-white/80 peer-checked:scale-110 transition-all hover:scale-105',
                  c.classe
                ]}></span>
              </label>
            ))}
          </div>
        </div>
        <div class="flex gap-3 pt-1">
          <button type="submit"
            class="flex-1 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
            Salvar
          </button>
          <button type="button" id="btn-cancelar-editar-modal"
            class="flex-1 rounded-lg border border-border px-4 py-2.5 text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-muted/20 transition-colors">
            Cancelar
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ── Modal Tutorial Asaas ──────────────────────────────────────────────── -->
  <div id="modal-tutorial-asaas"
    class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/70 backdrop-blur-sm">
    <div class="relative w-full max-w-lg max-h-[90vh] flex flex-col rounded-2xl border border-zinc-700 bg-zinc-900 shadow-2xl">

      <!-- Header fixo -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-zinc-800 shrink-0">
        <div class="flex items-center gap-2.5">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-500/10 border border-blue-500/20">
            <svg class="h-4 w-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <div>
            <h2 class="text-sm font-bold text-foreground">Tutorial: Configurar o Asaas</h2>
            <p class="text-xs text-muted-foreground">Passo a passo para integrar os pagamentos</p>
          </div>
        </div>
        <button id="btn-fechar-tutorial" type="button"
          class="text-zinc-500 hover:text-zinc-300 transition-colors p-1 rounded-lg hover:bg-zinc-800">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <!-- Corpo com scroll -->
      <div class="overflow-y-auto px-6 py-5 space-y-6 text-sm">

        <!-- Intro -->
        <div class="rounded-xl border border-blue-500/20 bg-blue-500/5 px-4 py-3">
          <p class="text-blue-300 text-xs leading-relaxed">
            O <strong class="text-blue-200">Asaas</strong> é a plataforma de pagamentos que o UNAFIT usa para cobrar seus alunos via PIX, Boleto e Cartão. Siga os passos abaixo para conectar sua conta ao sistema.
          </p>
        </div>

        <!-- PASSO 1 -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-white text-xs font-bold shrink-0">1</span>
            <h3 class="text-sm font-semibold text-foreground">Crie sua conta no Asaas</h3>
          </div>
          <div class="ml-8 space-y-2 text-zinc-400 text-xs leading-relaxed">
            <p>Se você ainda não tem uma conta, acesse <strong class="text-zinc-200">www.asaas.com</strong> e clique em <em>"Criar conta grátis"</em>.</p>
            <div class="rounded-lg border border-zinc-800 bg-zinc-950/60 px-3 py-2.5">
              <p class="text-zinc-300 font-medium mb-1">Há dois ambientes:</p>
              <ul class="space-y-1">
                <li class="flex gap-2"><span class="text-yellow-400 shrink-0">⚠</span> <span><strong class="text-yellow-300">Sandbox</strong> — para testes. Nenhuma cobrança real é feita. Use enquanto está configurando.</span></li>
                <li class="flex gap-2"><span class="text-green-400 shrink-0">✓</span> <span><strong class="text-green-300">Produção</strong> — cobranças reais dos seus alunos. Ative apenas quando tudo estiver funcionando.</span></li>
              </ul>
            </div>
          </div>
        </div>

        <!-- PASSO 2 -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-white text-xs font-bold shrink-0">2</span>
            <h3 class="text-sm font-semibold text-foreground">Gere sua API Key (chave de acesso)</h3>
          </div>
          <ol class="ml-8 space-y-2 text-zinc-400 text-xs leading-relaxed list-none">
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">①</span> Faça login no painel Asaas.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">②</span> No menu lateral, clique em <strong class="text-zinc-200">Configurações</strong> (ícone de engrenagem).</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">③</span> Acesse <strong class="text-zinc-200">Integrações</strong> → <strong class="text-zinc-200">API Keys</strong>.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">④</span> Clique em <strong class="text-zinc-200">"Gerar nova chave"</strong> ou copie a chave já existente.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">⑤</span> A chave começa com <code class="bg-zinc-800 text-primary px-1 py-0.5 rounded font-mono">$aact_</code>. Copie-a e cole no campo <em>"API Key do Asaas"</em> aqui no UNAFIT.</li>
          </ol>
          <div class="ml-8 mt-2 rounded-lg border border-yellow-500/20 bg-yellow-500/5 px-3 py-2">
            <p class="text-yellow-300 text-xs">⚠ <strong>Atenção:</strong> A chave de Sandbox e a de Produção são <em>diferentes</em>. Use a chave certa para cada ambiente.</p>
          </div>
        </div>

        <!-- PASSO 3 -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-white text-xs font-bold shrink-0">3</span>
            <h3 class="text-sm font-semibold text-foreground">Gere o Token do Webhook</h3>
          </div>
          <p class="ml-8 text-zinc-500 text-xs mb-2">O Webhook avisa o UNAFIT quando um pagamento é confirmado. O Token garante que só o Asaas pode enviar essas notificações.</p>
          <ol class="ml-8 space-y-2 text-zinc-400 text-xs leading-relaxed list-none">
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">①</span> No painel Asaas, vá em <strong class="text-zinc-200">Configurações</strong> → <strong class="text-zinc-200">Integrações</strong> → <strong class="text-zinc-200">Webhooks</strong>.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">②</span> Clique em <strong class="text-zinc-200">"Adicionar webhook"</strong> ou edite o existente.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">③</span> No campo <strong class="text-zinc-200">"URL"</strong>, cole a URL abaixo:
              <div class="mt-1 rounded bg-zinc-950 border border-zinc-800 px-2 py-1.5 font-mono text-primary text-xs break-all select-all">
                https://unafit.com.br/api/webhooks/asaas-academia
              </div>
            </li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">④</span> Clique em <strong class="text-zinc-200">"Token de autenticação"</strong> → <strong class="text-zinc-200">"Gerar Token"</strong>.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">⑤</span> Copie o token gerado e cole no campo <em>"Token de autenticação do Webhook"</em> aqui no UNAFIT.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">⑥</span> Ative os seguintes eventos no webhook:
              <div class="mt-1 flex flex-wrap gap-1">
                {['PAYMENT_CREATED','PAYMENT_RECEIVED','PAYMENT_CONFIRMED','PAYMENT_OVERDUE','PAYMENT_CANCELLED'].map(e => (
                  <code class="bg-zinc-800 text-zinc-300 px-1.5 py-0.5 rounded text-xs font-mono">{e}</code>
                ))}
              </div>
            </li>
          </ol>
        </div>

        <!-- PASSO 4 -->
        <div>
          <div class="flex items-center gap-2 mb-3">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-white text-xs font-bold shrink-0">4</span>
            <h3 class="text-sm font-semibold text-foreground">Salve e teste a conexão</h3>
          </div>
          <ol class="ml-8 space-y-2 text-zinc-400 text-xs leading-relaxed list-none">
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">①</span> Aqui no UNAFIT, cole a <strong class="text-zinc-200">API Key</strong> e o <strong class="text-zinc-200">Token do Webhook</strong>.</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">②</span> Selecione o ambiente correto (<strong class="text-yellow-300">Sandbox</strong> para testes ou <strong class="text-green-300">Produção</strong>).</li>
            <li class="flex gap-2.5"><span class="text-primary shrink-0 font-bold">③</span> Clique em <strong class="text-zinc-200">"Salvar e testar conexão"</strong>.</li>
            <li class="flex gap-2.5"><span class="text-green-400 shrink-0">✓</span> Se aparecer a mensagem <em class="text-green-400">"Integração salva e testada com sucesso!"</em>, está tudo certo!</li>
          </ol>
        </div>

        <!-- Dúvidas -->
        <div class="rounded-xl border border-zinc-800 bg-zinc-950/60 px-4 py-3">
          <p class="text-xs text-zinc-500 leading-relaxed">
            Dúvidas sobre o Asaas? Acesse a
            <a href="https://docs.asaas.com" target="_blank" rel="noopener"
              class="text-blue-400 hover:text-blue-300 underline underline-offset-2">documentação oficial</a>
            ou o
            <a href="https://suporte.asaas.com" target="_blank" rel="noopener"
              class="text-blue-400 hover:text-blue-300 underline underline-offset-2">suporte do Asaas</a>.
          </p>
        </div>

      </div>

      <!-- Footer fixo -->
      <div class="shrink-0 px-6 py-4 border-t border-zinc-800">
        <button id="btn-fechar-tutorial-footer" type="button"
          class="w-full rounded-xl bg-primary py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
          Entendi, vou configurar agora
        </button>
      </div>
    </div>
  </div>

  <script>
    // Modal editar modalidade
    const modalEditar = document.getElementById('modal-editar-modalidade');

    function abrirEditarModalidade(btn: HTMLElement) {
      (document.getElementById('edit-modal-id') as HTMLInputElement).value   = btn.dataset.id ?? '';
      (document.getElementById('edit-modal-nome') as HTMLInputElement).value = btn.dataset.nome ?? '';
      const corRadio = modalEditar?.querySelector<HTMLInputElement>(`input[name="modal_cor"][value="${btn.dataset.cor}"]`);
      if (corRadio) corRadio.checked = true;
      modalEditar?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function fecharEditarModalidade() {
      modalEditar?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    document.querySelectorAll<HTMLElement>('[data-action="editar-modalidade"]').forEach(btn => {
      btn.addEventListener('click', () => abrirEditarModalidade(btn));
    });

    document.getElementById('btn-fechar-editar-modal')?.addEventListener('click', fecharEditarModalidade);
    document.getElementById('btn-cancelar-editar-modal')?.addEventListener('click', fecharEditarModalidade);
    modalEditar?.addEventListener('click', e => { if (e.target === modalEditar) fecharEditarModalidade(); });

    // Confirmação antes de excluir integração Asaas
    const btnExcluir = document.getElementById('btn-excluir-asaas');
    btnExcluir?.addEventListener('click', () => {
      if (confirm('Tem certeza que deseja excluir a integração com o Asaas?\n\nNovos alunos não gerarão cobranças automáticas e as assinaturas existentes não serão canceladas no Asaas.')) {
        (document.getElementById('form-excluir-asaas') as HTMLFormElement)?.submit();
      }
    });

    const modal  = document.getElementById('modal-tutorial-asaas')!;
    const open   = document.getElementById('btn-tutorial-asaas')!;
    const close1 = document.getElementById('btn-fechar-tutorial')!;
    const close2 = document.getElementById('btn-fechar-tutorial-footer')!;

    function abrirModal()  { modal.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
    function fecharModal() { modal.classList.add('hidden');    document.body.style.overflow = ''; }

    open.addEventListener('click',   abrirModal);
    close1.addEventListener('click', fecharModal);
    close2.addEventListener('click', fecharModal);
    modal.addEventListener('click',  e => { if (e.target === modal) fecharModal(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape') fecharModal(); });

    // Botão de sincronização Asaas
    const btnSync   = document.getElementById('btn-sync-asaas');
    const syncIcon  = document.getElementById('sync-icon');
    const syncRes   = document.getElementById('sync-resultado');

    btnSync?.addEventListener('click', async () => {
      (btnSync as HTMLButtonElement).disabled = true;
      (btnSync as HTMLButtonElement).textContent = 'Sincronizando...';
      syncIcon?.classList.add('animate-spin');

      try {
        const res  = await fetch('/api/asaas-sync', { method: 'POST' });
        const data = await res.json();

        if (syncRes) {
          syncRes.classList.remove('hidden');
          if (data.sincronizados > 0 && !data.erros?.length) {
            syncRes.innerHTML = `<div class="rounded-lg border border-green-600/30 bg-green-900/20 px-4 py-3 text-xs text-green-400">✓ ${data.sincronizados} aluno(s) sincronizados com sucesso! Recarregue a página para atualizar.</div>`;
          } else if (data.erros?.length) {
            const listaErros = (data.erros as string[]).map(e => `<li>${e}</li>`).join('');
            syncRes.innerHTML = `<div class="rounded-lg border border-red-600/30 bg-red-900/20 px-4 py-3 text-xs text-red-400"><strong>${data.sincronizados} sincronizados.</strong> Erros:<ul class="mt-1 list-disc list-inside space-y-0.5">${listaErros}</ul></div>`;
          } else {
            syncRes.innerHTML = `<div class="rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-3 text-xs text-zinc-400">Nenhum aluno precisava de sincronização.</div>`;
          }
        }
      } catch {
        if (syncRes) {
          syncRes.classList.remove('hidden');
          syncRes.innerHTML = `<div class="rounded-lg border border-red-600/30 bg-red-900/20 px-4 py-3 text-xs text-red-400">Erro ao conectar. Verifique a chave API e tente novamente.</div>`;
        }
      } finally {
        (btnSync as HTMLButtonElement).disabled = false;
        (btnSync as HTMLButtonElement).textContent = 'Tentar novamente';
        syncIcon?.classList.remove('animate-spin');
      }
    });
  </script>
</DashboardLayout>
