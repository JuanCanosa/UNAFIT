---
/**
 * /dashboard/financeiro/faturas
 * Faturas de todos os alunos — visível apenas para dono e saas_admin.
 * Professor NÃO acessa (conforme RULES.md §2).
 */
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import { createSupabaseServerClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || (profile.role !== 'dono' && profile.role !== 'saas_admin')) {
  return Astro.redirect('/dashboard');
}

// Filtro de mês via query param
const url      = new URL(Astro.request.url);
const filtroMes = url.searchParams.get('mes'); // ex: "2026-04"

// Busca faturas com dados do aluno
let query = supabase
  .from('faturas')
  .select(`
    id, valor, status, vencimento, pago_em, mes_referencia, descricao,
    profiles ( nome_completo, telefone )
  `)
  .eq('academia_id', profile.academia_id!)
  .order('vencimento', { ascending: false });

if (filtroMes) {
  query = query
    .gte('mes_referencia', filtroMes + '-01')
    .lte('mes_referencia', filtroMes + '-31');
}

const { data: faturas } = await query.limit(100);

// Totais
const totalPagas    = faturas?.filter(f => f.status === 'paga').length ?? 0;
const totalPendentes= faturas?.filter(f => f.status === 'pendente').length ?? 0;
const totalVencidas = faturas?.filter(f => f.status === 'vencida').length ?? 0;
const valorTotal    = faturas?.reduce((acc, f) => acc + Number(f.valor), 0) ?? 0;
const valorRecebido = faturas?.filter(f => f.status === 'paga').reduce((acc, f) => acc + Number(f.valor), 0) ?? 0;

const statusConfig: Record<string, { label: string; variant: 'success' | 'warning' | 'destructive' | 'muted' }> = {
  paga:      { label: 'Paga',      variant: 'success' },
  pendente:  { label: 'Pendente',  variant: 'warning' },
  vencida:   { label: 'Vencida',   variant: 'destructive' },
  cancelada: { label: 'Cancelada', variant: 'muted' },
};

function formatCurrency(v: number) {
  return v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
}
---

<DashboardLayout title="Faturas">

  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-foreground">Faturas</h1>
      <p class="mt-1 text-sm text-muted-foreground">Controle financeiro dos alunos</p>
    </div>

    <!-- Filtro de mês -->
    <form method="GET" class="flex items-center gap-2">
      <input
        name="mes" type="month"
        value={filtroMes ?? new Date().toISOString().slice(0, 7)}
        class="rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
      />
      <button type="submit"
        class="rounded-lg bg-muted px-4 py-2 text-sm font-medium text-foreground hover:bg-muted/70 transition-colors">
        Filtrar
      </button>
    </form>
  </div>

  <!-- Stats -->
  <div class="mb-6 grid grid-cols-2 sm:grid-cols-4 gap-4">
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Pagas</p>
      <p class="mt-1 text-2xl font-bold text-primary">{totalPagas}</p>
    </Card>
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Pendentes</p>
      <p class="mt-1 text-2xl font-bold text-warning">{totalPendentes}</p>
    </Card>
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Vencidas</p>
      <p class="mt-1 text-2xl font-bold text-destructive">{totalVencidas}</p>
    </Card>
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Recebido</p>
      <p class="mt-1 text-lg font-bold text-foreground">{formatCurrency(valorRecebido)}</p>
      <p class="text-xs text-muted-foreground">de {formatCurrency(valorTotal)}</p>
    </Card>
  </div>

  <!-- Tabela -->
  <Card>
    {!faturas || faturas.length === 0 ? (
      <p class="py-8 text-center text-sm text-muted-foreground">
        Nenhuma fatura encontrada{filtroMes ? ` para ${filtroMes}` : ''}.
      </p>
    ) : (
      <div class="overflow-x-auto -mx-5">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground">Aluno</th>
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground hidden sm:table-cell">Descrição</th>
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground hidden md:table-cell">Vencimento</th>
              <th class="px-5 pb-3 text-right text-xs font-semibold uppercase tracking-wider text-muted-foreground">Valor</th>
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground">Status</th>
            </tr>
          </thead>
          <tbody>
            {faturas.map((f) => {
              const aluno = (f.profiles as any)?.nome_completo ?? '—';
              const cfg   = statusConfig[f.status] ?? { label: f.status, variant: 'muted' as const };
              return (
                <tr class="border-b border-border/50 hover:bg-muted/30 transition-colors">
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-3">
                      <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">
                        {aluno.charAt(0).toUpperCase()}
                      </div>
                      <span class="font-medium text-foreground">{aluno}</span>
                    </div>
                  </td>
                  <td class="px-5 py-3 text-muted-foreground hidden sm:table-cell text-xs">
                    {f.descricao ?? '—'}
                  </td>
                  <td class="px-5 py-3 text-muted-foreground hidden md:table-cell">
                    {new Date(f.vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}
                  </td>
                  <td class="px-5 py-3 text-right font-semibold text-foreground">
                    {formatCurrency(Number(f.valor))}
                  </td>
                  <td class="px-5 py-3">
                    <Badge variant={cfg.variant}>{cfg.label}</Badge>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </Card>

</DashboardLayout>
