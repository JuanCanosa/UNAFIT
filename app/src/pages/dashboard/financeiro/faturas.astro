---
/**
 * /dashboard/financeiro/faturas
 * Faturas de todos os alunos — visível apenas para dono e saas_admin.
 * Professor NÃO acessa (conforme RULES.md §2).
 */
import DashboardLayout from '@/layouts/DashboardLayout.astro';
import Card from '@/components/ui/Card.astro';
import Badge from '@/components/ui/Badge.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '@/lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase
  .from('profiles')
  .select('role, academia_id')
  .eq('id', user.id)
  .single();

if (!profile || (profile.role !== 'dono' && profile.role !== 'saas_admin')) {
  return Astro.redirect('/dashboard');
}

const admin = createSupabaseAdminClient();

// ── Assinatura SaaS da própria academia ──────────────────────────────────────
const { data: assinatura } = profile.academia_id
  ? await admin
      .from('saas_assinaturas')
      .select('id, status, saas_planos(id, nome, valor)')
      .eq('academia_id', profile.academia_id)
      .maybeSingle()
  : { data: null };

const valorPlano  = Number((assinatura as any)?.saas_planos?.valor ?? 0);
const isCourtesy  = valorPlano === 0;

// Faturas SaaS — só para planos pagos
const primeiroDiaMes = new Date(new Date().getFullYear(), new Date().getMonth(), 1).toISOString().split('T')[0];
const { data: faturasSaas } = (!isCourtesy && profile.academia_id)
  ? await admin
      .from('saas_faturas')
      .select('id, descricao, valor, data_vencimento, status, invoice_url, boleto_url, boleto_linha, pix_qr_code_base64, pix_copia_cola, asaas_payment_id')
      .eq('academia_id', profile.academia_id)
      .neq('status', 'cancelado')
      .or(`data_vencimento.gte.${primeiroDiaMes},status.in.(pago,vencido)`)
      .order('data_vencimento', { ascending: false })
      .limit(6)
  : { data: null };

// Filtro de mês via query param
const url      = new URL(Astro.request.url);
const filtroMes = url.searchParams.get('mes'); // ex: "2026-04"

// Busca faturas com dados do aluno
let query = supabase
  .from('faturas')
  .select(`
    id, valor, status, vencimento, pago_em, mes_referencia, descricao,
    profiles ( nome_completo, telefone )
  `)
  .eq('academia_id', profile.academia_id!)
  .order('vencimento', { ascending: false });

if (filtroMes) {
  query = query
    .gte('mes_referencia', filtroMes + '-01')
    .lte('mes_referencia', filtroMes + '-31');
}

const { data: faturas } = await query.limit(100);

// Totais
const totalPagas    = faturas?.filter(f => f.status === 'paga').length ?? 0;
const totalPendentes= faturas?.filter(f => f.status === 'pendente').length ?? 0;
const totalVencidas = faturas?.filter(f => f.status === 'vencida').length ?? 0;
const valorTotal    = faturas?.reduce((acc, f) => acc + Number(f.valor), 0) ?? 0;
const valorRecebido = faturas?.filter(f => f.status === 'paga').reduce((acc, f) => acc + Number(f.valor), 0) ?? 0;

const statusConfig: Record<string, { label: string; variant: 'success' | 'warning' | 'destructive' | 'muted' }> = {
  paga:      { label: 'Paga',      variant: 'success' },
  pendente:  { label: 'Pendente',  variant: 'warning' },
  vencida:   { label: 'Vencida',   variant: 'destructive' },
  cancelada: { label: 'Cancelada', variant: 'muted' },
};

function formatCurrency(v: number) {
  return v.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
}
---

<DashboardLayout title="Faturas">

  <!-- ── Assinatura UNAFIT (só para planos pagos) ──────────────────────────── -->
  {!isCourtesy && assinatura && (
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-3">
        <h2 class="text-sm font-semibold text-foreground uppercase tracking-wider">Assinatura UNAFIT</h2>
        <span class={`text-xs px-2 py-0.5 rounded-full border ${
          assinatura.status === 'ativa'    ? 'border-green-600/30 text-green-400 bg-green-600/10' :
          assinatura.status === 'trial'    ? 'border-yellow-500/30 text-yellow-400 bg-yellow-500/10' :
          assinatura.status === 'suspensa' ? 'border-red-600/30 text-red-400 bg-red-600/10' :
          'border-border text-muted-foreground'
        }`}>
          {(assinatura as any).saas_planos?.nome ?? 'Plano'} · {assinatura.status}
        </span>
      </div>

      {!faturasSaas || faturasSaas.length === 0 ? (
        <div class="rounded-xl border border-border bg-card px-5 py-4 text-sm text-muted-foreground">
          Nenhuma fatura de assinatura encontrada.
        </div>
      ) : (
        <div class="space-y-3">
          {faturasSaas.map((f: any) => {
            const venceu = new Date(f.data_vencimento + 'T12:00:00') < new Date() && f.status !== 'pago';
            return (
              <div class={`rounded-xl border bg-card overflow-hidden ${
                f.status === 'pago'    ? 'border-green-600/20' :
                venceu || f.status === 'vencido' ? 'border-red-600/30' :
                'border-yellow-500/20'
              }`}>
                <!-- Linha de resumo -->
                <div class="flex items-center gap-3 px-4 py-3">
                  <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-foreground truncate">{f.descricao}</p>
                    <p class="text-xs text-muted-foreground mt-0.5">
                      Vence: {new Date(f.data_vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}
                    </p>
                  </div>
                  <span class="font-bold text-foreground shrink-0">
                    {Number(f.valor).toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' })}
                  </span>
                  <span class={`shrink-0 text-xs px-2 py-0.5 rounded-full border ${
                    f.status === 'pago'    ? 'border-green-600/30 text-green-400 bg-green-600/10' :
                    f.status === 'vencido' ? 'border-red-600/30 text-red-400 bg-red-600/10' :
                    venceu                 ? 'border-red-600/30 text-red-400 bg-red-600/10' :
                    'border-yellow-500/30 text-yellow-400 bg-yellow-500/10'
                  }`}>
                    {f.status === 'pago' ? 'pago' : venceu ? 'vencido' : 'pendente'}
                  </span>
                </div>

                <!-- Opções de pagamento (só se não pago) -->
                {f.status !== 'pago' && f.asaas_payment_id && (
                  <div class="border-t border-border/50 px-4 py-3 bg-black/10 space-y-3">
                    {f.invoice_url && (
                      <a href={f.invoice_url} target="_blank"
                        class="flex items-center justify-center gap-2 w-full rounded-lg bg-primary py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                        Pagar agora (PIX · Boleto · Cartão)
                      </a>
                    )}
                    <div class="grid sm:grid-cols-2 gap-3">
                      {f.pix_qr_code_base64 && (
                        <div class="rounded-lg border border-zinc-800 p-3 text-center space-y-2">
                          <p class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">PIX</p>
                          <img src={`data:image/png;base64,${f.pix_qr_code_base64}`}
                            alt="QR Code PIX" class="h-28 w-28 mx-auto rounded" />
                          {f.pix_copia_cola && (
                            <button id={`pix-${f.id}`}
                              onclick={`navigator.clipboard.writeText('${f.pix_copia_cola}').then(()=>{var b=document.getElementById('pix-${f.id}');b.textContent='Copiado!';setTimeout(()=>b.textContent='Copiar código PIX',2000)})`}
                              class="w-full py-1.5 text-xs rounded border border-zinc-700 text-zinc-400 hover:text-primary hover:border-primary/40 transition-colors">
                              Copiar código PIX
                            </button>
                          )}
                        </div>
                      )}
                      {f.boleto_linha && (
                        <div class="rounded-lg border border-zinc-800 p-3 space-y-2">
                          <p class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">Boleto</p>
                          <p class="text-[10px] font-mono text-zinc-500 break-all leading-relaxed">{f.boleto_linha}</p>
                          <button id={`bol-${f.id}`}
                            onclick={`navigator.clipboard.writeText('${f.boleto_linha}').then(()=>{var b=document.getElementById('bol-${f.id}');b.textContent='Copiado!';setTimeout(()=>b.textContent='Copiar código',2000)})`}
                            class="w-full py-1.5 text-xs rounded border border-zinc-700 text-zinc-400 hover:text-primary hover:border-primary/40 transition-colors">
                            Copiar código de barras
                          </button>
                          {f.boleto_url && (
                            <a href={f.boleto_url} target="_blank"
                              class="block text-center text-xs text-primary hover:underline">
                              Ver boleto (PDF)
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      )}
    </div>
  )}

  <!-- ── Faturas dos alunos ─────────────────────────────────────────────────── -->
  <div class="mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h1 class="text-2xl font-bold text-foreground">Faturas</h1>
      <p class="mt-1 text-sm text-muted-foreground">Controle financeiro dos alunos</p>
    </div>

    <!-- Filtro de mês -->
    <form method="GET" class="flex items-center gap-2">
      <input
        name="mes" type="month"
        value={filtroMes ?? new Date().toISOString().slice(0, 7)}
        class="rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
      />
      <button type="submit"
        class="rounded-lg bg-muted px-4 py-2 text-sm font-medium text-foreground hover:bg-muted/70 transition-colors">
        Filtrar
      </button>
    </form>
  </div>

  <!-- Stats -->
  <div class="mb-6 grid grid-cols-2 sm:grid-cols-4 gap-4">
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Pagas</p>
      <p class="mt-1 text-2xl font-bold text-primary">{totalPagas}</p>
    </Card>
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Pendentes</p>
      <p class="mt-1 text-2xl font-bold text-warning">{totalPendentes}</p>
    </Card>
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Vencidas</p>
      <p class="mt-1 text-2xl font-bold text-destructive">{totalVencidas}</p>
    </Card>
    <Card>
      <p class="text-xs font-medium text-muted-foreground uppercase tracking-wider">Recebido</p>
      <p class="mt-1 text-lg font-bold text-foreground">{formatCurrency(valorRecebido)}</p>
      <p class="text-xs text-muted-foreground">de {formatCurrency(valorTotal)}</p>
    </Card>
  </div>

  <!-- Tabela -->
  <Card>
    {!faturas || faturas.length === 0 ? (
      <p class="py-8 text-center text-sm text-muted-foreground">
        Nenhuma fatura encontrada{filtroMes ? ` para ${filtroMes}` : ''}.
      </p>
    ) : (
      <div class="overflow-x-auto -mx-5">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border">
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground">Aluno</th>
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground hidden sm:table-cell">Descrição</th>
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground hidden md:table-cell">Vencimento</th>
              <th class="px-5 pb-3 text-right text-xs font-semibold uppercase tracking-wider text-muted-foreground">Valor</th>
              <th class="px-5 pb-3 text-left text-xs font-semibold uppercase tracking-wider text-muted-foreground">Status</th>
            </tr>
          </thead>
          <tbody>
            {faturas.map((f) => {
              const aluno = (f.profiles as any)?.nome_completo ?? '—';
              const cfg   = statusConfig[f.status] ?? { label: f.status, variant: 'muted' as const };
              return (
                <tr class="border-b border-border/50 hover:bg-muted/30 transition-colors">
                  <td class="px-5 py-3">
                    <div class="flex items-center gap-3">
                      <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-primary/15 text-primary text-xs font-bold">
                        {aluno.charAt(0).toUpperCase()}
                      </div>
                      <span class="font-medium text-foreground">{aluno}</span>
                    </div>
                  </td>
                  <td class="px-5 py-3 text-muted-foreground hidden sm:table-cell text-xs">
                    {f.descricao ?? '—'}
                  </td>
                  <td class="px-5 py-3 text-muted-foreground hidden md:table-cell">
                    {new Date(f.vencimento + 'T12:00:00').toLocaleDateString('pt-BR')}
                  </td>
                  <td class="px-5 py-3 text-right font-semibold text-foreground">
                    {formatCurrency(Number(f.valor))}
                  </td>
                  <td class="px-5 py-3">
                    <Badge variant={cfg.variant}>{cfg.label}</Badge>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    )}
  </Card>

</DashboardLayout>
