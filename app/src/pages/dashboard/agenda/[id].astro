          {wods.map(w => (
            <label class="flex items-center gap-3 rounded-lg border border-border p-3 cursor-pointer hover:border-primary/30 transition-colors has-[:checked]:border-primary has-[:checked]:bg-primary/5">
              <input type="radio" name="wod_id" value={w.id} class="accent-primary" checked={wod?.id === w.id} />
              <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-foreground">{w.nome}</p>
