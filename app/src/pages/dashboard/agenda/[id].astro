<!-- Modal Adicionar Exercício -->
<div id="modal-ex" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4">
  <div class="w-full max-w-md rounded-xl border border-border bg-card p-6 shadow-2xl">
    <div class="mb-1 flex items-center justify-between">
      <h2 class="text-lg font-bold text-foreground">Adicionar Exercício</h2>
      <button id="ex-close" class="text-muted-foreground hover:text-foreground">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    <p id="label-secao" class="mb-4 text-sm text-muted-foreground"></p>

    <div id="step-busca" class="space-y-3">
      <div>
        <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Nome do Exercício</label>
        <input id="ex-busca" type="text" placeholder="Buscar ou criar..."
          autocomplete="off"
          class="w-full rounded-lg border border-border bg-background px-3 py-2.5 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
        />
      </div>
      <div id="ex-resultados" class="hidden space-y-1 max-h-44 overflow-y-auto rounded-lg border border-border bg-background p-1"></div>
      <div id="ex-selecionado" class="hidden rounded-lg border border-primary/30 bg-primary/10 px-3 py-2">
        <p class="text-xs text-primary font-semibold uppercase tracking-wider">Selecionado</p>
        <p id="ex-sel-nome" class="text-sm font-bold text-foreground mt-0.5"></p>
        <p id="ex-sel-novo" class="hidden text-xs text-muted-foreground">Será criado automaticamente</p>
      </div>
    </div>

    <form id="form-ex" class="hidden space-y-3 mt-4">
      <input type="hidden" id="ex-secao-h" name="secao" />
      <input type="hidden" id="ex-id-h" name="exercicio_id" />
      <input type="hidden" id="ex-nome-novo-h" name="novo_nome" />
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Repetições</label>
          <input name="repeticoes" type="text" placeholder='ex: "3x5", "21-15-9"'
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Carga</label>
          <input name="carga" type="text" placeholder='ex: "43kg", "70% 1RM"'
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Distância</label>
          <input name="distancia" type="text" placeholder='ex: "400m", "5km"'
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-1.5">Observação</label>
          <input name="observacao" type="text" placeholder='ex: "ritmo forte"'
            class="w-full rounded-lg border border-border bg-background px-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary"
          />
        </div>
      </div>
      <p id="ex-form-error" class="hidden text-xs text-destructive"></p>
      <div class="flex gap-3 pt-1">
        <button type="button" id="ex-voltar"
          class="flex-1 rounded-lg border border-border px-4 py-2 text-sm font-medium text-muted-foreground hover:bg-muted transition-colors">
          Voltar
        </button>
        <button type="submit"
          class="flex-1 rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors disabled:opacity-50">
          Adicionar
        </button>
      </div>
    </form>
  </div>
</div>

<script define:vars={{ aulaId }}>
  function initModals() {
  // ── Modal Editar Aula ──────────────────────────────────
  const modalEditarAula    = document.getElementById('modal-editar-aula');
  const btnEditarAula      = document.getElementById('btn-editar-aula');
  const editarAulaClose    = document.getElementById('editar-aula-close');
  const editarAulaCancelar = document.getElementById('editar-aula-cancelar');

  function openEditarAula()  { if (!modalEditarAula) return; modalEditarAula.classList.remove('hidden'); modalEditarAula.classList.add('flex'); }
  function closeEditarAula() { if (!modalEditarAula) return; modalEditarAula.classList.add('hidden');    modalEditarAula.classList.remove('flex'); }

  btnEditarAula?.addEventListener('click', openEditarAula);
  editarAulaClose?.addEventListener('click', closeEditarAula);
  editarAulaCancelar?.addEventListener('click', closeEditarAula);
  modalEditarAula?.addEventListener('click', (e) => { if (e.target === modalEditarAula) closeEditarAula(); });

  // ── Modal Vincular WOD ─────────────────────────────────
  const modalWod     = document.getElementById('modal-vincular-wod');
  const btnVincular  = document.getElementById('btn-vincular-wod');
  const btnVinEmpty  = document.getElementById('btn-vincular-wod-empty');
  const wodLinkClose = document.getElementById('wod-link-close');
  const wodLinkCancel= document.getElementById('wod-link-cancel');

  function openWodModal()  { if (!modalWod) return; modalWod.classList.remove('hidden'); modalWod.classList.add('flex'); }
  function closeWodModal() { if (!modalWod) return; modalWod.classList.add('hidden');    modalWod.classList.remove('flex'); }

  btnVincular?.addEventListener('click', openWodModal);
  btnVinEmpty?.addEventListener('click', openWodModal);
  wodLinkClose?.addEventListener('click', closeWodModal);
  wodLinkCancel?.addEventListener('click', closeWodModal);
  modalWod?.addEventListener('click', (e) => { if (e.target === modalWod) closeWodModal(); });

  // ── Modal Adicionar Exercício ───────────────────────────
  const modalEx   = document.getElementById('modal-ex');
  const exBusca   = document.getElementById('ex-busca');
  const exResuls  = document.getElementById('ex-resultados');
  const exSel     = document.getElementById('ex-selecionado');
  const exSelNome = document.getElementById('ex-sel-nome');
  const exSelNovo = document.getElementById('ex-sel-novo');
  const labelSec  = document.getElementById('label-secao');
  const stepBusca = document.getElementById('step-busca');
  const formEx    = document.getElementById('form-ex');
  const exSecaoH  = document.getElementById('ex-secao-h');
  const exIdH     = document.getElementById('ex-id-h');
  const exNomeH   = document.getElementById('ex-nome-novo-h');
  const exErrP    = document.getElementById('ex-form-error');

  const secoesLabels = { aquecimento: 'Aquecimento', wod: 'WOD' };

  function openExModal(secao) {
    exSecaoH.value = secao;
    labelSec.textContent = `Seção: ${secoesLabels[secao]}`;
    resetExModal();
    modalEx.classList.remove('hidden');
    modalEx.classList.add('flex');
    setTimeout(() => exBusca.focus(), 50);
  }
  function closeExModal() { modalEx.classList.add('hidden'); modalEx.classList.remove('flex'); }
  function resetExModal() {
    exBusca.value = '';
    exResuls.classList.add('hidden'); exResuls.innerHTML = '';
    exSel.classList.add('hidden');
    formEx.classList.add('hidden');
    stepBusca.classList.remove('hidden');
    exErrP.classList.add('hidden');
    formEx.reset();
  }

  document.querySelectorAll('.btn-add-ex').forEach(btn => {
    btn.addEventListener('click', () => openExModal(btn.dataset.secao));
  });
  document.getElementById('ex-close').addEventListener('click', closeExModal);
  modalEx.addEventListener('click', (e) => { if (e.target === modalEx) closeExModal(); });

  // Live search
  let timer = null;
  exBusca.addEventListener('input', () => {
    clearTimeout(timer);
    const q = exBusca.value.trim();
    if (!q) { exResuls.classList.add('hidden'); return; }
    timer = setTimeout(() => buscar(q), 250);
  });

  async function buscar(q) {
    const res  = await fetch(`/api/exercicios/buscar?q=${encodeURIComponent(q)}`);
    const data = await res.json();
    exResuls.innerHTML = '';
    exResuls.classList.remove('hidden');
    for (const ex of data.exercicios ?? []) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'w-full text-left px-3 py-2 text-sm rounded-md hover:bg-primary/10 hover:text-primary transition-colors text-foreground';
      btn.textContent = ex.nome;
      btn.onclick = () => selecionar(ex.id, ex.nome, false);
      exResuls.appendChild(btn);
    }
    const exato = data.exercicios?.some(e => e.nome.toLowerCase() === q.toLowerCase());
    if (!exato) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'w-full text-left px-3 py-2 text-sm rounded-md border border-dashed border-primary/40 text-primary hover:bg-primary/10 transition-colors flex items-center gap-2 mt-1';
      btn.innerHTML = `<svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg> Criar "${q}"`;
      btn.onclick = () => selecionar(null, q, true);
      exResuls.appendChild(btn);
    }
  }

  function selecionar(id, nome, isNovo) {
    exResuls.classList.add('hidden');
    exSel.classList.remove('hidden');
    exSelNome.textContent = nome;
    exSelNovo.classList.toggle('hidden', !isNovo);
    exIdH.value   = id ?? '';
    exNomeH.value = isNovo ? nome : '';
    formEx.classList.remove('hidden');
  }

  document.getElementById('ex-voltar').addEventListener('click', () => {
    exSel.classList.add('hidden');
    formEx.classList.add('hidden');
    exBusca.value = '';
  });

  // ── Paginação do check-in (10 por página) ─────────────
  const PAG_SIZE   = 10;
  let pagAtual     = 1;

  const pagContainer = document.getElementById('checkin-pag');
  const pagInfo      = document.getElementById('pag-info');
  const pagBotoes    = document.getElementById('pag-botoes');

  function getAllItems(): HTMLElement[] {
    return Array.from(document.querySelectorAll<HTMLElement>('.checkin-item'));
  }

  function getVisibleItems(): HTMLElement[] {
    return getAllItems().filter(el => el.style.display !== 'none' || !el.dataset.hidden);
  }

  function renderPagina(items: HTMLElement[], pagina: number) {
    const total = items.length;
    const totalPags = Math.ceil(total / PAG_SIZE);
    const start = (pagina - 1) * PAG_SIZE;
    const end   = start + PAG_SIZE;

    // Mostra/oculta itens
    items.forEach((el, i) => {
      el.style.display = (i >= start && i < end) ? '' : 'none';
    });

    // Atualiza paginador
    if (!pagContainer || !pagInfo || !pagBotoes) return;

    if (totalPags <= 1) {
      pagContainer.classList.add('hidden');
      return;
    }
    pagContainer.classList.remove('hidden');
    pagInfo.textContent = `${start + 1}–${Math.min(end, total)} de ${total} alunos`;

    pagBotoes.innerHTML = '';

    // Botão anterior
    const btnPrev = document.createElement('button');
    btnPrev.type = 'button';
    btnPrev.className = `flex h-7 w-7 items-center justify-center rounded border text-xs transition-colors ${pagina <= 1 ? 'border-border/30 text-muted-foreground/30 cursor-not-allowed' : 'border-border text-muted-foreground hover:text-foreground hover:border-border/80'}`;
    btnPrev.innerHTML = '‹';
    btnPrev.disabled = pagina <= 1;
    btnPrev.onclick = () => irPara(pagina - 1, items);
    pagBotoes.appendChild(btnPrev);

    // Páginas
    for (let p = 1; p <= totalPags; p++) {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = String(p);
      btn.className = `flex h-7 w-7 items-center justify-center rounded border text-xs font-medium transition-colors ${p === pagina ? 'border-primary bg-primary/10 text-primary' : 'border-border text-muted-foreground hover:text-foreground hover:border-border/80'}`;
      btn.onclick = () => irPara(p, items);
      pagBotoes.appendChild(btn);
    }

    // Botão próximo
    const btnNext = document.createElement('button');
    btnNext.type = 'button';
    btnNext.className = `flex h-7 w-7 items-center justify-center rounded border text-xs transition-colors ${pagina >= totalPags ? 'border-border/30 text-muted-foreground/30 cursor-not-allowed' : 'border-border text-muted-foreground hover:text-foreground hover:border-border/80'}`;
    btnNext.innerHTML = '›';
    btnNext.disabled = pagina >= totalPags;
    btnNext.onclick = () => irPara(pagina + 1, items);
    pagBotoes.appendChild(btnNext);
  }

  function irPara(p: number, items: HTMLElement[]) {
    pagAtual = p;
    renderPagina(items, pagAtual);
  }

  // Inicializa paginação com todos os itens
  const todosItens = getAllItems();
  if (todosItens.length > PAG_SIZE) renderPagina(todosItens, 1);

  // ── Busca rápida na lista de check-in ─────────────────
  const checkinBusca = document.getElementById('checkin-busca');
  checkinBusca?.addEventListener('input', () => {
    const q = checkinBusca.value.toLowerCase().trim();
    const todos = getAllItems();
    if (!q) {
      // Sem busca: restaura paginação
      todos.forEach(el => el.removeAttribute('style'));
      pagAtual = 1;
      if (todos.length > PAG_SIZE) renderPagina(todos, 1);
      else if (pagContainer) pagContainer.classList.add('hidden');
    } else {
      // Com busca: mostra todos que batem, oculta paginador
      todos.forEach(el => {
        el.style.display = el.dataset.nome?.includes(q) ? '' : 'none';
      });
      if (pagContainer) pagContainer.classList.add('hidden');
    }
  });

  formEx.addEventListener('submit', async (e) => {
    e.preventDefault();
    exErrP.classList.add('hidden');
    const btn = formEx.querySelector('button[type="submit"]');
    btn.disabled = true; btn.textContent = 'Salvando...';
    const fd   = new FormData(formEx);
    const body = {
      aula_id:      aulaId,
      secao:        fd.get('secao'),
      exercicio_id: fd.get('exercicio_id') || null,
      novo_nome:    fd.get('novo_nome') || null,
      repeticoes:   fd.get('repeticoes') || null,
      carga:        fd.get('carga') || null,
      distancia:    fd.get('distancia') || null,
      observacao:   fd.get('observacao') || null,
    };
    const res  = await fetch('/api/aula-exercicios/adicionar', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const json = await res.json();
    if (res.ok) {
      window.location.reload();
    } else {
      exErrP.textContent = json.error ?? 'Erro ao adicionar.';
      exErrP.classList.remove('hidden');
      btn.disabled = false; btn.textContent = 'Adicionar';
    }
  });
    // Modal resultados da turma
    const modalResultado = document.getElementById('modal-resultado-turma');
    if (modalResultado) {
      const btnAdd    = document.getElementById('btn-add-resultado');
      const btnFechar = document.getElementById('btn-fechar-resultado');

      function abrirModalResultado() {
        modalResultado.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function fecharModalResultado() {
        modalResultado.classList.add('hidden');
        document.body.style.overflow = '';
      }

      btnAdd?.addEventListener('click', abrirModalResultado);
      btnFechar?.addEventListener('click', fecharModalResultado);
      modalResultado.addEventListener('click', e => {
        if (e.target === modalResultado) fecharModalResultado();
      });
    }
  } // fim initModals

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initModals);
  } else {
    initModals();
  }
</script>

</DashboardLayout>
