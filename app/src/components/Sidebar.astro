---
import type { UserRole } from '@/types/database';

interface Props {
  role: UserRole;
  nomeCompleto: string;
  currentPath: string;
  academiaLogoUrl?: string | null;
  academiaNome?: string;
  isMultiAcademia?: boolean;
}

const { role, nomeCompleto, currentPath, academiaLogoUrl, academiaNome = 'UNAFIT', isMultiAcademia = false } = Astro.props;

// Primeiro nome para saudação
const firstName = nomeCompleto.split(' ')[0];

interface NavItem {
  label: string;
  href: string;
  icon: string;                          // SVG path data (heroicons)
  roles: UserRole[];
  badge?: string;
}

const navItems: NavItem[] = [
  {
    label: 'Dashboard',
    href: '/dashboard',
    icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
    roles: ['saas_admin', 'dono', 'colaborador', 'aluno'],
  },
  // ── Aluno ─────────────────────────────────────────────────────────────────
  {
    label: 'Check-in',
    href: '/dashboard/checkin',
    icon: 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z',
    roles: ['aluno'],
  },
  {
    label: 'Agenda',
    href: '/dashboard/agenda-aluno',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    roles: ['aluno'],
  },
  {
    label: 'Meus Resultados',
    href: '/dashboard/resultados',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    roles: ['aluno'],
  },
  {
    label: 'Minhas Faturas',
    href: '/dashboard/faturas',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    roles: ['aluno'],
  },
  // ── Colaborador + Dono ──────────────────────────────────────────────────────
  {
    label: 'WODs',
    href: '/dashboard/wods',
    icon: 'M13 10V3L4 14h7v7l9-11h-7z',
    roles: ['colaborador', 'dono'],
  },
  {
    label: 'Agenda de Aulas',
    href: '/dashboard/agenda',
    icon: 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
    roles: ['colaborador', 'dono'],
  },
  {
    label: 'Rankings',
    href: '/dashboard/rankings',
    icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z',
    roles: ['colaborador', 'dono'],
  },
  {
    label: 'Aniversariantes',
    href: '/dashboard/aniversariantes',
    icon: 'M21 15.546c-.523 0-1.046.151-1.5.454a2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0 2.704 2.704 0 00-3 0 2.704 2.704 0 01-3 0A1.994 1.994 0 003 15.546M8.5 4h7M9 4V3m6 1V3m-7 8h8m-8 4h5',
    roles: ['colaborador', 'dono'],
  },
  {
    label: 'Alunos',
    href: '/dashboard/alunos',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z',
    roles: ['dono', 'colaborador'],
  },
  {
    label: 'Colaboradores',
    href: '/dashboard/colaboradores',
    icon: 'M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0z',
    roles: ['dono'],
  },
  {
    label: 'Planos',
    href: '/dashboard/planos',
    icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z',
    roles: ['dono'],
  },
  // ── Financeiro (Dono apenas) ───────────────────────────────────────────────
  {
    label: 'Faturas',
    href: '/dashboard/financeiro/faturas',
    icon: 'M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z',
    roles: ['dono'],
    badge: 'Financeiro',
  },
  {
    label: 'Relatórios',
    href: '/dashboard/financeiro/relatorios',
    icon: 'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
    roles: ['dono'],
  },
  // ── Perfil (todos) ────────────────────────────────────────────────────────
  {
    label: 'Meu Perfil',
    href: '/dashboard/perfil',
    icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z',
    roles: ['saas_admin', 'dono', 'colaborador', 'aluno'],
  },
  // ── SaaS Admin ────────────────────────────────────────────────────────────
  {
    label: 'Academias',
    href: '/dashboard/academias',
    icon: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4',
    roles: ['saas_admin'],
    badge: 'Admin',
  },
];

// Filtra itens visíveis para o role atual
const visibleItems = navItems.filter(item => item.roles.includes(role));

// Agrupa por seção para renderizar separadores
const hasFinanceiro = role === 'dono' || role === 'saas_admin';
const hasAdmin      = role === 'saas_admin';

function isActive(href: string) {
  return currentPath === href || (href !== '/dashboard' && currentPath.startsWith(href));
}

const roleLabels: Record<UserRole, string> = {
  saas_admin: 'SaaS Admin',
  dono:       'Dono',
  colaborador:      'Colaborador',
  aluno:      'Aluno',
};
---

<!-- ── Sidebar Desktop ──────────────────────────────────────────────────── -->
<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 w-64 flex flex-col
         bg-[hsl(var(--sidebar-bg))] border-r border-[hsl(var(--sidebar-border))]
         transition-transform duration-300 lg:translate-x-0 -translate-x-full"
>
  <!-- Botão fechar sidebar mobile -->
  <button
    id="sidebar-close"
    class="absolute right-3 top-3 z-50 text-muted-foreground hover:text-foreground lg:hidden"
    aria-label="Fechar menu"
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  <!-- Logo (white label) -->
  <div class="px-4 py-4 border-b border-[hsl(var(--sidebar-border))]">
    {academiaLogoUrl
      ? <img src={academiaLogoUrl} alt={academiaNome} class="w-full h-auto max-h-16 object-contain" />
      : <img src="/logo-unafit.png" alt="UNAFIT" class="w-full h-auto" />
    }
  </div>

  <!-- Nav -->
  <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-0.5">
    {visibleItems.map((item, idx) => {
      const active = isActive(item.href);
      // Separador antes do primeiro item de "Financeiro" e "Admin"
      const showSeparator =
        (item.badge === 'Financeiro' && hasFinanceiro) ||
        (item.badge === 'Admin' && hasAdmin);

      return (
        <>
          {showSeparator && (
            <div class="pt-3 pb-1 px-2">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-muted-foreground">
                {item.badge}
              </p>
            </div>
          )}
          <a
            href={item.href}
            class:list={[
              'group flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              active
                ? 'bg-primary/15 text-primary border border-primary/20'
                : 'text-muted-foreground hover:bg-[hsl(var(--sidebar-item-hover))] hover:text-foreground',
            ]}
          >
            <svg
              class:list={['h-4 w-4 shrink-0', active ? 'text-primary' : 'text-muted-foreground group-hover:text-foreground']}
              fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d={item.icon} />
            </svg>
            {item.label}
            {active && (
              <span class="ml-auto h-1.5 w-1.5 rounded-full bg-primary animate-pulse-glow" />
            )}
          </a>
        </>
      );
    })}
  </nav>

  <!-- Trocar academia (aluno multi-academia) -->
  {isMultiAcademia && (
    <div class="px-3 pb-2">
      <a
        href="/dashboard/selecionar-academia"
        class="flex items-center gap-2.5 rounded-lg border border-primary/20 bg-primary/8 px-3 py-2 text-xs font-medium text-primary hover:bg-primary/15 transition-colors w-full"
      >
        <svg class="h-3.5 w-3.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
        </svg>
        Trocar Academia
      </a>
    </div>
  )}

  <!-- User info -->
  <div class="border-t border-[hsl(var(--sidebar-border))] px-4 py-4">
    <div class="flex items-center gap-3">
      <!-- Avatar inicial -->
      <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary/20 text-primary text-sm font-bold">
        {firstName.charAt(0).toUpperCase()}
      </div>
      <div class="min-w-0 flex-1">
        <p class="truncate text-sm font-medium text-foreground">{firstName}</p>
        <p class="truncate text-xs text-muted-foreground">{roleLabels[role]}</p>
      </div>
      <!-- Logout -->
      <a href="/logout" class="text-muted-foreground hover:text-foreground transition-colors" title="Sair">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
            d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
      </a>
    </div>
  </div>
</aside>

<!-- ── Overlay mobile ──────────────────────────────────────────────────────── -->
<div
  id="sidebar-overlay"
  class="fixed inset-0 z-30 bg-black/60 backdrop-blur-sm lg:hidden hidden"
  aria-hidden="true"
></div>

<script>
  const sidebar  = document.getElementById('sidebar')!;
  const overlay  = document.getElementById('sidebar-overlay')!;
  const openBtn  = document.getElementById('sidebar-open')!;
  const closeBtn = document.getElementById('sidebar-close')!;

  function openSidebar() {
    sidebar.classList.remove('-translate-x-full');
    overlay.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeSidebar() {
    sidebar.classList.add('-translate-x-full');
    overlay.classList.add('hidden');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openSidebar);
  closeBtn?.addEventListener('click', closeSidebar);
  overlay.addEventListener('click', closeSidebar);
</script>
